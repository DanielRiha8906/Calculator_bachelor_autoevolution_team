@startuml
title Session Execution Flows — Interactive and CLI (Issue #406)

|Interactive Session|
|CLI Session|

start

fork
  |Interactive Session|
  :Initialize Calculator,\nOperationRegistry,\nOperationHistory, ErrorLogger;
  :retry_count = 0;

  repeat

    :Display numbered operation menu\n+ "h: View operation history";

    repeat
      :User enters selection;
      if (input == "h" or "history"?) then (yes)
        :display_history_indexed(history);
      else (no)
        if (input is valid index?) then (yes)
          :Resolve op_name from index;
          :Reset retry_count = 0;
        else (no — invalid)
          :log_invalid_operation();
          :retry_count++;
          if (retry_count >= MAX_ATTEMPTS (5)?) then (yes)
            :history.write_to_file();
            stop
          endif
        endif
      endif
    repeat while (valid operation selected?) is (no)
    -> yes;

    :get_arity(op_name);

    repeat
      :User enters operand;
      if (parse_operand() succeeds?) then (yes)
      else (no — ValueError)
        :log_invalid_operand();
        :retry_count++;
        if (retry_count >= MAX_ATTEMPTS (5)?) then (yes)
          :history.write_to_file();
          stop
        endif
      endif
    repeat while (all operands collected?) is (no)
    -> yes;

    :registry.call(op_name, *operands);

    if (call succeeds?) then (yes)
      :history.record(op_name, operands, result);
      :retry_count = 0;
      :Print result;
    elseif (ZeroDivisionError?) then (yes)
      :log_runtime_calculation_error();
      :Print "Error: Division by zero";
    else (other error)
      :log_runtime_calculation_error();
      :Print "Error: {exc}";
    endif

    :User enters "Continue? (yes/no)";

  repeat while (user chose yes?) is (yes)
  -> no;

  :history.write_to_file("history.txt");

fork again

  |CLI Session|
  :Parse argv (op_name, operand strings);
  :Initialize Calculator,\nOperationRegistry,\nErrorLogger, OperationHistory;

  if (op_name valid in registry?) then (yes)
  else (no)
    :log_invalid_operation();
    :Print error to stderr;
    :return 1;
    stop
  endif

  :get_arity(op_name) → required_count;

  if (operand count == required_count?) then (yes)
  else (no)
    :log_incorrect_argument_count();
    :Print error to stderr;
    :return 1;
    stop
  endif

  :parse_cli_operand() for each operand string;

  if (all parse_cli_operand() succeed?) then (yes)
  else (no — ValueError)
    :log_invalid_operand();
    :Print error to stderr;
    :return 1;
    stop
  endif

  :registry.call(op_name, *operands);

  if (call succeeds?) then (yes)
    :history.record(op_name, operands, result);
    :history.write_to_file();
    :Print result to stdout;
    :return 0;
  else (exception)
    :log_runtime_calculation_error();
    :Print error to stderr;
    :return 1;
    stop
  endif

end fork

stop

@enduml
