@startuml sequence_gui_mode_switch

participant User
participant GuiCalculator
participant GUISessionAdapter
participant CalculatorSession

== Phase 1: Button Click (Display Update) ==

User ->> GuiCalculator : click("add")
activate GuiCalculator

GuiCalculator -> GuiCalculator : _on_operation_click("add")
note right: stores _selected_op = "add"

GuiCalculator -> GuiCalculator : symbol = _SYMBOL_MAP.get("add") → "+"

GuiCalculator -> GuiCalculator : update_result("+")
note right: display refreshes to "+"

== Phase 2: Execution (Compute Result) ==

GuiCalculator ->> GUISessionAdapter : execute_operation_safe("add", [5, 3])
activate GUISessionAdapter

GUISessionAdapter ->> CalculatorSession : execute_operation("add", [5, 3])
activate CalculatorSession

CalculatorSession --> GUISessionAdapter : return (8, None)
deactivate CalculatorSession

GUISessionAdapter ->> CalculatorSession : record_history("add", [5, 3], 8)
activate CalculatorSession
CalculatorSession --> GUISessionAdapter : (recorded)
deactivate CalculatorSession

GUISessionAdapter --> GuiCalculator : return ("8", "")
deactivate GUISessionAdapter

GuiCalculator -> GuiCalculator : update_result("8")
note right: display shows "8"

deactivate GuiCalculator

@enduml
