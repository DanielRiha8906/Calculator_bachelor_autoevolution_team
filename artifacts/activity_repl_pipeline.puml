@startuml activity_repl_pipeline
title REPL Request Pipeline — Activity Flow

start

:main() routes to CalculatorREPL;
:Print welcome message and supported operations;

repeat
  :Read line from stdin;

  if (input empty?) then (yes)
    :Skip;
  elseif (input == "history"?) then (yes)
    :Retrieve history from Calculator;
    :Print history entries;
  elseif (input in EXIT_COMMANDS?) then (yes)
    :Print "Goodbye!";
    stop
  else (no)
    :_evaluate(raw_input);

    partition "ExpressionParser.parse()" {
      :Tokenize input string;
      :Lowercase operation token;
      :Coerce operand tokens to Numeric;
      if (Parse error?) then (yes)
        :Return error message;
        note right: skips to retry
      else (no)
        :Return (operation, operands);
      endif
    }

    partition "InputValidator.validate()" {
      :validate_operation(operation);
      if (Unknown operation?) then (yes)
        :Return validation error;
      else (no)
        :validate_operand_count(operation, operands);
        if (Wrong operand count?) then (yes)
          :Return validation error;
        else (no)
        endif
      endif
    }

    partition "_dispatch(operation, operands)" {
      :getattr(Calculator, operation_name);
      :Call method(*operands);

      partition "Calculator → CalculatorEngine" {
        :Delegate to CalculatorEngine method;
        if (Basic operation?) then (yes)
          :BasicOperations.method(operands);
        else (no)
          :AdvancedOperations.method(operands);
        endif
        :_record_history(operand1, op, operand2, result);
        :Return result;
      }

      if (Exception raised?) then (ZeroDivisionError)
        :Return "Math error: division by zero.";
      elseif (ValueError) then (yes)
        :Return "Math error: {exc}";
      elseif (TypeError) then (yes)
        :Return "Type error: {exc}";
      else (success)
        :Return "Result: {result}";
      endif
    }

    if (Response starts with "Result:"?) then (yes)
      :Print result to user;
    else (no)
      :Enter retry loop;
      repeat
        :Print error and prompt retry (attempt N/max);
        :_evaluate(new_input);
      repeat while (Result? or retries exhausted?) is (no error yet)
      if (Max retries reached?) then (yes)
        :Print "Too many invalid attempts";
      else (no)
        :Print result;
      endif
    endif
  endif

repeat while (KeyboardInterrupt or EOF?) is (no)

:Handle interrupt gracefully;
stop

@enduml
