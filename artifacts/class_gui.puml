@startuml
skinparam classAttributeIconSize 0

class Calculator {
  -_history: list[dict]
  -_scientific_mode: bool
  .. Basic ops ..
  +add(a, b) : float
  +subtract(a, b) : float
  +multiply(a, b) : float
  +divide(a, b) : float
  .. Power / Root ..
  +square(a) : float
  +cube(a) : float
  +square_root(a) : float
  +cube_root(a) : float
  +power(base, exp) : float
  +factorial(n) : float
  .. Scientific ..
  +log(a) : float
  +ln(a) : float
  +sin(x) : float
  +cos(x) : float
  +tan(x) : float
  +exp(x) : float
  +get_pi() : float
  +get_e() : float
  .. State ..
  +toggle_scientific_mode()
  +get_history() : list
  +clear_history()
}

class CalculatorGUI {
  == State Management ==
  -current_input: str
  -pending_op: str | None
  -first_operand: float | None
  -scientific_mode: bool
  == Widgets ==
  -root
  -display: Label
  -entry: Entry
  -scientific_buttons: list
  == Calculator Engine ==
  -calc: Calculator
  --
  +__init__(root=None)
  +destroy()
  -_on_number_click(digit: str)
  -_on_operator_click(op: str)
  -_set_operator(op: str)
  -_apply_unary(op: str) : float | None
  -_calculate() : float | None
  -_clear()
  -_on_backspace()
  -_on_sign_toggle()
  -_on_constant_click(op: str)
  -_toggle_scientific_mode()
}

note bottom of CalculatorGUI
  **Digit & Utility Buttons**
  bg=#333333, fg=white, relief=flat
  Keys: 0-9, ., ±, ←, C
  ---
  **Operator Buttons**
  bg=#FF9500, fg=white, relief=flat
  Keys: +, -, *, /, ^, x², x³, √, ∛, log, ln, !, =, Sci/Norm
  ---
  **Scientific Buttons** (hidden by default)
  bg=#FF9500, fg=white, relief=flat
  Keys: sin, cos, tan, asin, acos, atan, sinh, cosh, tanh, exp, π, e
end note

note top of CalculatorGUI
  **Window**
  bg=#000000
  geometry: 350×450
  grid: 11 rows × 5 cols, weight=1
end note

CalculatorGUI ..> Calculator : uses

@enduml
