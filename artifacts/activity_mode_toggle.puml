@startuml
skinparam activityFontSize 12
skinparam activityDiamondFontSize 11
title Mode Toggle Flow — NORMAL ↔ SCIENTIFIC

start

:User clicks mode toggle button;

:_on_mode_toggle();

if (_current_mode == NORMAL?) then (yes)
    :_current_mode = SCIENTIFIC;
else (no)
    :_current_mode = NORMAL;
endif

:_update_mode_toggle_text();
note right
  Button label flips between
  "Scientific" and "Normal"
end note

:_rebuild_bottom_panel();

:Destroy existing _bottom_frame and its buttons;

:Create new _bottom_frame;

if (_current_mode == NORMAL?) then (yes)
    :Operation set: sqrt, square, factorial, ln, log10\n(5 ops across 4-column grid);
else (no)
    :Operation set: all 14 ops\n(cube, cbrt, power, sin, cos,\ntan, cot, asin, acos + NORMAL);
endif

:_build_bottom_panel(parent);

:For each op: _op_button_colours(op_name) → (bg, fg, active_bg);

:_make_button(parent, symbol, bg, fg, active_bg, command);

:grid-place button in 4-column layout;

:bind <Enter> → _on_button_enter;
:bind <Leave> → _on_button_leave;

:Bottom panel updated — new op grid visible;

stop
@enduml
