@startuml
skinparam monochrome true
skinparam shadowing false
skinparam activityFontSize 12
title Mode Toggle — NORMAL ↔ SCIENTIFIC Panel Rebuild

start

:User clicks mode toggle button;

:_on_mode_toggle();

if (_current_mode == NORMAL?) then (yes)
    :_current_mode = SCIENTIFIC;
else (no)
    :_current_mode = NORMAL;
endif

:_update_mode_toggle_text();

note right
  Button label switches between
  "Scientific" and "Normal"
end note

:_rebuild_bottom_panel();

:Destroy existing _bottom_frame and its child buttons;

:Create new _bottom_frame widget;

if (_current_mode == NORMAL?) then (yes)
    :Op set: sqrt, square, factorial, ln, log10\n(5 ops in 4-column grid);
else (no)
    :Op set: NORMAL ops + cube, cbrt, power,\nsin, cos, tan, cot, asin, acos\n(14 ops in 4-column grid);
endif

:_build_bottom_panel(new _bottom_frame);

fork
    :For each op: _op_button_colours(op_name) → (bg, fg, active_bg);
fork again
    :_make_button(parent, symbol, bg, fg, active_bg, command);
end fork

:grid-place each button in 4-column layout;

:bind <Enter> → _on_button_enter;
:bind <Leave> → _on_button_leave;

:Bottom panel updated — new op set visible;

stop
@enduml
