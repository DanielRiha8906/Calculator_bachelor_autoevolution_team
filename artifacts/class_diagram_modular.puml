@startuml
title Modular Calculator Architecture — Class Diagram (Issue #406)

skinparam packageStyle rectangle
skinparam classAttributeIconSize 0

package "Core" {
  class Calculator {
    + add(a, b)
    + subtract(a, b)
    + multiply(a, b)
    + divide(a, b)
    + power(base, exponent)
    + factorial(n: int): int
    + square(x): int/float
    + cube(x): int/float
    + sqrt(x): float
    + cbrt(x): float
    + ln(x): float
    + log10(x): float
  }
}

package "Core Abstractions" {
  enum OperationType {
    UNARY = "unary"
    BINARY = "binary"
  }

  class OperationMetadata <<dataclass>> {
    + name: str
    + arity: int
    + op_type: OperationType
    + description: str
  }

  OperationMetadata --> OperationType
}

package "Discovery" {
  class OperationRegistry {
    - _calculator: Calculator
    - _operations: dict[str, int]
    - _sorted_names: List[str]
    + __init__(calculator: Calculator)
    + get_operations(): List[str]
    + get_arity(name: str): int
    + call(name: str, *args): Any
  }

  OperationRegistry --> Calculator : uses
}

package "Infrastructure" {
  class OperationHistory {
    - _entries: list[str]
    + __init__()
    + record(op_name, operands, result)
    + get_entries(): list[str]
    + display(): str
    + write_to_file(filepath: str)
  }

  note bottom of OperationHistory
    format_history_entry(op_name,
    operands, result): str  [module fn]
  end note

  class ErrorLogger {
    - _log_file: str
    + log_invalid_operation(op_name, msg)
    + log_invalid_operand(op_name, operand, msg)
    + log_incorrect_argument_count(op_name, required, actual, msg)
    + log_runtime_calculation_error(op_name, operands, error_type, msg)
  }
}

package "Session" {
  class SessionManager {
    - _MAX_ATTEMPTS: int = 5
    - _calculator: Calculator
    - _error_logger: ErrorLogger
    - _history: OperationHistory
    - _retry_count: int
    + __init__(calculator, error_logger, history)
    + increment_retry_count(): bool
    + reset_retry_count()
  }

  SessionManager o-- Calculator : has-a
  SessionManager o-- ErrorLogger : has-a
  SessionManager o-- OperationHistory : has-a
}

package "UI" {
  class "interactive.py" as Interactive <<module>> {
    MAX_ATTEMPTS: int = 5
    + run_interactive_session(calculator=None)
    + parse_operand(input: str): Union[int, float]
    + display_history_indexed(history)
  }

  class "cli.py" as CLI <<module>> {
    + run_cli(argv=None): int
    + parse_cli_operand(s: str): Union[int, float]
  }

  Interactive --> Calculator : uses
  Interactive --> OperationRegistry : uses
  Interactive --> OperationHistory : uses
  Interactive --> ErrorLogger : uses

  CLI --> Calculator : uses
  CLI --> OperationRegistry : uses
  CLI --> OperationHistory : uses
  CLI --> ErrorLogger : uses
}

@enduml
