@startuml class_diagram_calculator_io

skinparam classAttributeIconSize 0

class Calculator {
    +add(a, b) : numeric
    +subtract(a, b) : numeric
    +multiply(a, b) : numeric
    +divide(a, b) : float
    +power(x, y) : float
    +factorial(n: int) : int
    +square(x) : float
    +cube(x) : float
    +square_root(x) : float
    +cube_root(x) : float
    +log(x) : float
    +ln(x) : float
}

class InputHandler {
    +history: Any
    +__init__(history: Any = None)
    +display_history() : None
    +get_operation_choice(available_operations: dict, max_retries: int) : str
    +get_operand(prompt: str, max_retries: int) : float
    +display_result(operation: str, operands: list, result: float) : None
    +display_error(message: str) : None
}

class InputRetryExhaustedError {
}
ValueError <|-- InputRetryExhaustedError

InputHandler ..> InputRetryExhaustedError : raises

class OperationRegistry {
    -_registry: dict
    +__init__(calculator: Calculator) : None
    +get_operation(key: str) : tuple
    +list_operations() : dict
    +register_operation(key: str, method: callable, arity: int, description: str) : None
}

OperationRegistry *--> Calculator : holds reference and bound methods

class CalculationEngine {
    -_calculator: Calculator
    -_registry: OperationRegistry
    +__init__(calculator: Calculator, registry: OperationRegistry)
    +execute_operation(operation_key: str, operands: list) : float
}

CalculationEngine *--> Calculator
CalculationEngine *--> OperationRegistry

class UserInterface {
    +display_result(operation, operands, result) : None
    +display_error(message: str) : None
    +display_operations(available_operations: dict) : None
    +display_history(history_str: str) : None
}

class cli {
    +parse_args(argv: list[str]) : tuple[str, list[float]]
    +execute_cli(operation: str, operands: list[float]) : float | int
    +cli_main(argv: list[str]) : void
}

cli --> Calculator : uses in execute_cli
cli --> OperationRegistry : uses in execute_cli

class validation {
    +validate_operand(raw: str) : float
    +validate_operation(choice: str, available_operations: dict) : bool
    +get_validation_error_message(error: Exception) : str
}

class OperandValidationError {
}
ValueError <|-- OperandValidationError

class OperationValidationError {
}
ValueError <|-- OperationValidationError

validation ..> OperandValidationError : raises
validation ..> OperationValidationError : raises

InputHandler ..> validation : uses
cli ..> validation : uses

@enduml
