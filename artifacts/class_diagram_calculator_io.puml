@startuml class_diagram_calculator_io

skinparam classAttributeIconSize 0

class Calculator {
    +add(a, b) : numeric
    +subtract(a, b) : numeric
    +multiply(a, b) : numeric
    +divide(a, b) : float
    +power(x, y) : float
    +factorial(n: int) : int
    +square(x) : float
    +cube(x) : float
    +square_root(x) : float
    +cube_root(x) : float
    +log(x) : float
    +ln(x) : float
}

class InputHandler {
    +get_operation_choice(available_operations: dict) : str
    +get_operand(prompt: str) : float
    +display_result(operation: str, operands: list, result: float) : None
    +display_error(message: str) : None
}

class CLIHandler {
    +parse_arguments(args: list[str]) : tuple[str, list[str]]
    +validate_operands(operands: list[str], arity: int) : list[float]
    +print_result(description: str, operands: list[float], result: float) : None
    +print_error(message: str) : None
    +is_cli_mode(args: list[str]) : bool
}

class OperationRegistry {
    -_registry: dict
    +__init__(calculator: Calculator) : None
    +get_operation(key: str) : tuple
    +list_operations() : dict
}

OperationRegistry *--> Calculator : holds reference and bound methods
CLIHandler ..> OperationRegistry : uses get_operation
InputHandler ..> OperationRegistry : uses list_operations, get_operation

@enduml
