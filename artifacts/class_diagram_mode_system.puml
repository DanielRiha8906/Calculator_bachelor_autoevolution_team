@startuml class_diagram_mode_system

enum CalculatorMode {
  NORMAL = "normal"
  SCIENTIFIC = "scientific"
}

class ModeManager {
  -_current_mode: CalculatorMode
  --
  +__init__(): None
  +get_current_mode(): CalculatorMode
  +switch_mode(): None
  +set_mode(mode: CalculatorMode): None
  +get_mode_display_name(): str
  +is_operation_available(operation_name: str, scientific_operations: set): bool
}

class OperationRegistry {
  -_registry: dict[str, tuple]
  -_scientific_operations: set[str]
  --
  +__init__(calculator: Calculator): None
  +get_operation(key: str): tuple
  +list_operations(): dict
  +register_operation(key: str, method: callable, arity: int, description: str): None
  +register_scientific(key: str, method: callable, arity: int, description: str): None
  +get_scientific_operations(): set
  +get_available_operations(mode_manager: ModeManager = None): dict
  -_register_scientific_defaults(): None
}

ModeManager o-- CalculatorMode : has exactly one active
OperationRegistry --> ModeManager : filters operations using

@enduml
