@startuml sequence_diagram

skinparam ArrowColor #444444
skinparam ParticipantBorderColor #444444
skinparam SequenceLifeLineBorderColor #888888

participant User
participant "__main__" as main
participant "cli" as cli
participant "CalculatorGUI" as gui
participant ModeManager
participant retry_handler
participant input_handler
participant CalculatorWithHistory

alt GUI mode (--gui flag or CALCULATOR_GUI=1)
    User -> main : python -m src --gui
    create gui
    main -> gui : new CalculatorGUI()
    gui -> gui : build tkinter widgets
    main -> gui : run() / mainloop()

    loop User interaction (event-driven)
        User -> gui : button click (digit / operator / function / equals / mode)

        alt Normal mode — equals pressed
            gui -> input_handler : run_calculation(a, b, method_name)
            create CalculatorWithHistory
            input_handler -> CalculatorWithHistory : new CalculatorWithHistory()
            input_handler -> CalculatorWithHistory : e.g. add(a, b)
            alt ZeroDivisionError or ValueError
                CalculatorWithHistory --> input_handler : raises
                input_handler --> gui : propagates
                gui -> User : show error in display (red, auto-clears)
            end
            CalculatorWithHistory --> input_handler : result
            input_handler --> gui : (result, calc)
            gui -> User : update display + history label
        else Scientific mode — equals pressed
            gui -> input_handler : run_unary_calculation(x, method_name)
            create CalculatorWithHistory
            input_handler -> CalculatorWithHistory : new CalculatorWithHistory()
            input_handler -> CalculatorWithHistory : e.g. sin(x)
            alt ValueError
                CalculatorWithHistory --> input_handler : raises
                input_handler --> gui : propagates
                gui -> User : show error in display (red, auto-clears)
            end
            CalculatorWithHistory --> input_handler : result
            input_handler --> gui : (result, calc)
            gui -> User : update display + history label
        else Mode toggle button pressed
            gui -> ModeManager : set_mode("normal" | "scientific")
            gui -> gui : refresh layout (swap button frame)
            gui -> User : updated window
        end
    end
else CLI mode (sys.argv has arguments)
    User -> main : python -m src OPERAND_A OPERATOR OPERAND_B
    main -> cli : cli_main()
    cli -> cli : build_parser().parse_args()

    alt Argument count error or --help
        cli -> User : usage / help text (stdout)
        cli -> cli : sys.exit(0 or 2)
    end

    cli -> input_handler : parse_input(operand_a, operand_b, operator)
else Interactive mode (no sys.argv arguments)
    create ModeManager
    main -> ModeManager : new ModeManager()
    main -> User : print current mode + prompt for mode command
    User -> main : raw mode command (or empty)
    alt "mode science" entered
        main -> ModeManager : set_mode("scientific")
    else "mode normal" entered
        main -> ModeManager : set_mode("normal")
    end

    alt is_scientific() == true
        main -> retry_handler : get_scientific_unary_input_with_retries()

        loop up to MAX_RETRIES times
            retry_handler -> User : prompt for scientific expression
            User -> retry_handler : raw string
            retry_handler -> input_handler : parse_unary_function(raw)
            alt valid
                note right: break loop
            else invalid
                retry_handler -> User : print error + remaining retries
            end
        end

        alt retries exhausted
            retry_handler -> User : "Maximum retries reached. Operation cancelled."
            retry_handler --> main : None
            main -> main : return (no output)
        end

        retry_handler --> main : (method_name, operand)
        main -> input_handler : run_unary_calculation(operand, method_name)
    else is_scientific() == false
    main -> retry_handler : get_input_with_retries()

    loop up to MAX_RETRIES times
        retry_handler -> User : prompt for first operand
        User -> retry_handler : raw string
        retry_handler -> input_handler : parse_operand(raw)
        alt valid
            note right: break loop
        else invalid
            retry_handler -> User : print error + remaining retries
        end
    end

    alt retries exhausted (first operand)
        retry_handler -> User : "Maximum retries reached. Operation cancelled."
        retry_handler --> main : None
        main -> main : return (no output)
    end

    loop up to MAX_RETRIES times
        retry_handler -> User : prompt for second operand
        User -> retry_handler : raw string
        retry_handler -> input_handler : parse_operand(raw)
        alt valid
            note right: break loop
        else invalid
            retry_handler -> User : print error + remaining retries
        end
    end

    alt retries exhausted (second operand)
        retry_handler -> User : "Maximum retries reached. Operation cancelled."
        retry_handler --> main : None
        main -> main : return (no output)
    end

    loop up to MAX_RETRIES times
        retry_handler -> User : prompt for operator
        User -> retry_handler : raw string
        alt operator in BINARY_OPERATORS
            note right: break loop
        else invalid
            retry_handler -> User : print error + remaining retries
        end
    end

    alt retries exhausted (operator)
        retry_handler -> User : "Maximum retries reached. Operation cancelled."
        retry_handler --> main : None
        main -> main : return (no output)
    end

    retry_handler --> main : (first_operand, operator, second_operand)
    main -> input_handler : run_calculation(first_operand, second_operand, method_name)
    end
end

note over cli, input_handler
    CLI parse + dispatch flow
end note

input_handler -> input_handler : parse_operand(operand_a)
input_handler -> input_handler : parse_operand(operand_b)

alt ValueError raised (invalid operand or unsupported operator)
    input_handler --> cli : raises ValueError
    cli -> cli : print error to stderr\nsys.exit(1)
end

input_handler --> cli : return (a, b, method_name)
cli -> input_handler : run_calculation(a, b, method_name)

create CalculatorWithHistory
input_handler -> CalculatorWithHistory : new CalculatorWithHistory()
input_handler -> CalculatorWithHistory : e.g. add(a, b)

alt ZeroDivisionError or ValueError raised
    CalculatorWithHistory --> input_handler : raises exception
    input_handler --> cli : propagates
    cli -> cli : print error to stderr\nsys.exit(1)
end

CalculatorWithHistory --> input_handler : return result
input_handler --> cli : return (result, calc)
cli -> User : print "Result: {result}"

alt --history flag provided
    cli -> CalculatorWithHistory : get_history()
    CalculatorWithHistory --> cli : list[str]
    cli -> User : print "History:" + entries
end

note over main, input_handler
    Interactive dispatch flow (retry path succeeded)
end note

input_handler -> CalculatorWithHistory : run_calculation(first_operand, second_operand, method_name)

alt ZeroDivisionError or ValueError raised
    CalculatorWithHistory --> input_handler : raises exception
    input_handler --> main : propagates
    main -> main : print error to stderr\nsys.exit(1)
end

input_handler --> main : return (result, _calc)
main -> User : print "Result: {result}"

@enduml
