@startuml sequence_diagram

participant "main()" as Main
participant "Calculator" as Calc

Main -> Calc : <<create>>

Main -> Calc : add(10, 5)
Calc --> Main : 15

Main -> Calc : subtract(10, 5)
Calc --> Main : 5

Main -> Calc : multiply(10, 5)
Calc --> Main : 50

Main -> Calc : divide(10, 5)
alt divisor != 0
    Calc --> Main : 2.0
else divisor == 0
    Calc --> Main : ZeroDivisionError
end

Main -> Calc : factorial(5)
alt n is bool
    Calc --> Main : TypeError
else n is float and not integer
    Calc --> Main : TypeError
else n is not int
    Calc --> Main : TypeError
else n < 0
    Calc --> Main : ValueError
else valid n >= 0
    Calc --> Main : 120
end

Main -> Calc : factorial(0)
Calc --> Main : 1

@enduml
