@startuml sequence_diagram

participant "__main__" as Main
participant "CalculatorContext" as Ctx
participant "OperationHistory" as History
participant "ErrorLogger" as ErrLog
participant "GUIInterface" as GUI
participant "REPLInterface" as REPL
participant "OperationRegistry" as OperReg
participant "CLIHandler" as CLI
participant "Calculator" as Calc
participant "CalculationEngine" as Engine
actor "User" as User

note over Calc, Engine
  Calculator (src/calculator.py) delegates arithmetic
  (add/subtract/multiply/divide) to its internal
  CalculationEngine (src/core/engine.py).
  Scientific operations (factorial, square, cube, roots,
  power, log, ln, sin, cos, tan) are handled directly.
  src/operations/ (arithmetic.py, roots.py, scientific.py)
  provides standalone utility functions for direct import;
  not invoked by the OperationRegistry dispatch chain.
end note

Main -> Calc : Calculator()
activate Calc

Main -> History : OperationHistory()
activate History
Main -> History : clear_history()
note over History
  Truncates or creates history.txt
  at session start for isolation.
end note

Main -> ErrLog : ErrorLogger()
activate ErrLog
Main -> ErrLog : clear_errors()
note over ErrLog
  Truncates or creates error.log
  at session start for isolation.
end note

Main -> Ctx : CalculatorContext()
activate Ctx
note over Ctx
  Defaults to mode="normal".
  Single source of truth for mode state.
  Passed to both REPL and CLI.
end note

alt GUI mode (argv contains "--gui")

  Main -> GUI : GUIInterface(calculator, registry, context, history, error_logger)
  activate GUI
  GUI -> OperReg : OperationRegistry(calculator)
  activate OperReg
  GUI -> OperReg : set_mode(context.get_mode())
  note over OperReg
    Same registry used for token resolution,
    arity lookup, dispatch, and mode filtering.
    Operations with mode="scientific" only shown
    when _current_mode == "scientific".
  end note

  Main -> GUI : run()
  note over GUI
    Enters tkinter event loop.
    Mode panel shows current mode; "Switch Mode"
    button toggles normal ↔ scientific and rebuilds
    operation buttons via _build_operation_buttons().
  end note

  loop user interacts with GUI

    alt user clicks "Switch Mode"
      User -> GUI : click "Switch Mode"
      GUI -> Ctx : set_mode(new_mode)
      GUI -> OperReg : set_mode(new_mode)
      GUI -> GUI : _build_operation_buttons()
      GUI -> User : updated mode label and operation buttons
    else user clicks an operation button
      User -> GUI : click operation button
      GUI -> GUI : _on_operation(operation_name, arity)
      GUI -> GUI : _parse_float(operand1_var)
      alt arity == 2
        GUI -> GUI : _parse_float(operand2_var)
      end
      alt operand parsing failed
        GUI -> GUI : _show_error("Invalid operand value")
        GUI -> ErrLog : log_error(INVALID_INPUT, raw_input, exception)
        GUI -> User : display error in result label
      else operands valid
        GUI -> OperReg : dispatch(operation_name, operands)
        alt operation == "logarithm"
          OperReg -> OperReg : validate base (> 0, != 1) and x (> 0)
          OperReg --> GUI : log_base(x)
        else arithmetic operation (add/subtract/multiply/divide)
          OperReg -> Calc : <method_name>(*operands)
          Calc -> Engine : <method_name>(*operands)
          Engine --> Calc : result
          Calc --> OperReg : result
          OperReg --> GUI : result
        else scientific operation (factorial/roots/power/log/trig)
          OperReg -> Calc : <method_name>(*operands)
          Calc --> OperReg : result
          OperReg --> GUI : result
        end
        alt dispatch succeeded
          GUI -> GUI : _result_var.set(str(result))
          GUI -> History : record_operation("op(args) = result")
          GUI -> GUI : _refresh_history_display()
          GUI -> User : display result
        else exception raised
          GUI -> ErrLog : log_error(CALCULATION_ERROR, str(operands), exception)
          GUI -> GUI : _show_error(str(exception))
          GUI -> User : display error in result label
        end
      end
    end

  end

  note over User, GUI
    Loop ends when user closes the window
    (tkinter mainloop exits on window destroy).
  end note

  deactivate OperReg
  deactivate GUI

else REPL mode (argv empty or ["--repl"])

  Main -> REPL : REPLInterface(calculator, history, error_logger, context)
  activate REPL
  REPL -> OperReg : OperationRegistry(calculator)
  activate OperReg
  REPL -> OperReg : set_mode(context.get_mode())
  note over OperReg
    Builds _lookup from _CATALOG (15 operations).
    All names and aliases mapped to Operation objects.
    _current_mode synced from CalculatorContext.
    Operations with mode="scientific" (sin/cos/tan)
    only visible when _current_mode == "scientific".
  end note

  Main -> REPL : run()

  loop until user exits or MaxRetriesExceeded

    REPL -> Ctx : get_mode()
    Ctx --> REPL : current_mode
    REPL -> User : display current mode and operation menu

    loop up to MAX_RETRIES attempts
      User -> REPL : select operation, "mode <name>", "history", or "quit"

      alt "mode <name>" command
        REPL -> Ctx : set_mode(mode_name)
        REPL -> OperReg : set_mode(mode_name)
        REPL -> REPL : _refresh_operations()
        note over REPL
          _refresh_operations() re-queries
          OperationRegistry.get_operations() and
          rebuilds _operation_keys so menu
          numbering reflects the new mode.
        end note
        REPL -> User : print "Mode switched to: <mode_name>"
        REPL -> User : re-display updated menu
      else valid numeric selection
        REPL -> REPL : resolve operation key
      else "history" or "quit"
        REPL -> REPL : return keyword
      else invalid input
        REPL -> REPL : attempts++
        alt attempts >= MAX_RETRIES
          REPL -> REPL : raise MaxRetriesExceeded
          REPL -> User : print "Maximum retry attempts exceeded. Session ended."
          note over REPL
            run() catches MaxRetriesExceeded,
            prints the message, and returns.
          end note
        else
          REPL -> User : "Invalid selection. Enter a number from the list, 'history', 'mode <name>', or 'quit'."
        end
      end
    end

    alt user entered "quit"
      REPL -> User : "Calculator closed."
    else user entered "history"
      REPL -> History : display_history()
      History --> REPL : list[str]
      REPL -> User : print each history entry (or "No history recorded yet.")
    else valid operation selected

      REPL -> User : prompt first operand\n(with last_result as default)

      loop up to MAX_RETRIES attempts
        User -> REPL : enter value (or press Enter for default)
        alt valid float or empty+last_result set
          REPL -> REPL : parse operand
        else invalid input
          REPL -> REPL : attempts++
          alt attempts >= MAX_RETRIES
            REPL -> REPL : raise MaxRetriesExceeded
            REPL -> User : print "Maximum retry attempts exceeded. Session ended."
          else
            REPL -> User : "Invalid number. Please enter a numeric value."
          end
        end
      end

      alt arity == 2
        REPL -> User : prompt second operand
        loop up to MAX_RETRIES attempts
          User -> REPL : enter value
          alt valid float
            REPL -> REPL : parse second operand
          else invalid input
            REPL -> REPL : attempts++
            alt attempts >= MAX_RETRIES
              REPL -> REPL : raise MaxRetriesExceeded
              REPL -> User : print "Maximum retry attempts exceeded. Session ended."
            else
              REPL -> User : "Invalid number. Please enter a numeric value."
            end
          end
        end
      end

      REPL -> REPL : _execute(operation, operands)
      REPL -> OperReg : dispatch(operation, operands)

      alt operation == "logarithm"
        OperReg -> OperReg : validate base (> 0, != 1) and x (> 0)
        note over OperReg
          Handles logarithm as math.log(x, base) directly.
          Calculator.logarithm is base-10 only;
          the two-argument variant lives in the registry.
        end note
        OperReg --> REPL : log_base(x)
      else operation == "add"
        OperReg -> Calc : add(a, b)
        Calc -> Engine : add(a, b)
        Engine --> Calc : a + b
        Calc --> OperReg : result
        OperReg --> REPL : result
      else operation == "subtract"
        OperReg -> Calc : subtract(a, b)
        Calc -> Engine : subtract(a, b)
        Engine --> Calc : a - b
        Calc --> OperReg : result
        OperReg --> REPL : result
      else operation == "multiply"
        OperReg -> Calc : multiply(a, b)
        Calc -> Engine : multiply(a, b)
        Engine --> Calc : a * b
        Calc --> OperReg : result
        OperReg --> REPL : result
      else operation == "divide"
        OperReg -> Calc : divide(a, b)
        Calc -> Engine : divide(a, b)
        Engine -> Engine : check b != 0
        Engine --> Calc : a / b
        Calc --> OperReg : result
        OperReg --> REPL : result
        note over Engine
          divide(a, 0) raises ZeroDivisionError
        end note
      else operation == "factorial"
        OperReg -> Calc : factorial(n)
        Calc -> Calc : validate n (not negative,\nnot non-integer float)
        Calc -> Calc : iterative multiply 1..n
        Calc --> OperReg : n!
        OperReg --> REPL : result
        note over Calc
          factorial(-1) raises ValueError.
          factorial(5.5) raises TypeError.
          factorial(5.0) coerces to int → 120.
        end note
      else operation == "square"
        OperReg -> Calc : square(x)
        Calc --> OperReg : x ** 2
        OperReg --> REPL : result
      else operation == "cube"
        OperReg -> Calc : cube(x)
        Calc --> OperReg : x ** 3
        OperReg --> REPL : result
      else operation == "square_root"
        OperReg -> Calc : square_root(x)
        Calc -> Calc : check x >= 0
        Calc --> OperReg : sqrt(x)
        OperReg --> REPL : result
        note over Calc
          square_root(-1) raises ValueError.
        end note
      else operation == "cube_root"
        OperReg -> Calc : cube_root(x)
        Calc -> Calc : copysign(|x|^(1/3), x)
        Calc --> OperReg : ∛x (sign-preserving)
        OperReg --> REPL : result
      else operation == "power"
        OperReg -> Calc : power(base, exponent)
        Calc --> OperReg : base ** exponent
        OperReg --> REPL : result
      else operation == "natural_logarithm"
        OperReg -> Calc : natural_logarithm(x)
        Calc -> Calc : check x > 0
        Calc --> OperReg : ln(x)
        OperReg --> REPL : result
        note over Calc
          natural_logarithm(0) or negative raises ValueError.
        end note
      else operation == "sin" (scientific mode)
        OperReg -> Calc : sin(x)
        Calc --> OperReg : math.sin(x)
        OperReg --> REPL : result
      else operation == "cos" (scientific mode)
        OperReg -> Calc : cos(x)
        Calc --> OperReg : math.cos(x)
        OperReg --> REPL : result
      else operation == "tan" (scientific mode)
        OperReg -> Calc : tan(x)
        Calc --> OperReg : math.tan(x)
        OperReg --> REPL : result
      end

      alt result returned successfully
        REPL -> REPL : store result as last_result
        REPL -> User : display_result(operation, operands, result)
        REPL -> History : record_operation("op(args) = result")
      else exception raised
        REPL -> User : print error message
        REPL -> ErrLog : log_error(CALCULATION_ERROR, user_input, exception)
      end

    end

  end

  note over User, REPL
    Loop ends when user selects "quit",
    sends EOF (Ctrl-D) / KeyboardInterrupt (Ctrl-C),
    or MaxRetriesExceeded is raised after 3 bad inputs.
  end note

  deactivate OperReg
  deactivate REPL

else CLI mode (argv has operation + operands)

  Main -> CLI : CLIHandler(calculator, history, error_logger, context)
  activate CLI
  CLI -> OperReg : OperationRegistry(calculator)
  activate OperReg
  CLI -> OperReg : set_mode(context.get_mode())
  note over OperReg
    Same registry used for token resolution,
    arity lookup, and dispatch.
    Mode synced from CalculatorContext at startup.
    Scientific operations unavailable in normal mode.
  end note

  Main -> CLI : execute(argv)

  CLI -> CLI : parse_args(argv)
  CLI -> OperReg : resolve(raw_op) — get canonical name
  CLI -> OperReg : arity(raw_op) — validate operand count
  OperReg --> CLI : method_name, expected arity

  alt unknown operation or not in current mode
    CLI -> ErrLog : log_error(UNSUPPORTED_OPERATION, argv[0], exception)
    CLI --> Main : raises ValueError("Unknown operation: ...")
    Main -> User : print error to stderr; exit(2)
  else wrong operand count or non-numeric
    CLI -> ErrLog : log_error(INVALID_INPUT, str(argv), exception)
    CLI --> Main : raises ValueError(...)
    Main -> User : print error to stderr; exit(3)
  end

  CLI -> OperReg : dispatch(method_name, operands)

  alt method_name == "logarithm"
    OperReg -> OperReg : validate base (> 0, != 1) and x (> 0)
    note over OperReg
      Two-argument logarithm handled in registry:
      math.log(x, base) with domain validation.
    end note
    OperReg --> CLI : result
  else arithmetic operation (add/subtract/multiply/divide)
    OperReg -> Calc : <method_name>(*operands)
    Calc -> Engine : <method_name>(*operands)
    Engine --> Calc : result
    Calc --> OperReg : result
    OperReg --> CLI : result
  else scientific operation (factorial/square/etc./sin/cos/tan)
    OperReg -> Calc : <method_name>(*operands)
    Calc --> OperReg : result
    OperReg --> CLI : result
  end

  alt operation succeeded
    CLI -> History : record_operation("op(args) = result")
    CLI --> Main : result
    Main -> User : print result to stdout; exit(0)
  else ZeroDivisionError / domain error
    CLI -> ErrLog : log_error(CALCULATION_ERROR, str(argv), exception)
    CLI --> Main : raises exception
    Main -> User : print error to stderr; exit(4)
  end

  deactivate OperReg
  deactivate CLI

end

deactivate Ctx
deactivate ErrLog
deactivate History
deactivate Calc

@enduml
