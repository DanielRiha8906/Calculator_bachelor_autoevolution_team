@startuml sequence_diagram

participant "__main__" as main
participant "gui_main" as guimain
participant "CLI" as cli
participant "interface.InputParser" as inputparser
participant "interface.MenuRenderer" as menurenderer
participant "core.Operations" as ops
participant "core.OperationRegistry" as oreg
participant "interactive.Session" as session
participant "gui.CalcMode" as mode
participant "gui.CalculatorGUI" as gui
participant "Calculator" as calc
participant "HistoryTracker" as ht
participant "ErrorLogger" as el

alt Interactive Mode (python -m src)

    main -> calc : <<create>>
    main -> ht : <<create>>
    main -> session : run_interactive_session(calculator, history_tracker)

    session -> oreg : <<create>>(calculator)
    oreg -> oreg : _load_normal_operations()
    oreg -> oreg : _load_scientific_operations()
    session -> session : print welcome message
    session -> session : get_mode_selection() → current_mode

    loop interactive session
        alt current_mode == "scientific"
            session -> oreg : get_scientific_operations()
            oreg --> session : active_registry (18 ops)
        else current_mode == "normal"
            session -> oreg : get_normal_operations()
            oreg --> session : active_registry (6 ops)
        end

        session -> menurenderer : display_menu(active_registry, current_mode)
        session -> session : get_operation_choice_with_mode_option(active_registry)

        alt user quit (q / quit / exit)
            session -> ht : save_to_file("history.txt")
            session -> main : return\n(prints "Goodbye.")
        else mode switch request ("m")
            session -> session : get_mode_selection() → current_mode
        else history request ("h")
            session -> ht : display()
        else max validation attempts exceeded → (None, None, None)
            session -> ht : save_to_file("history.txt")
            session -> main : return
        else operation selected
            session -> session : get_operands(arity)

            alt max validation attempts exceeded → None
                session -> ht : save_to_file("history.txt")
                session -> main : return
            else operands collected
                opt method is factorial
                    session -> session : convert whole-valued floats to int
                end

                session -> calc : method(*operands)

                alt success
                    calc --> session : result
                    session -> session : print "Result: {result}"
                    session -> ht : record(operation_name, operands, result)
                else TypeError / ValueError / ZeroDivisionError
                    calc --> session : raises exception
                    session -> el : log_error(error_type, context)
                    session -> session : print error message
                end
            end
        end
    end

else GUI Mode (python -m src.gui_main)

    guimain -> calc : <<create>>
    guimain -> ht : <<create>>
    guimain -> mode : <<create>> SimpleMode(calculator)
    mode -> oreg : <<create>>(calculator)
    oreg -> oreg : _load_normal_operations()
    oreg -> oreg : _load_scientific_operations()
    guimain -> gui : <<create>> CalculatorGUI(root, calculator, mode, history_tracker)
    gui -> gui : _build_ui()
    gui -> mode : get_operations()
    mode -> oreg : get_normal_operations()
    oreg --> mode : ops dict (6 ops)
    mode --> gui : ops dict (6 ops)
    gui -> gui : build display, mode toggle button,\nbutton grid (unified 4-col), history panel

    loop tkinter event loop

        alt digit / decimal / clear button pressed
            gui -> gui : update _current_input, refresh display

        else Mode toggle button pressed (_toggle_mode)
            alt current mode is Simple → switch to Scientific
                gui -> mode : <<create>> ScientificMode(calculator)
                mode -> oreg : <<create>>(calculator)
                gui -> gui : _reset_transient_state()
                gui -> gui : _build_ui()
                gui -> mode : get_operations()
                mode -> oreg : get_scientific_operations()
                oreg --> mode : ops dict (18 ops)
                mode --> gui : ops dict (18 ops)
            else current mode is Scientific → switch to Simple
                gui -> mode : <<create>> SimpleMode(calculator)
                mode -> oreg : <<create>>(calculator)
                gui -> gui : _reset_transient_state()
                gui -> gui : _build_ui()
                gui -> mode : get_operations()
                mode -> oreg : get_normal_operations()
                oreg --> mode : ops dict (6 ops)
                mode --> gui : ops dict (6 ops)
            end

        else unary operation button pressed
            gui -> gui : _parse_current_input() → value
            alt parse failed
                gui -> gui : display "Error: invalid input"
            else value parsed
                opt op is factorial and value is not whole
                    gui -> gui : display "Error: factorial requires an integer"
                end
                gui -> calc : op_callable(value)
                alt success
                    calc --> gui : result
                    gui -> ht : record(op_name, [value], result)
                    gui -> gui : _refresh_history()
                    gui -> gui : update display with result
                else TypeError / ValueError / ZeroDivisionError
                    calc --> gui : raises exception
                    gui -> gui : display "Error: {exc}"
                end
            end

        else binary operation button pressed
            gui -> gui : _parse_current_input() → first_operand
            alt parse failed
                gui -> gui : display "Error: invalid input"
            else value parsed
                gui -> gui : store _first_operand, queue _pending_op
                gui -> gui : clear _current_input
            end

        else = (equals) button pressed
            alt no _pending_op queued
                gui -> gui : no-op
            else binary op pending
                gui -> gui : _parse_current_input() → second_value
                alt parse failed
                    gui -> gui : display "Error: invalid input"
                else second value parsed
                    gui -> calc : op_callable(_first_operand, second_value)
                    alt success
                        calc --> gui : result
                        gui -> ht : record(op_name,\n[_first_operand, second_value], result)
                        gui -> gui : _refresh_history()
                        gui -> gui : update display with result
                        gui -> gui : reset _pending_op, _first_operand
                    else TypeError / ValueError / ZeroDivisionError
                        calc --> gui : raises exception
                        gui -> gui : display "Error: {exc}"
                        gui -> gui : reset _pending_op, _first_operand
                    end
                end
            end

        end
    end

else CLI Mode (execute_cli)

    main -> calc : <<create>>
    main -> cli : parse_arguments(sys.argv)
    cli -> inputparser : parse_cli_args(args)
    inputparser --> cli : (operation_name, operand_strs)
    cli --> main : (operation_name, operand_strs)

    main -> ops : get_operation_registry(calculator)
    ops -> oreg : <<create>>(calculator)
    oreg -> oreg : _load_normal_operations()
    oreg -> oreg : _load_scientific_operations()
    ops -> oreg : get_all_operations()
    oreg --> ops : registry dict (18 ops)
    ops --> main : registry

    main -> cli : execute_cli(operation_name, operand_strs, registry, calculator)

    cli -> cli : lookup operation in registry

    alt invalid operation
        cli -> el : log_error("UNSUPPORTED_OPERATION", context)
        cli -> cli : print error to stderr
        cli --> main : return 1
    else arity mismatch
        cli -> el : log_error("ARGUMENT_COUNT_MISMATCH", context)
        cli -> cli : print error to stderr
        cli --> main : return 1
    else valid
        cli -> inputparser : convert_operand(value) for each operand

        alt operand conversion failed
            cli -> el : log_error("INVALID_OPERAND", context)
            cli -> cli : print error to stderr
            cli --> main : return 1
        else operands converted
            cli -> calc : method(*operands)

            alt success
                calc --> cli : result
                cli -> cli : print result to stdout
                cli --> main : return 0
            else ZeroDivisionError
                calc --> cli : raises ZeroDivisionError
                cli -> el : log_error("DIVISION_BY_ZERO", context)
                cli -> cli : print error to stderr
                cli --> main : return 1
            else TypeError / ValueError
                calc --> cli : raises TypeError / ValueError
                cli -> el : log_error("INVALID_OPERAND", context)
                cli -> cli : print error to stderr
                cli --> main : return 1
            end
        end
    end

end

@enduml
