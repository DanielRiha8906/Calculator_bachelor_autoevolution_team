@startuml sequence_diagram

participant "__main__" as Main
participant "Calculator" as Calc

Main -> Calc : Calculator()
activate Calc

Main -> Calc : add(10, 5)
Calc --> Main : 15

Main -> Calc : subtract(10, 5)
Calc --> Main : 5

Main -> Calc : multiply(10, 5)
Calc --> Main : 50

Main -> Calc : divide(10, 5)
Calc -> Calc : check b != 0
Calc --> Main : 2.0

note over Main, Calc
  If divide(a, 0) is called:
  ZeroDivisionError is raised
end note

Main -> Calc : factorial(5)
Calc -> Calc : validate n (not negative,\nnot non-integer float)
Calc -> Calc : iterative multiply 1..5
Calc --> Main : 120

Main -> Calc : factorial(0)
Calc --> Main : 1

note over Main, Calc
  factorial(-1) raises ValueError.
  factorial(5.5) raises TypeError.
  factorial(5.0) coerces to int and returns 120.
end note

deactivate Calc

@enduml
