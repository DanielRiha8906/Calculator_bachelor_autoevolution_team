@startuml sequence_diagram

participant "__main__" as Main
participant "OperationHistory" as History
participant "ErrorLogger" as ErrLog
participant "REPLInterface" as REPL
participant "OperationRegistry" as OperReg
participant "CLIHandler" as CLI
participant "Calculator" as Calc
actor "User" as User

Main -> Calc : Calculator()
activate Calc

Main -> History : OperationHistory()
activate History
Main -> History : clear_history()
note over History
  Truncates or creates history.txt
  at session start for isolation.
end note

Main -> ErrLog : ErrorLogger()
activate ErrLog
Main -> ErrLog : clear_errors()
note over ErrLog
  Truncates or creates error.log
  at session start for isolation.
end note

alt REPL mode (argv empty or ["--repl"])

  Main -> REPL : REPLInterface(calculator, history, error_logger)
  activate REPL
  REPL -> OperReg : OperationRegistry(calculator)
  activate OperReg
  note over OperReg
    Builds _lookup from _CATALOG (12 operations).
    All names and aliases mapped to Operation objects.
  end note

  Main -> REPL : run()

  loop until user exits or MaxRetriesExceeded

    REPL -> User : display operation menu

    loop up to MAX_RETRIES attempts
      User -> REPL : select operation (e.g. "1", "history", or "quit")
      alt valid selection
        REPL -> REPL : resolve operation key
      else invalid input
        REPL -> REPL : attempts++
        alt attempts >= MAX_RETRIES
          REPL -> REPL : raise MaxRetriesExceeded
          REPL -> User : print "Maximum retry attempts exceeded. Session ended."
          note over REPL
            run() catches MaxRetriesExceeded,
            prints the message, and returns.
          end note
        else
          REPL -> User : "Invalid selection. Enter a number from the list or 'quit'."
        end
      end
    end

    alt user entered "quit"
      REPL -> User : "Calculator closed."
    else user entered "history"
      REPL -> History : display_history()
      History --> REPL : list[str]
      REPL -> User : print each history entry (or "No history recorded yet.")
    else valid operation selected

      REPL -> User : prompt first operand\n(with last_result as default)

      loop up to MAX_RETRIES attempts
        User -> REPL : enter value (or press Enter for default)
        alt valid float or empty+last_result set
          REPL -> REPL : parse operand
        else invalid input
          REPL -> REPL : attempts++
          alt attempts >= MAX_RETRIES
            REPL -> REPL : raise MaxRetriesExceeded
            REPL -> User : print "Maximum retry attempts exceeded. Session ended."
          else
            REPL -> User : "Invalid number. Please enter a numeric value."
          end
        end
      end

      alt arity == 2
        REPL -> User : prompt second operand
        loop up to MAX_RETRIES attempts
          User -> REPL : enter value
          alt valid float
            REPL -> REPL : parse second operand
          else invalid input
            REPL -> REPL : attempts++
            alt attempts >= MAX_RETRIES
              REPL -> REPL : raise MaxRetriesExceeded
              REPL -> User : print "Maximum retry attempts exceeded. Session ended."
            else
              REPL -> User : "Invalid number. Please enter a numeric value."
            end
          end
        end
      end

      REPL -> REPL : _execute(operation, operands)
      REPL -> OperReg : dispatch(operation, operands)

      alt operation == "logarithm"
        OperReg -> OperReg : validate base (> 0, != 1) and x (> 0)
        note over OperReg
          Handles logarithm as math.log(x, base) directly.
          Calculator.logarithm is base-10 only;
          the two-argument variant lives in the registry.
        end note
        OperReg --> REPL : log_base(x)
      else operation == "add"
        OperReg -> Calc : add(a, b)
        Calc --> OperReg : a + b
        OperReg --> REPL : result
      else operation == "subtract"
        OperReg -> Calc : subtract(a, b)
        Calc --> OperReg : a - b
        OperReg --> REPL : result
      else operation == "multiply"
        OperReg -> Calc : multiply(a, b)
        Calc --> OperReg : a * b
        OperReg --> REPL : result
      else operation == "divide"
        OperReg -> Calc : divide(a, b)
        Calc -> Calc : check b != 0
        Calc --> OperReg : a / b
        OperReg --> REPL : result
        note over Calc
          divide(a, 0) raises ZeroDivisionError
        end note
      else operation == "factorial"
        OperReg -> Calc : factorial(n)
        Calc -> Calc : validate n (not negative,\nnot non-integer float)
        Calc -> Calc : iterative multiply 1..n
        Calc --> OperReg : n!
        OperReg --> REPL : result
        note over Calc
          factorial(-1) raises ValueError.
          factorial(5.5) raises TypeError.
          factorial(5.0) coerces to int → 120.
        end note
      else operation == "square"
        OperReg -> Calc : square(x)
        Calc --> OperReg : x ** 2
        OperReg --> REPL : result
      else operation == "cube"
        OperReg -> Calc : cube(x)
        Calc --> OperReg : x ** 3
        OperReg --> REPL : result
      else operation == "square_root"
        OperReg -> Calc : square_root(x)
        Calc -> Calc : check x >= 0
        Calc --> OperReg : sqrt(x)
        OperReg --> REPL : result
        note over Calc
          square_root(-1) raises ValueError.
        end note
      else operation == "cube_root"
        OperReg -> Calc : cube_root(x)
        Calc -> Calc : copysign(|x|^(1/3), x)
        Calc --> OperReg : ∛x (sign-preserving)
        OperReg --> REPL : result
      else operation == "power"
        OperReg -> Calc : power(base, exponent)
        Calc --> OperReg : base ** exponent
        OperReg --> REPL : result
      else operation == "natural_logarithm"
        OperReg -> Calc : natural_logarithm(x)
        Calc -> Calc : check x > 0
        Calc --> OperReg : ln(x)
        OperReg --> REPL : result
        note over Calc
          natural_logarithm(0) or negative raises ValueError.
        end note
      end

      alt result returned successfully
        REPL -> REPL : store result as last_result
        REPL -> User : display_result(operation, operands, result)
        REPL -> History : record_operation("op(args) = result")
      else exception raised
        REPL -> User : print error message
        REPL -> ErrLog : log_error(CALCULATION_ERROR, user_input, exception)
      end

    end

  end

  note over User, REPL
    Loop ends when user selects "quit",
    sends EOF (Ctrl-D) / KeyboardInterrupt (Ctrl-C),
    or MaxRetriesExceeded is raised after 3 bad inputs.
  end note

  deactivate OperReg
  deactivate REPL

else CLI mode (argv has operation + operands)

  Main -> CLI : CLIHandler(calculator, history, error_logger)
  activate CLI
  CLI -> OperReg : OperationRegistry(calculator)
  activate OperReg
  note over OperReg
    Same registry used for token resolution,
    arity lookup, and dispatch.
  end note

  Main -> CLI : execute(argv)

  CLI -> CLI : parse_args(argv)
  CLI -> OperReg : resolve(raw_op) — get canonical name
  CLI -> OperReg : arity(raw_op) — validate operand count
  OperReg --> CLI : method_name, expected arity

  alt unknown operation
    CLI -> ErrLog : log_error(UNSUPPORTED_OPERATION, argv[0], exception)
    CLI --> Main : raises ValueError("Unknown operation: ...")
    Main -> User : print error to stderr; exit(2)
  else wrong operand count or non-numeric
    CLI -> ErrLog : log_error(INVALID_INPUT, str(argv), exception)
    CLI --> Main : raises ValueError(...)
    Main -> User : print error to stderr; exit(3)
  end

  CLI -> OperReg : dispatch(method_name, operands)

  alt method_name == "logarithm"
    OperReg -> OperReg : validate base (> 0, != 1) and x (> 0)
    note over OperReg
      Two-argument logarithm handled in registry:
      math.log(x, base) with domain validation.
    end note
    OperReg --> CLI : result
  else any other operation
    OperReg -> Calc : <method_name>(*operands)
    Calc --> OperReg : result
    OperReg --> CLI : result
  end

  alt operation succeeded
    CLI -> History : record_operation("op(args) = result")
    CLI --> Main : result
    Main -> User : print result to stdout; exit(0)
  else ZeroDivisionError / domain error
    CLI -> ErrLog : log_error(CALCULATION_ERROR, str(argv), exception)
    CLI --> Main : raises exception
    Main -> User : print error to stderr; exit(4)
  end

  deactivate OperReg
  deactivate CLI

end

deactivate ErrLog
deactivate History
deactivate Calc

@enduml
