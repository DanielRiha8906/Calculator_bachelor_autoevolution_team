@startuml Calculator Sequence — Typical Interaction

title Calculator Sequence — Typical Interaction

' -----------------------------------------------------------------------
' Entry-point dispatch (src/__main__.py)
' -----------------------------------------------------------------------
== Entry Point — src/__main__.py main() ==

actor User as ep_user
participant "src/__main__\nmain()" as entry

ep_user -> entry : python -m src [--gui]
note over entry : calc = Calculator()
alt "--gui" in sys.argv
    note over entry : import tkinter as tk\nimport GuiCalculator (conditional)
    entry -> entry : root = tk.Tk()
    entry -> entry : GuiCalculator(root, calc).run()\n[enters Tk event loop — see GUI Mode section]
else default (no --gui flag)
    entry -> entry : run_session(calc)\n[enters interactive CLI session — see below]
end

' -----------------------------------------------------------------------
' Interactive CLI session (InputHandler)
' -----------------------------------------------------------------------
== Interactive CLI Session (InputHandler / run_session) ==

actor User
participant "__main__" as main
participant "InputHandler" as handler
participant "OperationDispatcher" as op_disp
boundary "OPERATIONS\n(src/operations/__init__.py)" as ops
participant "Calculator" as calc
participant "Logger" as log

main -> calc : calc = Calculator()
main -> handler : handler = InputHandler(calc)\n[via run_session(calc)]
note over handler : InputHandler.__init__ creates\nself._dispatcher = OperationDispatcher(calc)
handler -> op_disp : OperationDispatcher(calc)
main -> handler : handler.run()
note over handler : Lazy: Logger() created on\nfirst call to run()

loop session active
    handler -> handler : _show_menu()\n[filters OPERATIONS by _mode]
    handler -> ops : iterate _get_available_operations_for_mode().items()
    ops --> handler : key, info pairs (filtered by Mode)
    handler -> User : print available operations menu\n(header shows current mode)

    handler -> User : prompt "Enter operation (or 'exit'/'quit' to stop):"

    alt user enters mode-switch command
        User --> handler : "mode scientific"
        note over handler : parse_mode_command("mode scientific")\nreturns Mode.SCIENTIFIC
        handler -> handler : self._mode = Mode.SCIENTIFIC
        handler -> User : print "Mode switched to: Scientific"
        note over handler : continue — loop back to _show_menu()
    else user enters a normal operation
        User --> handler : "add"

        note over handler : parse_mode_command("add") returns None\nop_choice not in ("exit","quit")

        handler -> handler : _get_available_operations_for_mode()
        handler -> ops : check if "add" in available ops for current mode
        ops --> handler : True (add is a NORMAL_OPERATIONS key)

        handler -> ops : OPERATIONS["add"]
        ops --> handler : { method:"add", arity:2, label:... }

        handler -> handler : _prompt_operands(arity=2, coerce=float)
        handler -> User : prompt "Enter first operand:"
        User --> handler : "10"
        handler -> op_disp : coerce_operands(["10"], float)
        op_disp --> handler : [10.0]
        handler -> User : prompt "Enter second operand:"
        User --> handler : "5"
        handler -> op_disp : coerce_operands(["5"], float)
        op_disp --> handler : [5.0]
        note over handler : operands = [10.0, 5.0]

        handler -> handler : _dispatch("add", [10.0, 5.0])
        handler -> op_disp : dispatch("add", [10.0, 5.0])
        op_disp -> ops : OPERATIONS["add"]["method"]
        ops --> op_disp : "add"
        op_disp -> calc : getattr(calculator, "add")(10.0, 5.0)
        calc --> op_disp : 15.0
        op_disp --> handler : 15.0

        handler -> User : print "Result: 15.0"
    else user enters a scientific op in Normal mode
        User --> handler : "sin"
        note over handler : parse_mode_command("sin") returns None\n"sin" is in OPERATIONS but NOT in available ops\n(current mode is NORMAL)
        handler -> handler : _get_available_operations_for_mode()
        handler -> User : print "Error: 'sin' is only available in scientific mode.\nType 'mode scientific' to switch."
        note over handler : continue — op_attempts not incremented
    end

    handler -> User : prompt "Enter operation (or 'exit'/'quit' to stop):"
    User --> handler : "quit"

    note over handler : op_choice == "quit" — exit condition met
    handler -> User : print "Goodbye!"
end

handler --> main : return (run() exits)

' -----------------------------------------------------------------------
' CLI invocation sequence
' -----------------------------------------------------------------------
== CLI Mode (main.py) ==

actor User as cli_user
participant "main.py\nmain()" as cli_main
participant "CliDispatcher" as dispatcher
participant "OperationDispatcher" as cli_op_disp
boundary "OPERATIONS\n(src/operations/__init__.py)" as cli_ops
participant "Calculator" as cli_calc

cli_user -> cli_main : python main.py add 5 7
cli_main -> cli_calc : calc = Calculator()
cli_main -> dispatcher : dispatcher = CliDispatcher(calc)
note over dispatcher : CliDispatcher.__init__ creates\nself._dispatcher = OperationDispatcher(calc)
dispatcher -> cli_op_disp : OperationDispatcher(calc)
cli_main -> dispatcher : dispatch_from_args(["add", "5", "7"])
note over dispatcher : Lazy: Logger() created on\nfirst call to dispatch_from_args()

dispatcher -> cli_ops : "add" in OPERATIONS?
cli_ops --> dispatcher : True — { method:"add", arity:2, coerce:float }

note over dispatcher : len(["5","7"]) == arity(2) — OK

dispatcher -> dispatcher : _coerce_operands(["5","7"], float)
dispatcher -> cli_op_disp : coerce_operands(["5"], float)
cli_op_disp --> dispatcher : [5.0]
dispatcher -> cli_op_disp : coerce_operands(["7"], float)
cli_op_disp --> dispatcher : [7.0]
note over dispatcher : operands = [5.0, 7.0]

dispatcher -> dispatcher : _dispatch("add", [5.0, 7.0])
dispatcher -> cli_op_disp : dispatch("add", [5.0, 7.0])
cli_op_disp -> cli_ops : OPERATIONS["add"]["method"]
cli_ops --> cli_op_disp : "add"
cli_op_disp -> cli_calc : getattr(calculator, "add")(5.0, 7.0)
cli_calc --> cli_op_disp : 12.0
cli_op_disp --> dispatcher : 12.0

dispatcher -> cli_user : print("12.0")  [stdout]
dispatcher --> cli_main : return 0
cli_main -> cli_main : sys.exit(0)

' -----------------------------------------------------------------------
' GUI mode sequence (button-driven flow — iOS-style redesign)
' -----------------------------------------------------------------------
== GUI Mode (GuiCalculator) — Binary Operation Flow ==

actor User as gui_user
participant "GuiCalculator" as gui
participant "BaseMode" as base_mode
participant "OperationDispatcher" as gui_op_disp
boundary "OPERATIONS\n(src/operations/__init__.py)" as gui_ops
participant "Calculator" as gui_calc

gui_user -> gui : GuiCalculator(root, Calculator())
note over gui : __init__ creates OperationDispatcher,\nBaseMode, History, mode=NORMAL\n_display_value="0", _first_operand=None,\n_pending_op_key=None, _last_was_operator=False
gui -> base_mode : BaseMode()
gui -> gui : _setup_layout() — builds display label,\nmode toggle button, digit pad, op buttons

gui_user -> gui : click digit "1"
gui -> gui : _on_digit_click("1")
note over gui : _display_value="1"\n_last_was_operator=False
gui -> gui : _update_display()
gui -> gui_user : display shows "1"

gui_user -> gui : click digit "0"
gui -> gui : _on_digit_click("0")
note over gui : _display_value="10"
gui -> gui : _update_display()
gui -> gui_user : display shows "10"

gui_user -> gui : click binary op button "+"
gui -> gui : _on_binary_op_click("add")
note over gui : _first_operand=10.0\n_pending_op_key="add"\n_last_was_operator=True

gui_user -> gui : click digit "5"
gui -> gui : _on_digit_click("5")
note over gui : _last_was_operator was True → reset\n_display_value="5"
gui -> gui : _update_display()
gui -> gui_user : display shows "5"

gui_user -> gui : click "="
gui -> gui : _on_equals_click()
note over gui : _pending_op_key="add", _first_operand=10.0\nsecond_operand=float("5")=5.0
gui -> gui_op_disp : dispatch("add", [10.0, 5.0])
gui_op_disp -> gui_ops : OPERATIONS["add"]["method"]
gui_ops --> gui_op_disp : "add"
gui_op_disp -> gui_calc : getattr(calculator, "add")(10.0, 5.0)
gui_calc --> gui_op_disp : 15.0
gui_op_disp --> gui : 15.0
note over gui : _display_value="15"\n_pending_op_key=None\n_first_operand=None\n_last_was_operator=True
gui -> gui : _update_display()
gui -> gui_user : display shows "15"

== GUI Mode (GuiCalculator) — Unary Operation Flow ==

gui_user -> gui : click digit "9"
gui -> gui : _on_digit_click("9")
note over gui : _last_was_operator was True → reset\n_display_value="9"
gui -> gui : _update_display()
gui -> gui_user : display shows "9"

gui_user -> gui : click unary op "√" (square_root)
gui -> gui : _on_unary_op_click("square_root")
note over gui : arity=1, operands=[9.0]
gui -> gui_op_disp : dispatch("square_root", [9.0])
gui_op_disp -> gui_ops : OPERATIONS["square_root"]["method"]
gui_ops --> gui_op_disp : "square_root"
gui_op_disp -> gui_calc : getattr(calculator, "square_root")(9.0)
gui_calc --> gui_op_disp : 3.0
gui_op_disp --> gui : 3.0
note over gui : _display_value="3"\n_last_was_operator=True
gui -> gui : _update_display()
gui -> gui_user : display shows "3"

== GUI Mode (GuiCalculator) — Mode Toggle Flow ==

gui_user -> gui : click "Scientific" toggle button
gui -> gui : _on_mode_toggle_click()
note over gui : _mode switches NORMAL → SCIENTIFIC
gui -> gui : _on_clear_click() — resets all state
gui -> gui : _build_operation_buttons()
gui -> base_mode : get_available_operations(Mode.SCIENTIFIC)
base_mode --> gui : full OPERATIONS dict (including trig, pi, e)
note over gui : Rebuilds op column with scientific buttons\ntoggle button text → "Normal"
gui -> gui_user : display shows "0", expanded op panel visible

@enduml
