@startuml sequence_diagram

participant "__main__" as main
participant "CLI" as cli
participant "InputHandler" as ih
participant "Calculator" as calc

alt Interactive Mode (python -m src)

    main -> calc : <<create>>
    main -> ih : run_interactive_session(calculator)

    ih -> ih : get_operation_registry(calculator)
    ih -> ih : print welcome message

    loop interactive session
        ih -> ih : display_menu(registry)
        ih -> ih : get_operation_choice(registry)

        alt user quit (q / quit / exit)
            ih -> main : return\n(prints "Goodbye.")
        else max validation attempts exceeded → (None, None)
            ih -> main : return\n(prints "Too many invalid attempts. Exiting.")
        else operation selected
            ih -> ih : get_operands(arity)

            alt max validation attempts exceeded → None
                ih -> main : return\n(prints "Too many invalid attempts. Exiting.")
            else operands collected
                opt method is factorial
                    ih -> ih : convert whole-valued floats to int
                end

                ih -> calc : method(*operands)

                alt success
                    calc --> ih : result
                    ih -> ih : print "Result: {result}"
                else TypeError / ValueError / ZeroDivisionError
                    calc --> ih : raises exception
                    ih -> ih : print error message
                end
            end
        end
    end

else CLI Mode (execute_cli)

    main -> calc : <<create>>
    main -> cli : parse_arguments(sys.argv)
    cli --> main : (operation_name, operand_strs)

    main -> ih : get_operation_registry(calculator)
    ih --> main : registry

    main -> cli : execute_cli(operation_name, operand_strs, registry, calculator)

    cli -> cli : lookup operation in registry

    alt invalid operation or arity mismatch
        cli -> cli : print error to stderr
        cli --> main : return 1
    else valid
        cli -> cli : convert_operand(value) for each operand
        cli -> calc : method(*operands)

        alt success
            calc --> cli : result
            cli -> cli : print result to stdout
            cli --> main : return 0
        else TypeError / ValueError / ZeroDivisionError
            calc --> cli : raises exception
            cli -> cli : print error to stderr
            cli --> main : return 1
        end
    end

end

@enduml
