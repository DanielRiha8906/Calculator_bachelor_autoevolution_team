@startuml
title Calculator — Sequence Diagram (interactive divide + CLI add scenarios)

participant User
participant Main
participant CLI
participant InputLoop
participant RetryLogic
participant Calculator

== CLI mode (e.g. python -m src add 3 5) ==

User -> Main : sys.argv = ["add", "3", "5"]
Main -> CLI : run_cli()
note over CLI
  CLI mode validation is one-pass:
  invalid input exits immediately with code 2.
  Retry logic is not used here.
end note
CLI -> CLI : _build_parser() — build argparse parser
CLI -> CLI : validate operation in OPERATIONS
CLI -> CLI : validate operand count == 2
CLI -> CLI : parse operands as float: [3.0, 5.0]
CLI -> Calculator : create Calculator()
CLI -> InputLoop : dispatch("add", [3.0, 5.0], calc)
InputLoop -> Calculator : add(3.0, 5.0)
Calculator --> InputLoop : return 8.0
InputLoop --> CLI : return 8.0
CLI -> User : print("8.0")

alt CLI error path (unknown operation)
  User -> Main : sys.argv = ["badop", "1"]
  Main -> CLI : run_cli()
  CLI -> CLI : validate operation — not in OPERATIONS
  CLI -> User : print error to stderr
  CLI -> Main : sys.exit(2)
end

== Interactive mode (no CLI args) ==

User -> Main : sys.argv = []
Main -> InputLoop : run_loop()

loop until "exit"

  InputLoop -> User : print_menu()
  InputLoop -> RetryLogic : retry_get_operation(input_fn, _get_operation_fn=get_operation)
  RetryLogic -> InputLoop : get_operation(input_fn) => "divide"
  InputLoop --> RetryLogic : return "divide"
  RetryLogic --> InputLoop : return "divide"
  InputLoop -> InputLoop : look up operand_count = 2
  InputLoop -> RetryLogic : retry_get_operands(2, input_fn, _get_operands_fn=get_operands)
  RetryLogic -> InputLoop : get_operands(2, input_fn) — prompt operand 1
  User -> InputLoop : "10"
  InputLoop -> RetryLogic : (continuing) — prompt operand 2
  User -> InputLoop : "2"
  InputLoop --> RetryLogic : return [10.0, 2.0]
  RetryLogic --> InputLoop : return [10.0, 2.0]
  InputLoop -> Calculator : dispatch("divide", [10.0, 2.0])
  Calculator -> Calculator : divide(10.0, 2.0) — b != 0, returns 5.0
  Calculator --> InputLoop : return 5.0
  InputLoop -> User : print("Result: 5.0")

  alt Retry path — invalid operation input (within one menu cycle, MAX_RETRIES=3)
    InputLoop -> User : print_menu()
    InputLoop -> RetryLogic : retry_get_operation(input_fn, _get_operation_fn=get_operation)
    RetryLogic -> InputLoop : get_operation(input_fn) => "__invalid__" (attempt 1/3)
    RetryLogic -> User : print("Invalid operation. 2 attempt(s) remaining.")
    RetryLogic -> InputLoop : get_operation(input_fn) => "add" (attempt 2/3)
    InputLoop --> RetryLogic : return "add"
    RetryLogic --> InputLoop : return "add"
    InputLoop -> InputLoop : proceed normally with "add"
  end

  alt Max-retries-exceeded path — 3 consecutive invalid operation inputs
    note over InputLoop, RetryLogic
      After MAX_RETRIES (3) invalid operation inputs in a single menu cycle,
      retry_get_operation returns "__exhausted__".
      run_loop prints a warning and continues to the next menu cycle
      (does NOT terminate the session).
    end note
    InputLoop -> User : print_menu()
    InputLoop -> RetryLogic : retry_get_operation(input_fn, _get_operation_fn=get_operation)
    RetryLogic -> InputLoop : get_operation(input_fn) => "__invalid__" (attempt 1/3)
    RetryLogic -> User : print("Invalid operation. 2 attempt(s) remaining.")
    RetryLogic -> InputLoop : get_operation(input_fn) => "__invalid__" (attempt 2/3)
    RetryLogic -> User : print("Invalid operation. 1 attempt(s) remaining.")
    RetryLogic -> InputLoop : get_operation(input_fn) => "__invalid__" (attempt 3/3)
    RetryLogic --> InputLoop : return "__exhausted__"
    InputLoop -> User : print("Too many failed attempts. Please try again.")
    InputLoop -> InputLoop : continue — loop back to top of menu
  end

  alt Error path (b == 0)
    InputLoop -> User : print_menu()
    InputLoop -> RetryLogic : retry_get_operation(input_fn, _get_operation_fn=get_operation)
    RetryLogic -> InputLoop : get_operation(input_fn) => "divide"
    InputLoop --> RetryLogic : return "divide"
    RetryLogic --> InputLoop : return "divide"
    InputLoop -> InputLoop : look up operand_count = 2
    InputLoop -> RetryLogic : retry_get_operands(2, input_fn, _get_operands_fn=get_operands)
    RetryLogic -> InputLoop : get_operands(2, input_fn) — prompt operand 1
    User -> InputLoop : "10"
    RetryLogic -> InputLoop : (continuing) — prompt operand 2
    User -> InputLoop : "0"
    InputLoop --> RetryLogic : return [10.0, 0.0]
    RetryLogic --> InputLoop : return [10.0, 0.0]
    InputLoop -> Calculator : dispatch("divide", [10.0, 0.0])
    Calculator -> Calculator : divide(10.0, 0.0) — b == 0, raises ValueError
    Calculator --> InputLoop : raise ValueError("Division by zero is not allowed")
    InputLoop -> User : print("Error: Division by zero is not allowed")
  end

end

User -> InputLoop : get_operation() => "exit"
RetryLogic --> InputLoop : return None
InputLoop -> User : print("Goodbye!")
InputLoop --> Main : return (run_loop ends)

@enduml
