@startuml sequence_diagram

actor User
participant "__main__" as Main
participant "cli" as CLI
participant "user_input" as UI
participant "input_retry" as IR
participant "Calculator" as Calc
participant "math" as Math

User -> Main : python -m src [args...]
Main -> Main : main()

alt sys.argv has arguments (CLI mode)

    Main -> CLI : run_cli(sys.argv[1:])
    CLI -> CLI : expression = " ".join(args)
    CLI -> Calc : <<create>>
    CLI -> CLI : parse_and_evaluate(expression, calc)
    CLI -> CLI : ast.parse(expression, mode="eval")

    loop recursive _eval_node traversal
        alt ast.Constant
            CLI -> CLI : return constant value
        else ast.UnaryOp (USub)
            CLI -> Calc : multiply(operand, -1)
            Calc --> CLI : negated value
        else ast.BinOp Add
            CLI -> Calc : add(left, right)
            Calc --> CLI : result
        else ast.BinOp Sub
            CLI -> Calc : subtract(left, right)
            Calc --> CLI : result
        else ast.BinOp Mult
            CLI -> Calc : multiply(left, right)
            Calc --> CLI : result
        else ast.BinOp Div
            CLI -> Calc : divide(left, right)
            alt b == 0
                Calc --> CLI : ZeroDivisionError
                CLI --> User : "Error: Division by zero is not allowed." (stderr)
                CLI --> Main : exit code 1
            else b != 0
                Calc --> CLI : a / b
            end
        else ast.BinOp Pow
            CLI -> Calc : power(left, right)
            Calc --> CLI : float result
        else unsupported node / syntax error / empty expression
            CLI --> User : error message (stderr)
            CLI --> Main : exit code 1
        end
    end

    CLI --> User : result (stdout)
    CLI --> Main : exit code 0

else no arguments (interactive mode)

    Main -> UI : run_interactive()
    UI -> Calc : <<create>>
    note right of UI : MAX_RETRIES = DEFAULT_MAX_RETRIES (3)\nfrom input_retry module
    UI -> User : display numbered operation list

    loop until quit or retry limit reached
        UI -> User : prompt "Select operation:"
        User -> UI : operation name or 'quit'/'exit'

        alt input is 'quit' or 'exit'
            UI -> User : "Bye!"
            UI --> Main : return
        else unknown operation (op_attempts < MAX_RETRIES)
            UI -> User : unknown-operation error message
        else unknown operation (op_attempts >= MAX_RETRIES)
            UI -> User : max-retries-exceeded error
            UI --> Main : return
        else valid operation

            loop for each required operand (up to MAX_RETRIES per operand)
                UI -> User : prompt "Enter operand [n]:"
                User -> UI : raw string
                UI -> UI : parse_number(raw)
                alt parse fails and attempts < MAX_RETRIES
                    UI -> User : InvalidInputError message (retry)
                else parse fails and attempts >= MAX_RETRIES
                    UI -> UI : raise OperandRetryExceeded
                    UI -> User : retry-exceeded error message
                else parse succeeds
                    note right of UI : operand appended to list
                end
            end

            alt OperandRetryExceeded raised
                note right of UI : skip execute_operation, continue loop
            else all operands collected

                UI -> UI : execute_operation(calc, operation, operands)
                UI -> Calc : resolved_method(*operands)

                alt add / subtract / multiply
                    Calc --> UI : numeric result
                else divide — b == 0
                    Calc --> UI : ZeroDivisionError → error string
                else divide — b != 0
                    Calc --> UI : a / b
                else factorial — invalid input (bool / non-integer float / negative)
                    Calc --> UI : TypeError or ValueError → error string
                else factorial — valid n
                    Calc --> UI : n!
                else square / cube
                    Calc --> UI : x*x or x*x*x
                else square_root — x < 0
                    Calc --> UI : ValueError → error string
                else square_root — x >= 0
                    Calc -> Math : sqrt(x)
                    Math --> Calc : float
                    Calc --> UI : float result
                else cube_root
                    Calc -> Math : copysign(abs(x)^(1/3), x)
                    Math --> Calc : float
                    Calc --> UI : float result
                else power — invalid types
                    Calc --> UI : TypeError → error string
                else power — valid
                    Calc --> UI : float(base ** exponent)
                else log10 / natural_log — x <= 0
                    Calc --> UI : ValueError → error string
                else log10 — x > 0
                    Calc -> Math : log10(x)
                    Math --> Calc : float
                    Calc --> UI : float result
                else natural_log — x > 0
                    Calc -> Math : log(x)
                    Math --> Calc : float
                    Calc --> UI : float result
                end

                UI -> UI : format_result(result) → str
                UI -> User : "Result: <value>"

            end

        end
    end

end

note over IR
  input_retry module provides:
  - DEFAULT_MAX_RETRIES = 3
  - RetryLimitExceeded exception
  - InputRetryConfig dataclass
  - validate_with_retry() generic helper
  user_input imports DEFAULT_MAX_RETRIES
  and enforces limits directly in its loops.
end note

@enduml
