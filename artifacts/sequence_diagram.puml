@startuml
title Calculator — Sequence Diagram (interactive divide + CLI add scenarios)

box "Interaction Layer" #LightBlue
  participant User
  participant Main
  participant GUI
  participant CLI
  participant InputLoop
  participant Mode
  participant OperationHistory
  participant Validation
  participant ErrorLogger
end box

box "Calculation Layer" #LightYellow
  participant Calculator
end box

note over Calculator
  Calculator has no direct I/O.
  It is only called from the Interaction Layer
  (via InputLoop.dispatch()).
end note

== GUI mode (e.g. python -m src --gui) ==

User -> Main : sys.argv = ["--gui"]
Main -> GUI : create CalculatorGUI()
GUI -> Calculator : create Calculator()
GUI -> GUI : _build_display() — display label shows "0"
GUI -> GUI : _build_mode_toggle() — "Scientific" toggle button
GUI -> GUI : _build_button_grid() — Normal rows + hidden sci_frame
Main -> GUI : gui.run() — enter tkinter mainloop

alt User performs a binary calculation (5 + 3 = 8)
  User -> GUI : press digit "5"
  GUI -> GUI : _on_digit_pressed(5)
  note right of GUI: _current_display = "5"\n_result_just_shown = False
  GUI -> GUI : _update_display() — shows "5"

  User -> GUI : press operator "+"
  GUI -> GUI : _on_operator_pressed("add")
  note right of GUI: _pending_operand = 5.0\n_pending_operator = "add"\n_result_just_shown = True

  User -> GUI : press digit "3"
  GUI -> GUI : _on_digit_pressed(3)
  note right of GUI: _result_just_shown=True → reset\n_current_display = "3"
  GUI -> GUI : _update_display() — shows "3"

  User -> GUI : press "="
  GUI -> GUI : _on_equals_pressed()
  GUI -> InputLoop : dispatch("add", [5.0, 3.0], calc)
  InputLoop -> Calculator : add(5.0, 3.0)
  Calculator --> InputLoop : return 8.0
  InputLoop --> GUI : return 8.0
  GUI -> GUI : _current_display = "8" (trailing .0 stripped)
  GUI -> GUI : _pending_operator = None, _result_just_shown = True
  GUI -> GUI : _update_display() — shows "8"
end

alt Calculation error (e.g. divide by zero)
  User -> GUI : press digits "1", "0", then "÷", then "0", then "="
  GUI -> GUI : _on_equals_pressed()
  GUI -> InputLoop : dispatch("divide", [10.0, 0.0], calc)
  InputLoop -> Calculator : divide(10.0, 0.0)
  Calculator --> InputLoop : raise ValueError("Division by zero is not allowed")
  InputLoop --> GUI : raise ValueError
  GUI -> GUI : _current_display = "Error", reset pending state
  GUI -> GUI : _update_display() — shows "Error"
end

alt Unary scientific function (e.g. √9)
  User -> GUI : press "9"
  GUI -> GUI : _on_digit_pressed(9) → _current_display = "9"
  User -> GUI : press "√" (scientific mode must be active)
  GUI -> GUI : _on_unary_pressed("square_root")
  GUI -> InputLoop : dispatch("square_root", [9.0], calc)
  InputLoop -> Calculator : square_root(9.0)
  Calculator --> InputLoop : return 3.0
  InputLoop --> GUI : return 3.0
  GUI -> GUI : _current_display = "3", _result_just_shown = True
  GUI -> GUI : _update_display() — shows "3"
end

alt Mode toggle (Normal → Scientific)
  User -> GUI : press "Scientific" toggle button
  GUI -> GUI : _on_mode_toggle()
  note right of GUI: _is_scientific_mode = True
  GUI -> GUI : sci_frame.pack() — show √, x², x³, ∛, n!, ln, log rows
  GUI -> GUI : mode button label → "Normal"
  note right of GUI: Pending state (_pending_operator, _pending_operand) preserved
end

alt Mode toggle (Scientific → Normal)
  User -> GUI : press "Normal" toggle button
  GUI -> GUI : _on_mode_toggle()
  note right of GUI: _is_scientific_mode = False
  GUI -> GUI : sci_frame.pack_forget() — hide scientific rows
  GUI -> GUI : mode button label → "Scientific"
end

== CLI mode (e.g. python -m src add 3 5) ==

User -> Main : sys.argv = ["add", "3", "5"]
Main -> CLI : run_cli()
CLI -> OperationHistory : create OperationHistory() — clears history.txt
CLI -> CLI : _build_parser() — build argparse parser
CLI -> CLI : validate operation in OPERATIONS
CLI -> CLI : validate operand count == 2
CLI -> CLI : parse operands as float: [3.0, 5.0]
CLI -> Calculator : create Calculator()
CLI -> InputLoop : dispatch("add", [3.0, 5.0], calc)
InputLoop -> Calculator : add(3.0, 5.0)
Calculator --> InputLoop : return 8.0
InputLoop --> CLI : return 8.0
CLI -> OperationHistory : record_operation("add", [3.0, 5.0], 8.0)
OperationHistory -> OperationHistory : _format_entry → "3.0 add 5.0 = 8.0"
OperationHistory --> OperationHistory : append to _history
OperationHistory --> OperationHistory : write to history.txt
CLI -> User : print("8.0")

alt CLI error path (unknown operation)
  User -> Main : sys.argv = ["badop", "1"]
  Main -> CLI : run_cli()
  CLI -> CLI : validate operation — not in OPERATIONS
  CLI -> User : print error to stderr
  CLI -> Main : sys.exit(2)
end

== Interactive mode (no CLI args) ==

User -> Main : sys.argv = []
Main -> InputLoop : run_loop()
InputLoop -> OperationHistory : create OperationHistory() — clears history.txt
InputLoop -> ErrorLogger : create ErrorLogger() — opens error.log in append mode
InputLoop -> Mode : initialize current_mode = Mode.NORMAL

loop until "exit" or max retries exceeded

  InputLoop -> Mode : get_operations_for_mode(current_mode)
  Mode --> InputLoop : frozenset of allowed operations
  InputLoop -> User : print_menu(current_mode) — mode-scoped operation list
  User -> InputLoop : get_operation() — attempt 1 => "divide"
  InputLoop -> Validation : validate_operation("divide", current_mode)
  Validation -> Mode : get_operations_for_mode(current_mode)
  Mode --> Validation : frozenset of allowed operations
  Validation --> InputLoop : (True, "")
  InputLoop -> InputLoop : look up operand_count = 2
  InputLoop -> User : get_operands(2) — prompt operand 1
  User -> InputLoop : "10"
  InputLoop -> Validation : validate_operand("10")
  Validation --> InputLoop : (True, 10.0, "")
  InputLoop -> User : get_operands(2) — prompt operand 2
  User -> InputLoop : "2"
  InputLoop -> Validation : validate_operand("2")
  Validation --> InputLoop : (True, 2.0, "")
  InputLoop -> Calculator : dispatch("divide", [10.0, 2.0])
  Calculator -> Calculator : divide(10.0, 2.0) — b != 0, returns 5.0
  Calculator --> InputLoop : return 5.0
  InputLoop -> User : print("Result: 5.0")
  InputLoop -> OperationHistory : record_operation("divide", [10.0, 2.0], 5.0)
  OperationHistory -> OperationHistory : _format_entry → "10.0 divide 2.0 = 5.0"
  OperationHistory --> OperationHistory : append to _history
  OperationHistory --> OperationHistory : write to history.txt

  alt Mode-switch command
    InputLoop -> User : print_menu(current_mode)
    User -> InputLoop : get_operation() => "mode scientific"
    InputLoop -> InputLoop : handle_mode_switch("mode scientific", current_mode)
    InputLoop -> InputLoop : current_mode = Mode.SCIENTIFIC
    InputLoop -> User : print("Switched to Scientific mode.")
    InputLoop --> InputLoop : continue loop
  end

  alt Error path (b == 0)
    InputLoop -> User : print_menu()
    User -> InputLoop : get_operation() => "divide"
    InputLoop -> Validation : validate_operation("divide")
    Validation --> InputLoop : (True, "")
    InputLoop -> InputLoop : look up operand_count = 2
    InputLoop -> User : get_operands(2) — prompt operand 1
    User -> InputLoop : "10"
    InputLoop -> Validation : validate_operand("10")
    Validation --> InputLoop : (True, 10.0, "")
    InputLoop -> User : get_operands(2) — prompt operand 2
    User -> InputLoop : "0"
    InputLoop -> Validation : validate_operand("0")
    Validation --> InputLoop : (True, 0.0, "")
    InputLoop -> Calculator : dispatch("divide", [10.0, 0.0])
    Calculator -> Calculator : divide(10.0, 0.0) — b == 0, raises ValueError
    Calculator --> InputLoop : raise ValueError("Division by zero is not allowed")
    InputLoop -> InputLoop : _categorize_error(exc, "divide", [10.0, 0.0]) => (CALCULATION_ERROR, context)
    InputLoop -> ErrorLogger : log_error("CALCULATION_ERROR", "Division by zero is not allowed", context)
    ErrorLogger -> ErrorLogger : _format_entry(timestamp, category, message, context)
    ErrorLogger --> ErrorLogger : append to _history
    ErrorLogger --> ErrorLogger : write entry to error.log
    ErrorLogger --> InputLoop : return
    InputLoop -> User : print("Error: Division by zero is not allowed")
  end

  alt Error logging path — invalid input (e.g. square root of negative number)
    User -> InputLoop : get_operation() => "square_root"
    InputLoop -> InputLoop : look up operand_count = 1
    User -> InputLoop : get_operands(1) => [-4.0]
    InputLoop -> InputLoop : dispatch("square_root", [-4.0], calc)
    InputLoop -> Calculator : square_root(-4.0)
    Calculator --> InputLoop : raise ValueError("Square root of a negative number is not allowed")
    InputLoop -> InputLoop : _categorize_error(exc, "square_root", [-4.0]) => (CALCULATION_ERROR, context)
    InputLoop -> ErrorLogger : log_error("CALCULATION_ERROR", "Square root ...", context)
    ErrorLogger --> ErrorLogger : append to _history
    ErrorLogger --> ErrorLogger : write entry to error.log
    ErrorLogger --> InputLoop : return
    InputLoop -> User : print("Error: Square root of a negative number is not allowed")
  end

  alt Retry path — invalid operation (up to MAX_RETRY_ATTEMPTS times)
    InputLoop -> User : print_menu(current_mode)
    User -> InputLoop : get_operation() — attempt 1 => "badop"
    InputLoop -> Validation : validate_operation("badop", current_mode)
    Validation -> Mode : get_operations_for_mode(current_mode)
    Mode --> Validation : frozenset of allowed operations
    Validation --> InputLoop : (False, "Invalid operation. Valid operations are: ...")
    InputLoop -> User : print error + "(Attempt 1 of 3)"
    User -> InputLoop : get_operation() — attempt 2 => "alsowrong"
    InputLoop -> Validation : validate_operation("alsowrong", current_mode)
    Validation --> InputLoop : (False, "Invalid operation. Valid operations are: ...")
    InputLoop -> User : print error + "(Attempt 2 of 3)"
    User -> InputLoop : get_operation() — attempt 3 => "stillwrong"
    InputLoop -> Validation : validate_operation("stillwrong", current_mode)
    Validation --> InputLoop : (False, "Invalid operation. Valid operations are: ...")
    InputLoop -> User : print error + "(Attempt 3 of 3)"
    InputLoop -> User : print("Maximum retry attempts reached. Terminating session.")
    InputLoop --> InputLoop : return "__max_retries_exceeded__"
    InputLoop -> User : print("Session terminated due to too many invalid operation entries.")
  end

  alt Retry path — invalid operand (up to MAX_RETRY_ATTEMPTS times per operand)
    InputLoop -> User : print_menu()
    User -> InputLoop : get_operation() => "add"
    InputLoop -> Validation : validate_operation("add")
    Validation --> InputLoop : (True, "")
    InputLoop -> InputLoop : look up operand_count = 2
    InputLoop -> User : get_operands(2) — prompt operand 1
    User -> InputLoop : "abc"
    InputLoop -> Validation : validate_operand("abc")
    Validation --> InputLoop : (False, 0.0, "Invalid operand. Please enter a numeric value.")
    InputLoop -> User : print error + "(Attempt 1 of 3)"
    User -> InputLoop : "xyz"
    InputLoop -> Validation : validate_operand("xyz")
    Validation --> InputLoop : (False, 0.0, "Invalid operand. Please enter a numeric value.")
    InputLoop -> User : print error + "(Attempt 2 of 3)"
    User -> InputLoop : "???"
    InputLoop -> Validation : validate_operand("???")
    Validation --> InputLoop : (False, 0.0, "Invalid operand. Please enter a numeric value.")
    InputLoop -> User : print error + "(Attempt 3 of 3)"
    InputLoop -> User : print("Maximum retry attempts reached for operand 1. Returning to menu.")
    InputLoop --> InputLoop : return None from get_operands
    InputLoop -> User : print("Returning to the main menu.")
  end

  alt History command
    InputLoop -> User : print_menu()
    User -> InputLoop : get_operation() => "history"
    InputLoop -> Validation : validate_operation("history")
    Validation --> InputLoop : (True, "")
    InputLoop -> OperationHistory : get_history()
    OperationHistory --> InputLoop : list of entry strings
    InputLoop -> User : print each entry (or "No operations recorded in this session.")
    InputLoop --> InputLoop : continue loop
  end

end

User -> InputLoop : get_operation() => "exit"
InputLoop -> User : print("Goodbye!")
InputLoop --> User : return (run_loop ends)

@enduml
