@startuml sequence_diagram

actor User
participant "__main__" as Main
participant "logging_config" as LogConf
participant "presentation.gui" as GUIMod
participant "CalculatorGUI" as GUI
participant "presentation.cli" as CLI
participant "presentation.interactive" as UI
participant "input_retry" as IR
participant "Calculator" as Calc
participant "OperationRegistry" as Registry
participant "ArithmeticEngine" as Engine
participant "OperationHistory" as Hist
participant "math" as Math

User -> Main : python -m src [args...]
Main -> Main : main()
Main -> LogConf : setup_logging()
note right of LogConf
  Configures "calculator" logger with
  a FileHandler at ERROR level writing
  to calculator.log. Idempotent.
end note
LogConf --> Main : logger (configured)

alt args[0] == "--gui" (GUI mode)

    Main -> GUIMod : import CalculatorGUI
    Main -> Main : root = tk.Tk()
    Main -> GUI : <<create>>(root)
    activate GUI
    GUI -> Calc : <<create>>
    activate Calc
    Calc -> Engine : <<create>>
    activate Engine
    Calc -> Hist : <<create>>
    activate Hist
    Calc -> Registry : <<create>>
    activate Registry
    Calc -> Registry : register_basic_operations(registry)\n[12 basic operations registered]
    Calc -> Registry : register_scientific_operations(registry)\n[8 scientific operations registered]
    GUI -> GUI : _build_ui()\n_build_button_grid()\n_build_scientific_panel()\n_bind_keyboard()
    Main -> GUI : app.run() → root.mainloop()

    loop user interaction (until window closed)
        alt digit / decimal button pressed
            User -> GUI : digit
            GUI -> GUI : _on_number_click(digit)
            GUI -> GUI : _update_display(...)
        else binary op button (+,-,*,/,^)
            User -> GUI : op symbol
            GUI -> GUI : _on_operation_click(op)
            note right of GUI : if pending op exists, _execute_operation() first;\nthen store _first_operand, _pending_op
        else equals button / Enter key
            User -> GUI : =
            GUI -> GUI : _on_equals_click() → _execute_operation()
            GUI -> Calc : method(_first_operand, _parse_display())
            Calc -> Engine : method(a, b)
            Engine --> Calc : result
            Calc -> Hist : add_record(op, [a, b], result, now())
            Calc --> GUI : result
            GUI -> GUI : _update_display(_format_result(result))
            GUI --> User : display updated
        else scientific button (sin, cos, sqrt, …)
            User -> GUI : scientific button
            GUI -> GUI : _on_scientific_click(method_name)
            GUI -> Calc : method(_parse_display())
            Calc -> Engine : method(x)
            Engine -> Math : math function(x)
            Math --> Engine : float
            Engine --> Calc : float
            Calc -> Hist : add_record(method, [x], result, now())
            Calc --> GUI : float result
            GUI -> GUI : _update_display(_format_result(result))
            GUI --> User : display updated
        else C / Escape key
            User -> GUI : clear
            GUI -> GUI : _on_clear_click()\n_reset_state()\n_update_display("0")
        else Backspace
            User -> GUI : backspace
            GUI -> GUI : _on_backspace_click()
        else +/- negate
            User -> GUI : +/-
            GUI -> GUI : _on_negate_click()
        else % percent
            User -> GUI : %
            GUI -> GUI : _on_percent_click()
        else SCI/BASIC toggle
            User -> GUI : toggle
            GUI -> GUI : _toggle_scientific_mode()\n(show/hide scientific panel)
        else window closed
            note right of GUI : root.mainloop() exits
        end
    end

    deactivate Hist
    deactivate Registry
    deactivate Engine
    deactivate Calc
    deactivate GUI

else sys.argv has arguments (CLI mode)

    Main -> CLI : run_cli(sys.argv[1:])
    CLI -> CLI : expression = " ".join(args)
    CLI -> Calc : <<create>>
    activate Calc
    Calc -> Engine : <<create>>
    activate Engine
    Calc -> Hist : <<create>>
    activate Hist
    Calc -> Registry : <<create>>
    activate Registry
    Calc -> Registry : register_basic_operations(registry)\n[Add, Subtract, Multiply, Divide, Power,\nFactorial, Square, Cube, SquareRoot,\nCubeRoot, Log10, NaturalLog registered]
    Calc -> Registry : register_scientific_operations(registry)\n[Sin, Cos, Tan, Exp, Log, Log10, Sqrt,\nFactorial (scientific) registered;\nlog10 and factorial overwrite basic variants]
    CLI -> CLI : parse_and_evaluate(expression, calc)

    alt SyntaxError during ast.parse
        CLI -> LogConf : logger.error("parse_and_evaluate: invalid syntax …")
        CLI --> User : error message (stderr)
        CLI --> Main : exit code 1
    else valid parse
        CLI -> CLI : ast.parse(expression, mode="eval")
    end

    loop recursive _eval_node traversal
        alt ast.Constant
            CLI -> CLI : return constant value
        else ast.UnaryOp (USub)
            CLI -> Calc : multiply(operand, -1)
            Calc -> Engine : multiply(operand, -1)
            Engine --> Calc : result
            Calc -> Hist : add_record("multiply", [operand, -1], result, now())
            Calc --> CLI : negated value
        else ast.BinOp Add
            CLI -> Calc : add(left, right)
            Calc -> Engine : add(left, right)
            Engine --> Calc : result
            Calc -> Hist : add_record("add", [left, right], result, now())
            Calc --> CLI : result
        else ast.BinOp Sub
            CLI -> Calc : subtract(left, right)
            Calc -> Engine : subtract(left, right)
            Engine --> Calc : result
            Calc -> Hist : add_record("subtract", [left, right], result, now())
            Calc --> CLI : result
        else ast.BinOp Mult
            CLI -> Calc : multiply(left, right)
            Calc -> Engine : multiply(left, right)
            Engine --> Calc : result
            Calc -> Hist : add_record("multiply", [left, right], result, now())
            Calc --> CLI : result
        else ast.BinOp Div
            CLI -> Calc : divide(left, right)
            Calc -> Engine : divide(left, right)
            alt b == 0
                Engine -> LogConf : logger.error("divide: division by zero …")
                Engine --> Calc : ZeroDivisionError raised
                note right of Hist : history NOT recorded on error
                Calc --> CLI : ZeroDivisionError propagated
                CLI -> LogConf : logger.error("cli: division by zero in expression …")
                CLI --> User : "Error: Division by zero is not allowed." (stderr)
                CLI --> Main : exit code 1
            else b != 0
                Engine --> Calc : a / b
                Calc -> Hist : add_record("divide", [left, right], result, now())
                Calc --> CLI : a / b
            end
        else ast.BinOp Pow
            CLI -> Calc : power(left, right)
            Calc -> Engine : power(left, right)
            Engine --> Calc : float result
            Calc -> Hist : add_record("power", [left, right], result, now())
            Calc --> CLI : float result
        else unsupported node / empty expression
            CLI -> LogConf : logger.error("cli: ValueError …") [if applicable]
            CLI --> User : error message (stderr)
            CLI --> Main : exit code 1
        end
    end

    CLI --> User : result (stdout)
    CLI --> Main : exit code 0
    deactivate Hist
    deactivate Registry
    deactivate Engine
    deactivate Calc

else no arguments (interactive mode)

    Main -> UI : run_interactive()
    UI -> Calc : <<create>>
    activate Calc
    Calc -> Engine : <<create>>
    activate Engine
    Calc -> Hist : <<create>>
    activate Hist
    Calc -> Registry : <<create>>
    activate Registry
    Calc -> Registry : register_basic_operations(registry)\n[12 basic operations registered]
    Calc -> Registry : register_scientific_operations(registry)\n[8 scientific operations registered]
    note right of UI : MAX_RETRIES = DEFAULT_MAX_RETRIES (3)\nfrom input_retry module\nmode = "normal" initially
    UI -> User : display numbered operation list\n(BASIC_OPERATIONS in normal mode)

    loop until quit or retry limit reached
        UI -> User : prompt "[MODE] > "
        User -> UI : command string

        alt input is 'quit' or 'exit'
            UI -> User : "Bye!"
            UI --> Main : return

        else input is 'mode'
            UI -> UI : toggle mode ("normal" ↔ "scientific")
            UI -> Calc : set_mode(mode)
            Calc --> UI : (mode updated)
            UI -> User : "Switched to <mode> mode."
            UI -> User : display updated operation list\n(BASIC_OPERATIONS + SCIENTIFIC_OPERATIONS\nin scientific mode)

        else unknown operation (op_attempts < MAX_RETRIES)
            UI -> User : unknown-operation error message

        else unknown operation (op_attempts >= MAX_RETRIES)
            UI -> User : max-retries-exceeded error
            UI --> Main : return

        else valid operation

            loop for each required operand (up to MAX_RETRIES per operand)
                UI -> User : prompt "Enter operand [n]:"
                User -> UI : raw string
                UI -> UI : parse_number(raw)
                alt parse fails and attempts < MAX_RETRIES
                    UI -> LogConf : logger.error("parse_number: could not parse … InvalidInputError")
                    UI -> User : InvalidInputError message (retry)
                else parse fails and attempts >= MAX_RETRIES
                    UI -> LogConf : logger.error("parse_number: could not parse … InvalidInputError")
                    UI -> UI : raise OperandRetryExceeded
                    UI -> User : retry-exceeded error message
                else parse succeeds
                    note right of UI : operand appended to list
                end
            end

            alt OperandRetryExceeded raised
                note right of UI : skip execute_operation, continue loop
            else all operands collected

                UI -> UI : execute_operation(calc, operation, operands, active_ops)
                UI -> Calc : resolved_method(*operands)

                alt add / subtract / multiply
                    Calc -> Engine : method(operands)
                    Engine --> Calc : result
                    Calc -> Hist : add_record(op, operands, result, now())
                    Calc --> UI : numeric result
                else divide — b == 0
                    Calc -> Engine : divide(a, 0)
                    Engine -> LogConf : logger.error("divide: division by zero …")
                    Engine --> Calc : ZeroDivisionError raised
                    note right of Hist : history NOT recorded on error
                    Calc --> UI : ZeroDivisionError propagated
                    UI -> LogConf : logger.error("execute_operation: … ZeroDivisionError")
                    UI --> UI : "Error: Division by zero is not allowed."
                else divide — b != 0
                    Calc -> Engine : divide(a, b)
                    Engine --> Calc : a / b
                    Calc -> Hist : add_record("divide", operands, result, now())
                    Calc --> UI : a / b
                else factorial — invalid input (bool / non-integer float / negative)
                    Calc -> Engine : factorial(n)
                    Engine -> LogConf : logger.error("factorial: … TypeError/ValueError")
                    Engine --> Calc : TypeError or ValueError raised
                    note right of Hist : history NOT recorded on error
                    Calc --> UI : TypeError or ValueError propagated
                    UI -> LogConf : logger.error("execute_operation: … TypeError/ValueError")
                    UI --> UI : error string
                else factorial — valid n
                    Calc -> Engine : factorial(n)
                    Engine --> Calc : n!
                    Calc -> Hist : add_record("factorial", [n], n!, now())
                    Calc --> UI : n!
                else square / cube — invalid type
                    Calc -> Engine : square/cube(x)
                    Engine -> LogConf : logger.error("square/cube: invalid type … TypeError")
                    Engine --> Calc : TypeError raised
                    note right of Hist : history NOT recorded on error
                    Calc --> UI : TypeError propagated
                    UI -> LogConf : logger.error("execute_operation: … TypeError")
                    UI --> UI : error string
                else square / cube — valid
                    Calc -> Engine : square/cube(x)
                    Engine --> Calc : result
                    Calc -> Hist : add_record(op, [x], result, now())
                    Calc --> UI : x*x or x*x*x
                else square_root — x < 0 or invalid type
                    Calc -> Engine : square_root(x)
                    Engine -> LogConf : logger.error("square_root: … ValueError/TypeError")
                    Engine --> Calc : ValueError or TypeError raised
                    note right of Hist : history NOT recorded on error
                    Calc --> UI : ValueError or TypeError propagated
                    UI -> LogConf : logger.error("execute_operation: … ValueError/TypeError")
                    UI --> UI : error string
                else square_root — x >= 0
                    Calc -> Engine : square_root(x)
                    Engine -> Math : sqrt(x)
                    Math --> Engine : float
                    Engine --> Calc : float
                    Calc -> Hist : add_record("square_root", [x], result, now())
                    Calc --> UI : float result
                else cube_root
                    Calc -> Engine : cube_root(x)
                    Engine -> Math : copysign(abs(x)^(1/3), x)
                    Math --> Engine : float
                    Engine --> Calc : float
                    Calc -> Hist : add_record("cube_root", [x], result, now())
                    Calc --> UI : float result
                else power — invalid types
                    Calc -> Engine : power(base, exponent)
                    Engine -> LogConf : logger.error("power: invalid type … TypeError")
                    Engine --> Calc : TypeError raised
                    note right of Hist : history NOT recorded on error
                    Calc --> UI : TypeError propagated
                    UI -> LogConf : logger.error("execute_operation: … TypeError")
                    UI --> UI : error string
                else power — valid
                    Calc -> Engine : power(base, exponent)
                    Engine --> Calc : float(base ** exponent)
                    Calc -> Hist : add_record("power", [base, exp], result, now())
                    Calc --> UI : float(base ** exponent)
                else log10 / natural_log — x <= 0 or invalid type
                    Calc -> Engine : log10/natural_log(x)
                    Engine -> LogConf : logger.error("log10/natural_log: … ValueError/TypeError")
                    Engine --> Calc : ValueError or TypeError raised
                    note right of Hist : history NOT recorded on error
                    Calc --> UI : ValueError or TypeError propagated
                    UI -> LogConf : logger.error("execute_operation: … ValueError/TypeError")
                    UI --> UI : error string
                else log10 — x > 0
                    Calc -> Engine : log10(x)
                    Engine -> Math : log10(x)
                    Math --> Engine : float
                    Engine --> Calc : float
                    Calc -> Hist : add_record("log10", [x], result, now())
                    Calc --> UI : float result
                else natural_log — x > 0
                    Calc -> Engine : natural_log(x)
                    Engine -> Math : log(x)
                    Math --> Engine : float
                    Engine --> Calc : float
                    Calc -> Hist : add_record("natural_log", [x], result, now())
                    Calc --> UI : float result
                else sin / cos / exp (scientific mode)
                    Calc -> Engine : sin/cos/exp(x)
                    Engine -> Math : sin/cos/exp(x)
                    Math --> Engine : float
                    Engine --> Calc : float
                    Calc -> Hist : add_record(op, [x], result, now())
                    Calc --> UI : float result
                else tan — undefined (|cos(x)| < 1e-9)
                    Calc -> Engine : tan(x)
                    Engine -> LogConf : logger.error("tan: value … undefined …")
                    Engine --> Calc : ValueError raised
                    note right of Hist : history NOT recorded on error
                    Calc --> UI : ValueError propagated
                    UI -> LogConf : logger.error("execute_operation: … ValueError")
                    UI --> UI : error string
                else tan — valid
                    Calc -> Engine : tan(x)
                    Engine -> Math : tan(x)
                    Math --> Engine : float
                    Engine --> Calc : float
                    Calc -> Hist : add_record("tan", [x], result, now())
                    Calc --> UI : float result
                else log / sqrt (scientific mode) — invalid input
                    Calc -> Engine : log/sqrt(x)
                    Engine -> LogConf : logger.error("log/sqrt: … ValueError/TypeError")
                    Engine --> Calc : ValueError or TypeError raised
                    note right of Hist : history NOT recorded on error
                    Calc --> UI : exception propagated
                    UI -> LogConf : logger.error("execute_operation: … ValueError/TypeError")
                    UI --> UI : error string
                else log / sqrt (scientific mode) — valid
                    Calc -> Engine : log/sqrt(x)
                    Engine -> Math : log(x) or sqrt(x)
                    Math --> Engine : float
                    Engine --> Calc : float
                    Calc -> Hist : add_record(op, [x], result, now())
                    Calc --> UI : float result
                end

                UI -> UI : format_result(result) → str
                UI -> User : "Result: <value>"

            end

        end
    end

    deactivate Hist
    deactivate Registry
    deactivate Engine
    deactivate Calc

end

note over IR
  input_retry module provides:
  - DEFAULT_MAX_RETRIES = 3
  - RetryLimitExceeded exception
  - InputRetryConfig dataclass
  - validate_with_retry() generic helper
  presentation.interactive imports DEFAULT_MAX_RETRIES
  and enforces limits directly in its loops.
end note

note over Registry
  OperationRegistry (src/operations/base.py)
  maps operation name strings to Operation
  instances. Populated once in Calculator.__init__
  via register_basic_operations() (12 ops) and
  register_scientific_operations() (8 ops).
  "factorial" and "log10" scientific variants
  overwrite the basic variants in the registry.
end note

note over Hist
  OperationHistory stores OperationRecord
  entries (operation_name, operands, result,
  timestamp). Records are only appended on
  successful operations — errors are not
  logged. get_history() returns a copy;
  clear_history() wipes the log.
end note

note over Engine
  ArithmeticEngine (src/logic/core.py) is
  stateless — it performs pure computation
  and calls logger.error() before raising
  on invalid input. It never records history.
  Calculator (src/logic/state.py) delegates
  all arithmetic here, then records in
  OperationHistory on success.
  Scientific methods (sin, cos, tan, exp,
  log, sqrt) delegate to Python math stdlib.
end note

note over LogConf
  All modules (ArithmeticEngine, presentation.cli,
  presentation.interactive) obtain the same
  "calculator" named logger via
  logging.getLogger("calculator").
  All error paths emit logger.error() before
  raising or returning an error string.
  Log destination: calculator.log (ERROR+).
end note

@enduml
