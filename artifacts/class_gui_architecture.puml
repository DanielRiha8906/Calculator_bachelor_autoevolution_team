@startuml class_gui_architecture

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

package "src.gui" {

    class GuiCalculator {
        -_adapter: GUISessionAdapter
        -_mode: str
        -_selected_op: str | None
        -_result_label: tk.Label
        -_toggle_btn: tk.Button
        -_grid_frame: tk.Frame
        --
        +__init__(adapter: GUISessionAdapter | None) : void
        -_build_ui() : void
        -_build_button_grid(frame: tk.Frame) : void
        -_get_button_colors(op_name: str) : tuple
        -_on_mode_toggle() : void
        -_on_operation_click(op_name: str) : void
        +update_result(text: str) : void
    }

    class GUISessionAdapter {
        -_session: CalculatorSession
        --
        +__init__(session: CalculatorSession) : void
        +execute_operation_safe(op_name: str, operands: list) : tuple
        +set_mode(mode_name: str) : void
        +get_operations() : list
        +get_history() : list
        +clear_history() : void
        +get_arity(op_name: str) : int
    }

    note top of GuiCalculator
      Module-level constants:
      _THEME: dict (18 visual constants)
      _SYMBOL_MAP: dict (20+ op-name → symbol)
      _OPERATOR_OPS: set {"add","subtract","multiply","divide"}
    end note
}

package "src" {

    class CalculatorSession {
        -_calculator: Calculator
        -_history: OperationHistory
        -_error_logger: ErrorLogger
        -_current_mode: str | None
        -_operation_list: list[str]
        --
        +set_mode(mode_name: str) : bool
        +get_current_mode() : str | None
        +execute_operation(op_name: str, operands: list) : tuple
        +record_history(op_name: str, operands: list, result) : void
        +get_arity(op_name: str) : int
        +get_history() : list[str]
        +get_operation_list() : list[str]
    }
}

"tk.Tk" <|-- GuiCalculator : extends

GuiCalculator *--> GUISessionAdapter : uses
GUISessionAdapter *--> CalculatorSession : wraps

GuiCalculator ..> "_THEME" : references
GuiCalculator ..> "_SYMBOL_MAP" : references
GuiCalculator ..> "_OPERATOR_OPS" : references

@enduml
