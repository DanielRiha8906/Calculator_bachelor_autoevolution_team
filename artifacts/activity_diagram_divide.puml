@startuml activity_diagram_divide

start

:Receive arguments a and b;

:Attempt: a / b via Python's / operator;
note right
  No explicit checks in source.
  Exceptions raised by Python's / operator.
end note

if (Exception raised?) then (yes)
    fork
        if (TypeError?) then (yes)
            :Raise TypeError;
            stop
        endif
    fork again
        if (ZeroDivisionError?) then (yes)
            :Raise ZeroDivisionError;
            stop
        endif
    end fork
else (no)
    :Return float result;
    stop
endif

@enduml
