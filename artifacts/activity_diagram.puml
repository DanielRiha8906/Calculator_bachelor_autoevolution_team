@startuml activity_diagram

start

:Instantiate Calculator;

:Call add(a, b);
:Return a + b;

:Call subtract(a, b);
:Return a - b;

:Call multiply(a, b);
:Return a * b;

:Call divide(a, b);

if (b == 0?) then (yes)
    :Raise ZeroDivisionError;
    stop
else (no)
    :Return a / b;
endif

:Call factorial(n);

if (n is not int?) then (yes)
    :Raise TypeError;
    stop
else (no)
    if (n < 0?) then (yes)
        :Raise ValueError;
        stop
    else (no)
        :Compute product of 1..n;
        :Return result;
    endif
endif

stop

@enduml
