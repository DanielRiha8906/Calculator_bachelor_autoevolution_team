@startuml activity_diagram

skinparam ArrowColor #444444
skinparam ActivityBorderColor #444444
skinparam swimlaneBorderColor #888888

|User|
start

|__main__|
if (sys.argv has arguments?) then (yes)
    :Delegate to cli.main();
    |cli|
    :argparse parses\n(operand_a, operator, operand_b, --history?);

    if (wrong argument count\nor --help?) then (yes)
        :argparse prints usage / help;
        :exit(0) or exit(2);
        end
    else (no)
    endif
else (no)
    |__main__|
    :Call get_input_with_retries();

    |retry_handler|
    :Prompt for first operand (with retries);
    if (retries exhausted?) then (yes)
        :Print "Maximum retries reached. Operation cancelled.";
        |__main__|
        :Return (no output);
        end
    else (no)
    endif

    :Prompt for second operand (with retries);
    if (retries exhausted?) then (yes)
        :Print "Maximum retries reached. Operation cancelled.";
        |__main__|
        :Return (no output);
        end
    else (no)
    endif

    :Prompt for operator (with retries);
    if (retries exhausted?) then (yes)
        :Print "Maximum retries reached. Operation cancelled.";
        |__main__|
        :Return (no output);
        end
    else (no)
    endif

    :Return (first_operand, operator, second_operand);
    |__main__|
endif

:Lookup method_name via BINARY_OPERATORS;
:Call run_calculation(first_operand, second_operand, method_name);

|input_handler / CalculatorWithHistory|
:Instantiate CalculatorWithHistory;
:Dispatch method via getattr;
:Record successful operation in history;

if (arithmetic error?\n(ZeroDivisionError / ValueError)) then (yes)
    :Print error to stderr;
    :exit(1);
    end
else (no)
endif

:Return (result, calc) tuple;

|__main__|
:Print "Result: {result}";

|cli|
if (--history flag set?) then (yes)
    :Call calc.get_history();
    :Print "History:" and each entry;
else (no)
endif

end

@enduml
