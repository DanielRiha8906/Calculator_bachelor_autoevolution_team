@startuml activity_diagram

start

:__main__.main() is invoked;
:setup_logging() → configures "calculator" logger\n(FileHandler, ERROR level, calculator.log);

if (sys.argv has arguments?) then (yes — CLI mode)

    partition "presentation.cli.run_cli(args)" {
        if (args is empty?) then (yes)
            :Print usage error to stderr;
            :Return exit code 1;
            stop
        else (no)
            :Join args with spaces → expression string;
            :Instantiate Calculator\n(creates ArithmeticEngine + OperationHistory +\nOperationRegistry populated via\nregister_basic_operations() and\nregister_scientific_operations());

            partition "parse_and_evaluate(expression, calc)" {
                :Strip expression;
                if (expression is empty?) then (yes)
                    :Raise ValueError "Expression must not be empty";
                else (no)
                    :ast.parse(expression, mode="eval");
                    if (SyntaxError?) then (yes)
                        :logger.error("parse_and_evaluate: invalid syntax …");
                        :Raise ValueError "Invalid expression syntax";
                    else (no)
                        partition "_eval_node(tree.body, calc)" {
                            if (node is ast.Constant?) then (yes)
                                :Return constant value (int or float);
                            elseif (node is ast.UnaryOp?) then (yes)
                                :Recurse on operand;
                                if (USub?) then (yes)
                                    :calc.multiply(operand, -1)\n→ ArithmeticEngine computes\n→ Calculator records in OperationHistory;
                                else (UAdd)
                                    :Return operand as-is;
                                endif
                            elseif (node is ast.BinOp?) then (yes)
                                :Recurse on left and right nodes;
                                if (Add?) then (yes)
                                    :calc.add(left, right)\n→ ArithmeticEngine computes\n→ Calculator records in OperationHistory;
                                elseif (Sub?) then (yes)
                                    :calc.subtract(left, right)\n→ ArithmeticEngine computes\n→ Calculator records in OperationHistory;
                                elseif (Mult?) then (yes)
                                    :calc.multiply(left, right)\n→ ArithmeticEngine computes\n→ Calculator records in OperationHistory;
                                elseif (Div?) then (yes)
                                    :calc.divide(left, right)\n→ ArithmeticEngine computes;
                                    note right
                                        If b==0: ArithmeticEngine calls logger.error()
                                        then raises ZeroDivisionError — caught at
                                        run_cli level. On success, Calculator records
                                        in OperationHistory.
                                    end note
                                else (Pow)
                                    :calc.power(left, right)\n→ ArithmeticEngine computes\n→ Calculator records in OperationHistory;
                                endif
                            else (unsupported node)
                                :Raise ValueError "Unsupported expression node";
                            endif
                        }
                    endif
                endif
            }

            if (ZeroDivisionError?) then (yes)
                :logger.error("cli: division by zero in expression …");
                :Print "Error: Division by zero is not allowed." to stderr;
                :Return exit code 1;
                stop
            elseif (ValueError?) then (yes)
                :logger.error("cli: ValueError in expression …");
                :Print error message to stderr;
                :Return exit code 1;
                stop
            elseif (TypeError?) then (yes)
                :logger.error("cli: TypeError in expression …");
                :Print error message to stderr;
                :Return exit code 1;
                stop
            else (success)
                :Print result to stdout;
                :Return exit code 0;
                stop
            endif
        endif
    }

else (no — interactive mode)

    partition "presentation.interactive.run_interactive()" {
        :Instantiate Calculator\n(creates ArithmeticEngine + OperationHistory +\nOperationRegistry populated via\nregister_basic_operations() and\nregister_scientific_operations());
        :mode = "normal";
        :Display operation list for current mode\n(BASIC_OPERATIONS in normal mode;\nBASIC_OPERATIONS + SCIENTIFIC_OPERATIONS in scientific mode);
        :op_attempt = 0;

        repeat

            :Prompt "[MODE] > ";

            if (input is 'quit' or 'exit'?) then (yes)
                :Print "Bye!";
                stop

            elseif (input is 'mode'?) then (yes)
                :Toggle mode: "normal" ↔ "scientific";
                :calc.set_mode(mode);
                :Print "Switched to <mode> mode.";
                :Re-display operation list for new mode;
                :op_attempt = 0;

            elseif (input not in active_ops?) then (yes)
                :op_attempt += 1;
                :Print unknown-operation error with attempt count;
                if (op_attempt >= MAX_RETRIES?) then (yes)
                    :Print max-retries-exceeded error;
                    stop
                endif

            else (valid operation)
                :op_attempt = 0;

                partition "get_operands(operation, active_ops)" {
                    :Look up operand_count in active_ops;
                    :operand_attempts = 0;
                    repeat
                        :Prompt user for next operand;
                        :operand_attempts += 1;
                        if (parse_number(raw) succeeds?) then (yes)
                            :Append parsed number to operands list;
                            :operand_attempts = 0;
                        else (InvalidInputError)
                            :logger.error("parse_number: could not parse … InvalidInputError");
                            if (operand_attempts >= MAX_RETRIES?) then (yes)
                                :Raise OperandRetryExceeded;
                            else (no)
                                :Print error message, retry same operand;
                            endif
                        endif
                    repeat while (all operands collected?) is (no)
                    -> yes;
                }

                if (OperandRetryExceeded?) then (yes)
                    :Print retry-exceeded error;
                else (no)

                    partition "execute_operation(calc, operation, operands, active_ops)" {
                        :Resolve Calculator method name via active_ops;
                        :Call Calculator.method(*operands)\n  → Calculator delegates to ArithmeticEngine\n  → ArithmeticEngine computes result;
                        if (exception raised?) then (ZeroDivisionError)
                            :logger.error("execute_operation: … ZeroDivisionError");
                            :Return "Error: Division by zero is not allowed.";
                        elseif (ValueError)
                            :logger.error("execute_operation: … ValueError");
                            :Return "Error: <exception message>";
                        elseif (TypeError)
                            :logger.error("execute_operation: … TypeError");
                            :Return "Error: <exception message>";
                        else (success)
                            :Calculator records in OperationHistory;
                            :Return numeric result;
                        endif
                    }

                    :format_result(result) → str;
                    :Print "Result: <formatted_result>";

                endif

            endif

        repeat while (loop continues?) is (yes)
        -> no;

        stop
    }

endif

@enduml
