@startuml activity_diagram

start

:Instantiate Calculator;

if (Mode?) then (interactive — via __main__)

    :get_operation_registry(calculator);
    :Print welcome message;
    :display_menu(registry);
    :get_operation_choice(registry);

    while (choice is not None?) is (yes)

        if (choice is (None, None)?) then (yes — max attempts exhausted)
            :Print "Too many invalid attempts. Exiting.";
            stop
        endif

        :Unpack (method, arity) from choice;
        :get_operands(arity);

        if (operands is None?) then (yes — max attempts exhausted)
            :Print "Too many invalid attempts. Exiting.";
            stop
        endif

        if (method is factorial?) then (yes)
            :Convert whole-valued float operands to int;
        endif

        :method(*operands);

        if (Exception raised?) then (yes)
            :Print error message\n(TypeError / ValueError / ZeroDivisionError);
        else (no)
            :Print "Result: {result}";
        endif

        :display_menu(registry);
        :get_operation_choice(registry);

    endwhile (no — user quit)

    :Print "Goodbye.";

else (CLI — via execute_cli)

    :parse_arguments(sys.argv);
    :get_operation_registry(calculator);

    :Look up operation_name in registry;
    if (operation found?) then (no)
        :Print error to stderr;
        :Return exit code 1;
        stop
    endif

    :Validate operand count matches arity;
    if (arity mismatch?) then (yes)
        :Print error to stderr;
        :Return exit code 1;
        stop
    endif

    :convert_operand(value) for each operand;
    :method(*operands);

    if (Exception raised?) then (yes)
        :Print error to stderr;
        :Return exit code 1;
    else (no)
        :Print result to stdout;
        :Return exit code 0;
    endif

endif

stop

@enduml
