@startuml activity_diagram

start

:Instantiate Calculator;

fork
  :add(a, b);
  :return a + b;
fork again
  :subtract(a, b);
  :return a - b;
fork again
  :multiply(a, b);
  :return a * b;
fork again
  :divide(a, b);
  if (b == 0?) then (yes)
    :raise ZeroDivisionError\n"Cannot divide by zero";
    stop
  else (no)
    :return a / b;
  endif
fork again
  :factorial(n);
  if (n is float?) then (yes)
    if (n != int(n)?) then (yes)
      :raise TypeError\n"factorial() only accepts\ninteger values";
      stop
    else (no)
      :n = int(n);
    endif
  endif
  if (n < 0?) then (yes)
    :raise ValueError\n"factorial() not defined\nfor negative values";
    stop
  else (no)
    :result = 1;
    :for i in range(2, n+1): result *= i;
    :return result;
  endif
fork again
  :square(x);
  :return x ** 2;
fork again
  :cube(x);
  :return x ** 3;
fork again
  :square_root(x);
  if (x < 0?) then (yes)
    :raise ValueError\n"square_root() not defined\nfor negative values";
    stop
  else (no)
    :return math.sqrt(x);
  endif
fork again
  :cube_root(x);
  if (x == 0?) then (yes)
    :return 0.0;
  else (no)
    :return copysign(|x|^(1/3), x);
  endif
fork again
  :power(base, exponent);
  :return base ** exponent;
fork again
  :logarithm(x);
  if (x <= 0?) then (yes)
    :raise ValueError\n"logarithm() not defined\nfor non-positive values";
    stop
  else (no)
    :return math.log10(x);
  endif
fork again
  :natural_logarithm(x);
  if (x <= 0?) then (yes)
    :raise ValueError\n"natural_logarithm() not defined\nfor non-positive values";
    stop
  else (no)
    :return math.log(x);
  endif
end fork

:Return result;

stop

@enduml
