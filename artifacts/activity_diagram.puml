@startuml activity_diagram

start

:Instantiate Calculator;

if (Mode?) then (interactive — via __main__)

    :Instantiate HistoryTracker;
    :Instantiate OperationRegistry(calculator)\n→ loads normal ops (6) + scientific ops (12);
    :Print welcome message;
    :get_mode_selection() → current_mode ("normal" or "scientific");

    while (session active?) is (yes)

        if (current_mode == "scientific"?) then (yes)
            :active_registry = op_registry.get_scientific_operations()\n(18 ops: normal + scientific);
        else (no — normal)
            :active_registry = op_registry.get_normal_operations()\n(6 ops);
        endif

        :interface.MenuRenderer: display_menu(active_registry, current_mode);
        :get_operation_choice_with_mode_option(active_registry);

        if (choice is None?) then (yes — user quit)
            :Print "Goodbye.";
            stop
        elseif (choice is (_MODE_SWITCH_TOKEN, None, None)?) then (yes — mode switch)
            :get_mode_selection() → current_mode;
        elseif (choice is (_HISTORY_TOKEN, None, None)?) then (yes — history request)
            :history_tracker.display();
        elseif (choice is (None, None, None)?) then (yes — max attempts exhausted)
            stop
        else (operation selected)
            :Unpack (operation_name, method, arity) from choice;
            :get_operands(arity);

            if (operands is None?) then (yes — max attempts exhausted)
                stop
            endif

            if (method is factorial?) then (yes)
                :Convert whole-valued float operands to int;
            endif

            :method(*operands);

            if (Exception raised?) then (yes)
                :error_logger.log_error(error_type, context);
                :Print error message\n(TypeError / ValueError / ZeroDivisionError);
            else (no)
                :Print "Result: {result}";
                :history_tracker.record(operation_name, operands, result);
            endif
        endif

    endwhile (no)

    :history_tracker.save_to_file("history.txt");
    :Print "Goodbye.";

elseif (Mode?) then (GUI — via gui_main)

    :Instantiate HistoryTracker;
    :Instantiate SimpleMode(calculator)\n→ creates OperationRegistry internally;
    :Instantiate CalculatorGUI(root, calculator, mode, history_tracker);
    :_build_ui() → build display, mode buttons,\nnumber buttons, operation buttons, history panel;

    while (tkinter event loop active?) is (yes)

        if (digit or decimal button pressed?) then (yes)
            :Append to _current_input;
            :Update display;
        elseif (C (clear) button pressed?) then (yes)
            :Reset _current_input, _first_operand,\n_pending_op, _pending_op_name;
            :Set display to "0";
        elseif (Mode toggle button pressed?) then (yes)
            :_toggle_mode();
            if (current mode is Simple?) then (yes)
                :_switch_to_scientific()\n→ new ScientificMode, _reset_transient_state, _build_ui;
            else (no — current mode is Scientific)
                :_switch_to_simple()\n→ new SimpleMode, _reset_transient_state, _build_ui;
            endif
        elseif (operation button pressed?) then (yes)
            :_parse_current_input() → value;
            if (parse failed?) then (yes)
                :Display "Error: invalid input";
            elseif (arity == 1?) then (yes — unary)
                if (op is factorial and value not whole?) then (yes)
                    :Display "Error: factorial requires an integer";
                else (no)
                    :op_callable(value);
                    if (Exception raised?) then (yes)
                        :Display "Error: {exc}";
                    else (no)
                        :Display result;
                        :history_tracker.record(op_name, [value], result);
                        :_refresh_history();
                    endif
                endif
            else (no — binary)
                :Store value as _first_operand;
                :Queue (op_callable, arity) as _pending_op;
                :Clear _current_input;
            endif
        elseif (= (equals) button pressed?) then (yes)
            if (no _pending_op?) then (yes)
                :no-op;
            else (no)
                :_parse_current_input() → second_value;
                if (parse failed?) then (yes)
                    :Display "Error: invalid input";
                else (no)
                    :op_callable(_first_operand, second_value);
                    if (Exception raised?) then (yes)
                        :Display "Error: {exc}";
                        :Reset _pending_op, _pending_op_name, _first_operand;
                    else (no)
                        :Display result;
                        :history_tracker.record(op_name,\n[_first_operand, second_value], result);
                        :_refresh_history();
                        :Reset _pending_op, _pending_op_name, _first_operand;
                    endif
                endif
            endif
        endif

    endwhile (no — window closed)

else (CLI — via execute_cli)

    :interface.InputParser: parse_cli_args(sys.argv);
    :core.Operations: get_operation_registry(calculator)\n→ OperationRegistry loads normal + scientific operations;

    :Look up operation_name in registry;
    if (operation found?) then (no)
        :error_logger.log_error("UNSUPPORTED_OPERATION", context);
        :Print error to stderr;
        :Return exit code 1;
        stop
    endif

    :Validate operand count matches arity;
    if (arity mismatch?) then (yes)
        :error_logger.log_error("ARGUMENT_COUNT_MISMATCH", context);
        :Print error to stderr;
        :Return exit code 1;
        stop
    endif

    :interface.InputParser: convert_operand(value) for each operand;
    if (conversion failed?) then (yes)
        :error_logger.log_error("INVALID_OPERAND", context);
        :Print error to stderr;
        :Return exit code 1;
        stop
    endif

    :method(*operands);

    if (Exception raised?) then (yes)
        :error_logger.log_error(error_type, context);
        :Print error to stderr;
        :Return exit code 1;
    else (no)
        :Print result to stdout;
        :Return exit code 0;
    endif

endif

stop

@enduml
