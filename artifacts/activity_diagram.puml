@startuml activity_diagram

start

note right
  Modular package layout:
  src/core/       — CalculationEngine, Operation, OperationRegistry
  src/interface/  — CLIHandler, REPLInterface
  src/operations/ — standalone arithmetic/roots/scientific functions + re-exports
  src/support/    — ErrorLogger, OperationHistory, MaxRetriesExceeded
  src/context.py  — CalculatorContext (mode state)
  src/*.py shims re-export from canonical sub-package locations.
end note

:Instantiate Calculator;
note right
  Calculator._engine = CalculationEngine()
  Arithmetic ops delegate to CalculationEngine.
  Scientific ops implemented directly on Calculator.
  Trig ops (sin/cos/tan) added in issue-186.
end note
:Instantiate OperationHistory(history_file="history.txt");
:history.clear_history();
:Instantiate ErrorLogger(error_file="error.log");
:error_logger.clear_errors();
:Instantiate CalculatorContext();
note right
  Defaults to mode="normal".
  Acts as single source of truth for mode state.
  Passed to both REPLInterface and CLIHandler.
end note

if (argv contains "--gui"?) then (yes — GUI mode)

  :Instantiate GUIInterface(\n  calculator, registry, context, history, error_logger);
  note right
    GUIInterface creates OperationRegistry internally
    and syncs its mode from CalculatorContext.
    Tkinter event loop drives all user interaction.
    ModernGUIInterface (src/interface/gui_modern.py) exists
    as an iOS-inspired alternative (4×5 grid, dark theme,
    collapsible scientific panel) but is not yet wired to
    the --gui entry point (pending human review).
  end note
  :gui.run();
  stop

else (no — REPL or CLI mode)

if (argv empty or ["--repl"]?) then (yes — REPL mode)

  :Instantiate REPLInterface(calculator, history, error_logger, context);
  note right
    REPLInterface creates an OperationRegistry
    internally and syncs its mode from context.
    _operations filtered to mode-compatible ops.
  end note
  :repl.run();

  repeat
    :Display current mode;
    :Display operation menu\n(get_operation_selection());

    repeat
      :User selects operation, "mode <name>",\n"history", or "quit";
      if (input is "mode <name>"?) then (yes)
        :context.set_mode(mode_name);
        :registry.set_mode(mode_name);
        :_refresh_operations();
        note right
          Refreshes _operations and _operation_keys
          to reflect new mode's available operations.
        end note
        :Re-display mode and menu;
      elseif (input valid (number, "history", or "quit")?) then (yes)
        break
      else (no)
        :attempts++;
        if (attempts >= MAX_RETRIES?) then (yes)
          :raise MaxRetriesExceeded;
          stop
        else (no)
          :Print invalid selection message;
        endif
      endif
    repeat while (retry?)

    if (User chose "quit"?) then (yes)
      stop
    endif

    if (User chose "history"?) then (yes)
      if (history is not None?) then (yes)
        :entries = history.display_history();
        if (entries non-empty?) then (yes)
          :Print each history entry;
        else (no)
          :Print "No history recorded yet.";
        endif
      else (no)
        :Print "History is not available in this session.";
      endif
      note right
        Continue to next menu iteration
      end note
    else (operation selected)

      :Determine arity from OperationRegistry;

      repeat
        :get_operand(first prompt\nwith last_result default);
        if (input empty and last_result set?) then (yes)
          :use last_result as operand;
          break
        elseif (input is valid float?) then (yes)
          :parse operand as float;
          break
        else (no)
          :attempts++;
          if (attempts >= MAX_RETRIES?) then (yes)
            :raise MaxRetriesExceeded;
            stop
          else (no)
            :Print invalid number message;
          endif
        endif
      repeat while (retry?)

      if (arity == 2?) then (yes)
        repeat
          :get_operand(second prompt);
          if (input is valid float?) then (yes)
            :parse second operand as float;
            break
          else (no)
            :attempts++;
            if (attempts >= MAX_RETRIES?) then (yes)
              :raise MaxRetriesExceeded;
              stop
            else (no)
              :Print invalid number message;
            endif
          endif
        repeat while (retry?)
      endif

      :_execute(operation, operands)\n→ OperationRegistry.dispatch(operation, operands);

      if (operation == "logarithm"?) then (yes — registry special case)
        if (base <= 0 or base == 1?) then (yes)
          :raise ValueError\n"logarithm base must be positive\nand not equal to 1";
        else (no)
          if (x <= 0?) then (yes)
            :raise ValueError\n"logarithm() not defined\nfor non-positive values";
          else (no)
            :return math.log(x, base);
          endif
        endif
      else (no — forwarded to Calculator via getattr)
        fork
          :add(a, b);
          note right: Calculator → CalculationEngine
          :return a + b;
        fork again
          :subtract(a, b);
          note right: Calculator → CalculationEngine
          :return a - b;
        fork again
          :multiply(a, b);
          note right: Calculator → CalculationEngine
          :return a * b;
        fork again
          :divide(a, b);
          note right: Calculator → CalculationEngine
          if (b == 0?) then (yes)
            :raise ZeroDivisionError\n"Cannot divide by zero";
          else (no)
            :return a / b;
          endif
        fork again
          :factorial(n);
          if (n is float?) then (yes)
            if (n != int(n)?) then (yes)
              :raise TypeError\n"factorial() only accepts\ninteger values";
            else (no)
              :n = int(n);
            endif
          endif
          if (n < 0?) then (yes)
            :raise ValueError\n"factorial() not defined\nfor negative values";
          else (no)
            :result = 1;
            :for i in range(2, n+1): result *= i;
            :return result;
          endif
        fork again
          :square(x);
          :return x ** 2;
        fork again
          :cube(x);
          :return x ** 3;
        fork again
          :square_root(x);
          if (x < 0?) then (yes)
            :raise ValueError\n"square_root() not defined\nfor negative values";
          else (no)
            :return math.sqrt(x);
          endif
        fork again
          :cube_root(x);
          if (x == 0?) then (yes)
            :return 0.0;
          else (no)
            :return copysign(|x|^(1/3), x);
          endif
        fork again
          :power(base, exponent);
          :return base ** exponent;
        fork again
          :natural_logarithm(x);
          if (x <= 0?) then (yes)
            :raise ValueError\n"natural_logarithm() not defined\nfor non-positive values";
          else (no)
            :return math.log(x);
          endif
        fork again
          :sin(x);
          note right: scientific mode only
          :return math.sin(x);
        fork again
          :cos(x);
          note right: scientific mode only
          :return math.cos(x);
        fork again
          :tan(x);
          note right: scientific mode only
          :return math.tan(x);
        end fork
      endif

      if (Calculator or registry raised an exception?) then (yes)
        :Print error message to user;
        if (error_logger is not None?) then (yes)
          :error_logger.log_error(\n  CALCULATION_ERROR,\n  user_input,\n  exception\n);
        endif
      else (no)
        :display_result(operation, operands, result);
        :Store result as last_result;
        if (history is not None?) then (yes)
          :history.record_operation(entry);
        endif
      endif

    endif

  repeat while (continue?) is (yes)
  -> no;

  stop

else (no — CLI mode)

  if (argv has only 1 arg and not "--repl"?) then (yes)
    :Print usage to stderr;
    :sys.exit(1);
    stop
  endif

  :Instantiate CLIHandler(calculator, history, error_logger, context);
  note right
    CLIHandler creates an OperationRegistry
    internally and syncs its mode from context.
  end note
  :handler.execute(argv);

  :parse_args(argv) via OperationRegistry\n→ (method_name, operands);

  if (operation unknown or not in current mode?) then (yes)
    if (error_logger is not None?) then (yes)
      :error_logger.log_error(\n  UNSUPPORTED_OPERATION,\n  argv[0],\n  exception\n);
    endif
    :Print error to stderr;
    :sys.exit(2);
    stop
  endif

  if (operand count wrong or non-numeric?) then (yes)
    if (error_logger is not None?) then (yes)
      :error_logger.log_error(\n  INVALID_INPUT,\n  str(argv),\n  exception\n);
    endif
    :Print error to stderr;
    :sys.exit(3);
    stop
  endif

  :OperationRegistry.dispatch(method_name, operands);

  if (method_name == "logarithm"?) then (yes — registry special case)
    if (base <= 0 or base == 1?) then (yes)
      :raise ValueError\n"invalid base";
    else (no)
      if (x <= 0?) then (yes)
        :raise ValueError\n"non-positive x";
      else (no)
        :return math.log(x, base);
      endif
    endif
  else (no)
    :getattr(calculator, method_name)(*operands);
  endif

  if (operation raised exception?) then (yes)
    if (error_logger is not None?) then (yes)
      :error_logger.log_error(\n  CALCULATION_ERROR,\n  str(argv),\n  exception\n);
    endif
    :Print error to stderr;
    :sys.exit(4);
    stop
  endif

  if (history is not None?) then (yes)
    :history.record_operation(entry);
  endif

  :Print result to stdout;
  :sys.exit(0);
  stop

endif

endif

@enduml
