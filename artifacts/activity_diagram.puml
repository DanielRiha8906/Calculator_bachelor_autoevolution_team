@startuml Calculator User Interaction Flow

title Calculator User Interaction Flow

start

:Create Calculator instance;
:Create InputHandler with calculator;
:Call handler.run();

repeat
    :_show_menu()\nPrint available operations from OPERATIONS registry;
    :Prompt user: "Enter operation (or 'exit'/'quit' to stop)";
    :Read and strip/lower input;

    if (input == "exit" or "quit"?) then (yes)
        :Print "Goodbye!";
        stop
    else (no)
        if (op_choice in OPERATIONS?) then (no)
            :Print "Error: Unknown operation '<op_choice>'.\nPlease choose from the menu.";
        else (yes)
            :Look up op_info from OPERATIONS;
            :Extract arity and coerce callable;

            :_prompt_operands(arity, coerce);
            fork
                :Prompt for first operand (and second if arity=2);
                :Read raw input and call coerce(raw);
                if (coerce raises ValueError or TypeError?) then (yes)
                    :Raise ValueError:\n"Invalid operand '<raw>': expected a numeric value.";
                else (no)
                    :Append coerced value to operands list;
                endif
            end fork

            if (ValueError raised during _prompt_operands?) then (yes)
                :Print "Error: <exc>";
            else (no)
                :_dispatch(op_choice, operands)\ngetattr(calculator, method_name)(*operands);

                if (ZeroDivisionError raised?) then (yes)
                    :Print "Error: Division by zero is not allowed.";
                elseif (ValueError raised?) then (yes)
                    :Print "Error: <exc>";
                elseif (TypeError raised?) then (yes)
                    :Print "Error: <exc>";
                else (no)
                    :Print "Result: <result>";
                endif
            endif
        endif
    endif
repeat while (session active)

' -----------------------------------------------------------------------
' CLI Mode Flow
' -----------------------------------------------------------------------

partition "CLI Mode (src/cli.py run_cli)" {
    start

    :Parse sys.argv[1:] into args list;

    if (len(args) == 0?) then (yes)
        :Print usage message to stderr;
        :sys.exit(1);
        stop
    else (no)
        :Extract op_name = args[0];

        if (op_name in OPERATIONS?) then (no)
            :Print "Error: Unknown operation '<op_name>'" to stderr;
            :sys.exit(1);
            stop
        else (yes)
            :Read expected_arity from OPERATIONS[op_name];
            :Count provided = len(args) - 1;

            if (provided == expected_arity?) then (no)
                :Print arity-mismatch error to stderr;
                :sys.exit(1);
                stop
            else (yes)
                :Read coerce callable from OPERATIONS[op_name]\n(default: float);

                :For each operand string in args[1:];
                fork
                    :Attempt coerce(raw);
                    if (ValueError or TypeError raised?) then (yes)
                        :Print "Error: Invalid operand '<raw>'" to stderr;
                        :sys.exit(1);
                        stop
                    else (no)
                        :Append coerced value to operands list;
                    endif
                end fork

                :Instantiate Calculator();
                :Call getattr(calc, method_name)(*operands);

                if (ZeroDivisionError raised?) then (yes)
                    :Print "Error: Division by zero is not allowed." to stderr;
                    :sys.exit(1);
                    stop
                elseif (ValueError raised?) then (yes)
                    :Print "Error: <exc>" to stderr;
                    :sys.exit(1);
                    stop
                elseif (TypeError raised?) then (yes)
                    :Print "Error: <exc>" to stderr;
                    :sys.exit(1);
                    stop
                else (no)
                    :Print result to stdout;
                    :sys.exit(0);
                    stop
                endif
            endif
        endif
    endif
}

@enduml
