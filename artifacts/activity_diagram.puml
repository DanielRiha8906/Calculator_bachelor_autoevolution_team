@startuml Calculator User Interaction Flow

title Calculator User Interaction Flow

start

:Create Calculator instance;
:Create InputHandler with calculator;
note right
    InputHandler.__init__ also creates
    an OperationDispatcher instance
    (_dispatcher = OperationDispatcher(calc))
end note
:Call handler.run();
:op_attempts = 0;

repeat
    :_show_menu()\nPrint available operations from OPERATIONS registry;
    :Prompt user: "Enter operation (or 'exit'/'quit' to stop)";
    :Read and strip/lower input;

    if (input == "exit" or "quit"?) then (yes)
        :Print "Goodbye!";
        stop
    else (no)
        if (op_choice in OPERATIONS?) then (no)
            :op_attempts += 1;
            :logger.log_unsupported_operation(op_choice);
            :Print "Error: Unknown operation '<op_choice>'.\nPlease choose from the menu.";
            :Print "Available operations: " + list of keys;
            if (op_attempts >= MAX_RETRIES?) then (yes)
                :Print "Too many invalid attempts. Ending session.";
                stop
            else (no)
                ' retry < MAX_RETRIES: loop back to operation input
            endif
        else (yes)
            :op_attempts = 0;
            :Look up op_info from OPERATIONS;
            :Extract arity and coerce callable;

            :_prompt_operands(arity, coerce);
            note right
                For each operand position:
                attempt_count = 0 .. MAX_RETRIES-1
            end note

            partition "_prompt_operands retry loop" {
                repeat
                    :Prompt for operand (label: first/second/"");
                    :Read raw input;

                    partition "OperationDispatcher.coerce_operands([raw], coerce)" {
                        :Call coerce(raw);
                        if (coerce raises ValueError or TypeError?) then (yes)
                            :Raise ValueError:\n"Invalid operand '<raw>'...";
                        else (no)
                            :Return [coerced_value];
                        endif
                    }

                    if (ValueError from coerce_operands?) then (yes)
                        :attempt_count += 1;
                        :logger.log_invalid_operand(raw, "<numeric>");
                        :Print "Error: Invalid operand '<raw>': expected a numeric value.";
                        if (attempt_count >= MAX_RETRIES?) then (yes)
                            :Raise ValueError:\n"Too many invalid attempts for operand. Ending session.";
                        else (no)
                            ' retry < MAX_RETRIES: re-prompt same operand
                        endif
                    else (no)
                        :Append coerced value to operands list;
                    endif
                repeat while (more operands to collect)
            }

            if (ValueError raised during _prompt_operands?) then (yes)
                :Print "Error: <exc>";
            else (no)
                :_dispatch(op_choice, operands);
                note right
                    Delegates to
                    OperationDispatcher.dispatch()
                end note

                partition "OperationDispatcher.dispatch(op_key, operands)" {
                    :Look up method_name from OPERATIONS[op_key];
                    :getattr(calculator, method_name)(*operands);
                }

                if (ZeroDivisionError raised?) then (yes)
                    :logger.log_division_by_zero(operands);
                    :Print "Error: Division by zero is not allowed.";
                elseif (ValueError raised?) then (yes)
                    :logger.log_domain_error(op_choice, str(exc));
                    :Print "Error: <exc>";
                elseif (TypeError raised?) then (yes)
                    :logger.log_domain_error(op_choice, str(exc));
                    :Print "Error: <exc>";
                else (no)
                    :Print "Result: <result>";
                endif
            endif
        endif
    endif
repeat while (session active)

' -----------------------------------------------------------------------
' CLI mode flow
' -----------------------------------------------------------------------
partition "CLI Mode (main.py)" {
    start

    :Create Calculator instance;
    :Create CliDispatcher with calculator;
    note right
        CliDispatcher.__init__ also creates
        an OperationDispatcher instance
        (_dispatcher = OperationDispatcher(calc))
    end note
    :Call dispatcher.dispatch_from_args(sys.argv[1:]);

    if (args is empty?) then (yes)
        :Print usage and available operations to stderr;
        :Return exit code 1;
        stop
    else (no)
        :Extract op_key = args[0].lower();

        if (op_key in OPERATIONS?) then (no)
            :logger.log_unsupported_operation(op_key);
            :Print "Error: Unknown operation '<op_key>'" to stderr;
            :Return exit code 1;
            stop
        else (yes)
            :Look up op_info from OPERATIONS;
            :Extract arity and coerce callable;

            :operand_args = args[1:];

            if (len(operand_args) != arity?) then (yes)
                :logger.log_invalid_argument_count(op_key, arity, len(operand_args));
                :Print "Error: wrong operand count" to stderr;
                :Return exit code 1;
                stop
            else (no)
                :_coerce_operands(operand_args, coerce);
                note right
                    Iterates per element;
                    delegates to
                    OperationDispatcher.coerce_operands([raw], coerce)
                end note

                partition "OperationDispatcher.coerce_operands (per element)" {
                    :Call coerce(raw);
                    if (coerce raises ValueError or TypeError?) then (yes)
                        :Raise ValueError:\n"Invalid operand '<raw>'...";
                    else (no)
                        :Return [coerced_value];
                    endif
                }

                if (ValueError from _coerce_operands?) then (yes)
                    :logger.log_invalid_operand(raw, "<numeric>");
                    :Print "Error: Invalid operand '<raw>'" to stderr;
                    :Return exit code 1;
                    stop
                else (no)
                    :_dispatch(op_key, operands);
                    note right
                        Delegates to
                        OperationDispatcher.dispatch()
                    end note

                    partition "OperationDispatcher.dispatch(op_key, operands)" {
                        :Look up method_name from OPERATIONS[op_key];
                        :getattr(calculator, method_name)(*operands);
                    }

                    if (ZeroDivisionError raised?) then (yes)
                        :logger.log_division_by_zero(operands);
                        :Print "Error: Division by zero" to stderr;
                        :Return exit code 1;
                        stop
                    elseif (ValueError raised?) then (yes)
                        :logger.log_domain_error(op_key, str(exc));
                        :Print "Error: <exc>" to stderr;
                        :Return exit code 1;
                        stop
                    elseif (TypeError raised?) then (yes)
                        :logger.log_domain_error(op_key, str(exc));
                        :Print "Error: <exc>" to stderr;
                        :Return exit code 1;
                        stop
                    else (no)
                        :Print result to stdout;
                        :Return exit code 0;
                        stop
                    endif
                endif
            endif
        endif
    endif
}


' -----------------------------------------------------------------------
' GUI mode flow
' -----------------------------------------------------------------------
partition "GUI Mode (python -m src --gui)" {
    start

    :Create Calculator instance;
    :Create GuiCalculator(calculator);
    note right
        GuiCalculator.__init__ creates:
        - OperationDispatcher(_calculator)
        - History()
        - _current_mode = SimpleMode()
    end note
    :_build_window(): create tkinter widget tree;
    note right
        Creates display label, mode radio buttons,
        digit buttons (0-9, "."), Clear, Equals,
        operation buttons frame, history text panel
    end note
    :_build_operation_buttons() for SimpleMode;
    note right
        Iterates SimpleMode.available_operations()
        (NORMAL_OPERATIONS) and creates one
        Button per entry in _op_frame
    end note
    :Call gui.run() -> root.mainloop();

    fork
        ' --- Digit button pressed ---
        :User clicks digit button (e.g. "5");
        :_on_digit("5");
        if (display == "0" or starts with "Error"?) then (yes)
            :Replace display with "5";
        else (no)
            :Append "5" to display;
        endif

    fork again
        ' --- Binary operation selected ---
        :User clicks binary operation (e.g. "add");
        :_on_operation_select("add");
        note right
            arity == 2
        end note
        :Parse current display as float -> first_operand;
        if (parse raises ValueError/TypeError?) then (yes)
            :_handle_error(message);
            :Display "Error: <message>";
        else (no)
            :_first_operand = parsed_value;
            :_pending_operation = "add";
            :_waiting_for_second = True;
            :Reset display to "0";
        endif

    fork again
        ' --- Equals pressed after binary op ---
        :User clicks "=";
        :_on_equals();
        if (_waiting_for_second == False?) then (yes)
            :No-op, return;
        else (no)
            :Parse current display as second operand;
            if (parse raises error?) then (yes)
                :_handle_error(message);
            else (no)
                :operands = [_first_operand, second];
                :_dispatch(_pending_operation, operands);
                note right
                    Delegates to
                    OperationDispatcher.dispatch()
                end note
                if (ZeroDivisionError?) then (yes)
                    :_logger.log_division_by_zero(operands);
                    :_handle_error("Division by zero");
                elseif (ValueError or TypeError?) then (yes)
                    :_log_error(op_key, exc);
                    :_handle_error(str(exc));
                else (no)
                    :Display formatted result;
                    :_history.add_operation(op_key, operands, result);
                    :_update_history_display();
                endif
                :_reset_binary_state();
            endif
        endif

    fork again
        ' --- Unary operation selected ---
        :User clicks unary operation (e.g. "square");
        :_on_operation_select("square");
        note right
            arity == 1
        end note
        :Parse current display as float -> value;
        if (parse raises error?) then (yes)
            :_handle_error(message);
        else (no)
            :_dispatch("square", [value]);
            if (ValueError or TypeError?) then (yes)
                :_log_error(op_key, exc);
                :_handle_error(str(exc));
            else (no)
                :Display formatted result;
                :_history.add_operation("square", [value], result);
                :_update_history_display();
            endif
        endif

    fork again
        ' --- Clear pressed ---
        :User clicks "C";
        :_on_clear();
        :Display = "0";
        :_pending_operation = None;
        :_first_operand = None;
        :_waiting_for_second = False;

    fork again
        ' --- Mode switch ---
        :User selects "Scientific" radio button;
        :_on_mode_change();
        :switch_mode(ScientificMode());
        :_build_operation_buttons();
        note right
            Rebuilds operation buttons using
            ScientificMode.available_operations()
            (full OPERATIONS dict)
        end note

    end fork

    :User closes window;
    stop
}

@enduml
