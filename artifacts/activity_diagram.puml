@startuml activity_diagram

start

:Instantiate Calculator;

:Call add(a, b);
:Return a + b;

:Call subtract(a, b);
:Return a - b;

:Call multiply(a, b);
:Return a * b;

:Call divide(a, b);
if (b == 0?) then (yes)
    :Raise ZeroDivisionError;
    stop
else (no)
    :Return a / b;
endif

:Call factorial(n);
if (n is not int?) then (yes)
    :Raise TypeError;
    stop
else (no)
    if (n < 0?) then (yes)
        :Raise ValueError;
        stop
    else (no)
        :Compute product of 1..n;
        :Return result;
    endif
endif

:Call square(x);
if (x is not numeric?) then (yes)
    :Raise TypeError;
    stop
else (no)
    :Return x * x;
endif

:Call cube(x);
if (x is not numeric?) then (yes)
    :Raise TypeError;
    stop
else (no)
    :Return x * x * x;
endif

:Call square_root(x);
if (x is not numeric?) then (yes)
    :Raise TypeError;
    stop
else (no)
    if (x < 0?) then (yes)
        :Raise ValueError;
        stop
    else (no)
        :Return math.sqrt(x);
    endif
endif

:Call cube_root(x);
if (x is not numeric?) then (yes)
    :Raise TypeError;
    stop
else (no)
    if (x < 0?) then (yes)
        :Return -(abs(x) ** (1/3));
    else (no)
        :Return abs(x) ** (1/3);
    endif
endif

:Call power(base, exponent);
if (base or exponent not numeric?) then (yes)
    :Raise TypeError;
    stop
else (no)
    if (base < 0 and exponent not int?) then (yes)
        :Raise ValueError (complex result);
        stop
    else (no)
        :Return base ** exponent;
    endif
endif

:Call log(x);
if (x is not numeric?) then (yes)
    :Raise TypeError;
    stop
else (no)
    if (x <= 0?) then (yes)
        :Raise ValueError;
        stop
    else (no)
        :Return math.log10(x);
    endif
endif

:Call ln(x);
if (x is not numeric?) then (yes)
    :Raise TypeError;
    stop
else (no)
    if (x <= 0?) then (yes)
        :Raise ValueError;
        stop
    else (no)
        :Return math.log(x);
    endif
endif

stop

@enduml
