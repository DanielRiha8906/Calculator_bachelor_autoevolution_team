@startuml
title Calculator — Activity Diagram

start

if (CLI arguments present? (sys.argv[1:])) then (yes)
  :Parse arguments with argparse (run_cli);
  note right
    CLI mode validation is one-pass.
    Invalid input exits immediately
    with code 2 (no retries).
  end note
  if (Operation recognised in OPERATIONS?) then (no)
    :Print error to stderr;
    :Exit with code 2;
    stop
  else (yes)
  endif
  if (Operand count correct?) then (no)
    :Print error to stderr;
    :Exit with code 2;
    stop
  else (yes)
  endif
  if (All operands parse as float?) then (no)
    :Print error to stderr;
    :Exit with code 2;
    stop
  else (yes)
  endif
  :Create Calculator instance;
  :dispatch(operation, operands, calc);
  if (ValueError raised?) then (yes)
    :Print error to stderr;
    :Exit with code 2;
    stop
  else (no)
    :Print result to stdout;
    stop
  endif
else (no)
endif

:Create Calculator instance;

note right
  Guided interactive mode uses retry logic.
  MAX_RETRIES = 3 (src/retry_logic.py)
  Operation retry: up to MAX_RETRIES per menu cycle.
  Operand retry: single attempt; error loops back to menu.
end note

while (session active?) is (yes)
  :Print operation menu (print_menu);
  :Prompt user for operation\n(retry_get_operation, up to MAX_RETRIES attempts);

  if (Operation == "exit"?) then (yes)
    :Print "Goodbye!";
    stop
  else (no)
    if (Operation valid?) then (no)
      :Print "Invalid operation.\nN attempt(s) remaining.";
      if (Attempt count < MAX_RETRIES?) then (yes)
        :Loop back — prompt for operation again\n(within same menu cycle);
      else (no)
        :Print "Too many failed attempts. Please try again.";
        :Loop back to top of menu (continue);
      endif
    else (yes)
      :Look up operand_count from OPERATIONS;
      group try
        :Prompt user for operand(s)\n(retry_get_operands — single attempt);
        :dispatch(operation, operands, calc);
        :Print "Result: <value>";
      end group
      if (ValueError raised?) then (yes)
        :Print "Error: <message>";
        :Loop back to top of menu;
      else (no)
        :Loop back to top of menu;
      endif
    endif
  endif
endwhile (no)

stop
@enduml
