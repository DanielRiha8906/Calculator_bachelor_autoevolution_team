@startuml activity_diagram

start

:Test method invoked;

:Request calculator fixture;
:Create Calculator() instance;
:Calculator ready;

if (Does method raise an exception\nfor this input?) then (yes)
    :Invoke method inside\npytest.raises(ExceptionType);
    note right
      ZeroDivisionError: divide(a, 0)
      ValueError: square_root(negative),
        log10/ln(non-positive),
        power(negative base + non-int exp),
        factorial(invalid input)
    end note
    :Calculator raises exception;
    :pytest.raises() catches exception;
    :Assert exception was raised;
    :PASS;
else (no)
    :Invoke calculator method\n(add / subtract / multiply / divide /\nsquare / cube / square_root / cube_root /\npower / log10 / ln / factorial);
    :Calculator executes and returns result;
    :Assert result == expected value;
    :PASS;
endif

:Test complete;

stop

@enduml
