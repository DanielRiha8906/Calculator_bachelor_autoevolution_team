@startuml
title Calculator — Activity Diagram

start

partition "Interaction Layer" {
  if ("--gui" in sys.argv?) then (yes)
    :Create CalculatorGUI();
    note right
      _current_display = "0"
      _pending_operator = None
      _pending_operand = None
      _decimal_entered = False
      _is_scientific_mode = False
      _result_just_shown = False
    end note
    :Display "0" in result label;
    :gui.run() — enter tkinter mainloop;

    repeat
      :User presses a button;

      if (Button type?) then (Digit 0-9)
        if (_result_just_shown or _current_display == "0"?) then (yes)
          :_current_display = str(digit);
          :_decimal_entered = False;
        else (no)
          :_current_display += str(digit);
        endif
        :_result_just_shown = False;
        :Update display label;

      elseif (Decimal (.)) then
        if (_result_just_shown?) then (yes)
          :_current_display = "0.";
          :_decimal_entered = True;
          :_result_just_shown = False;
        elseif (not _decimal_entered?) then (yes)
          :_current_display += ".";
          :_decimal_entered = True;
        endif
        :Update display label;

      elseif (Operator (+, −, ×, ÷)) then
        :_pending_operand = float(_current_display);
        :_pending_operator = operator_key;
        :_result_just_shown = True;
        :_decimal_entered = False;
        note right: Display not cleared — shows pending operand

      elseif (Unary function (√, x², x³, ∛, n!, ln, log)) then
        :current_float = float(_current_display);
        group try
          :result = dispatch(function_key, [current_float], calc);
          :_current_display = format_result(result);
          :_decimal_entered = "." in _current_display;
          :_result_just_shown = True;
        end group
        if (ValueError or KeyError raised?) then (yes)
          :_current_display = "Error";
          :Reset pending state;
        endif
        :Update display label;

      elseif (Equals (=)) then
        if (_pending_operator is None?) then (yes)
          :Do nothing;
        else (no)
          :current_float = float(_current_display);
          group try
            :result = dispatch(_pending_operator, [_pending_operand, current_float], calc);
            :_current_display = format_result(result);
            :_pending_operator = None;
            :_pending_operand = None;
            :_decimal_entered = "." in _current_display;
            :_result_just_shown = True;
          end group
          if (ValueError or KeyError raised?) then (yes)
            :_current_display = "Error";
            :Reset pending state;
          endif
          :Update display label;
        endif

      elseif (Clear (C)) then
        :_current_display = "0";
        :_pending_operator = None;
        :_pending_operand = None;
        :_decimal_entered = False;
        :_result_just_shown = False;
        :Update display label;

      elseif (Negate (+/-)) then
        :current_float = float(_current_display);
        :_current_display = format_result(-current_float);
        :Update display label;

      elseif (Percent (%)) then
        :current_float = float(_current_display);
        :_current_display = format_result(current_float / 100.0);
        :_decimal_entered = "." in _current_display;
        :Update display label;

      elseif (Mode toggle) then
        :_is_scientific_mode = not _is_scientific_mode;
        if (_is_scientific_mode?) then (yes)
          :Show scientific button rows (√, x², x³, ∛, n!, ln, log);
          :Mode button label → "Normal";
        else (no)
          :Hide scientific button rows;
          :Mode button label → "Scientific";
        endif
        note right: Pending state preserved

      endif

    repeat while (window open?) is (yes)
    stop

  else (no)
  endif

  if (CLI arguments present? (sys.argv[1:])) then (yes)
    :Parse arguments with argparse (run_cli);
    if (Operation recognised in OPERATIONS?) then (no)
      :Print error to stderr;
      :Exit with code 2;
      stop
    else (yes)
    endif
    if (Operand count correct?) then (no)
      :Print error to stderr;
      :Exit with code 2;
      stop
    else (yes)
    endif
    if (All operands parse as float?) then (no)
      :Print error to stderr;
      :Exit with code 2;
      stop
    else (yes)
    endif
}

partition "Calculation Layer" {
    :Create Calculator instance;
    :dispatch(operation, operands, calc);
}

partition "Interaction Layer" {
    if (ValueError raised?) then (yes)
      :Print error to stderr;
      :Exit with code 2;
      stop
    else (no)
      :Print result to stdout;
      stop
    endif
  else (no)
  endif

  :Create Calculator instance;
  note right: OperationHistory created; history.txt cleared
  :Initialize current_mode = NORMAL;

  repeat
    :Print operation menu for current_mode (print_menu);
    :attempt = 1;
    repeat
      :Prompt user for operation (get_operation);
      if (User typed "exit"?) then (yes)
        :Print "Goodbye!";
        stop
      else (no)
      endif
      if (Input is "mode normal" or "mode scientific"?) then (yes)
        :handle_mode_switch(input, current_mode);
        :Update current_mode;
        :Print "Switched to <mode> mode.";
        break
      else (no)
      endif
      if (Input is "history"?) then (yes)
        :Use operation;
        break
      else (no)
      endif
      :validate_operation(choice, current_mode);
      if (Valid operation for mode?) then (yes)
        :Use operation;
        break
      else (no)
        :Print error + attempt counter message;
        :attempt = attempt + 1;
      endif
    repeat while (attempt <= MAX_RETRY_ATTEMPTS?) is (yes)
    if (Retries exceeded?) then (yes)
      :Print "Session terminated due to too many invalid operation entries.";
      stop
    else (no)
    endif

    if (Operation is "history"?) then (yes)
      :print_history(history);
      if (history entries exist?) then (yes)
        :Print each entry;
      else (no)
        :Print "No operations recorded in this session.";
      endif
    else (no)
    endif
    if (Operation is "history"?) then (yes)
      :continue;
    else (no)
    endif

    :Look up operand_count from OPERATIONS;

    :operand_index = 1;
    :all_operands_ok = true;
    while (operand_index <= operand_count?) is (yes)
      :attempt = 1;
      repeat
        :Prompt user for operand N;
        :validate_operand(raw);
        if (Valid numeric value?) then (yes)
          :Append float to operands list;
          break
        else (no)
          :Print error + attempt counter message;
          :attempt = attempt + 1;
        endif
      repeat while (attempt <= MAX_RETRY_ATTEMPTS?) is (yes)
      if (Retries exceeded for this operand?) then (yes)
        :Print "Maximum retry attempts reached. Returning to menu.";
        :all_operands_ok = false;
        break
      else (no)
        :operand_index = operand_index + 1;
      endif
    endwhile

    if (all_operands_ok?) then (no)
      :Print "Returning to the main menu.";
    else (yes)
}

partition "Calculation Layer" {
      group try
        :dispatch(operation, operands, calc);
      end group
}

partition "Interaction Layer" {
      :Print Result;
      :history.record_operation(operation, operands, result);
      :Append entry to history.txt;
      if (ValueError raised?) then (yes)
        :Log error to ErrorLogger with category and context;
        :Print "Error: <message>";
      else (no)
      endif
    endif

  repeat while (loop continues) is (yes)
}

stop
@enduml
