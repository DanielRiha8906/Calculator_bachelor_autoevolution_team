@startuml activity_diagram

skinparam ArrowColor #444444
skinparam ActivityBorderColor #444444
skinparam swimlaneBorderColor #888888

|User|
start

fork
    :Provide operand_a string\n(interactive prompt);
    :Provide operand_b string\n(interactive prompt);
    :Provide operator string\n(interactive prompt);

    |__main__|
    :Call parse_input(operand_a, operand_b, operator);

fork again
    :Invoke python -m src.cli\n<operand1> <operator> <operand2>\n(sys.argv);

    |cli|
    if (len(sys.argv) != 4?) then (yes)
        :Print usage to stderr;
        :exit(2);
        end
    else (no)
    endif

    :Call parse_input(operand1, operand2, operator);

end fork

|input_handler / Calculator|
:parse_operand attempts float conversion\nfor both operands;

if (conversion fails?) then (yes)
    :Print error to stderr;
    :exit(1);
    end
else (no)
endif

:BINARY_OPERATORS lookup for operator;

if (operator unsupported?) then (yes)
    :Print error to stderr;
    :exit(1);
    end
else (no)
endif

:Return (a, b, method_name);

fork
    |__main__|
    :Call run_calculation(a, b, method_name);
fork again
    |cli|
    :Call run_calculation(a, b, method_name);
end fork

|input_handler / Calculator|
:Instantiate Calculator;
:Dispatch Calculator method via getattr;

if (arithmetic error?\n(ZeroDivisionError / ValueError)) then (yes)
    :Print error to stderr;
    :exit(1);
    end
else (no)
endif

:Return result float;

fork
    |__main__|
    :Print "Result: {result}";
fork again
    |cli|
    :Print result to stdout;
end fork

|User|
end

@enduml
