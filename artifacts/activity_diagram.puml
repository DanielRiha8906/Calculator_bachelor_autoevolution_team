@startuml Calculator User Interaction Flow

title Calculator User Interaction Flow

' -----------------------------------------------------------------------
' Entry-point mode dispatch (src/__main__.py)
' -----------------------------------------------------------------------
partition "Entry Point (src/__main__.py main())" {
    start
    :Create Calculator instance;
    if ("--gui" in sys.argv?) then (yes)
        :import tkinter as tk\nimport GuiCalculator (conditional);
        :root = tk.Tk();
        :GuiCalculator(root, calc).run();
        note right
            Enters Tk main-event loop.
            See GUI Mode partition below.
        end note
        stop
    else (no)
        :run_session(calc);
        note right
            Default CLI mode — unchanged behaviour.
            See interactive session flow below.
        end note
        stop
    endif
}

' -----------------------------------------------------------------------
' Interactive session flow (InputHandler)
' -----------------------------------------------------------------------

start

:Create Calculator instance;
:Create InputHandler with calculator;
note right
    InputHandler.__init__ also creates
    an OperationDispatcher instance
    (_dispatcher = OperationDispatcher(calc))
end note
:Call handler.run();
:op_attempts = 0;

repeat
    :_show_menu()\nPrint available operations filtered by _mode\n(Normal Mode: NORMAL_OPERATIONS only;\nScientific Mode: all OPERATIONS);
    :Prompt user: "Enter operation (or 'exit'/'quit' to stop)";
    :Read and strip/lower input;

    if (input == "exit" or "quit"?) then (yes)
        :Print "Goodbye!";
        stop
    else (no)
        if (parse_mode_command(input) returns a Mode?) then (yes)
            :Update _mode to returned Mode;
            :Print "Mode switched to: <mode>";
            ' loop back to top
        else (no)
            if (op_choice in OPERATIONS?) then (no)
                :op_attempts += 1;
                :logger.log_unsupported_operation(op_choice);
                :Print "Error: Unknown operation '<op_choice>'.\nPlease choose from the menu.";
                :Print "Available operations: " + list of keys in current mode;
                if (op_attempts >= MAX_RETRIES?) then (yes)
                    :Print "Too many invalid attempts. Ending session.";
                    stop
                else (no)
                    ' retry < MAX_RETRIES: loop back to operation input
                endif
            else (yes)
                if (op_choice in _get_available_operations_for_mode()?) then (no)
                    :Print "Error: '<op_choice>' is only available in scientific mode.\nType 'mode scientific' to switch.";
                    ' loop back without incrementing op_attempts
                else (yes)
                    :op_attempts = 0;
                    :Look up op_info from OPERATIONS;
                    :Extract arity and coerce callable;

                    :_prompt_operands(arity, coerce);
                    note right
                        For each operand position:
                        attempt_count = 0 .. MAX_RETRIES-1
                        (arity=0 operations skip this entirely)
                    end note

                    partition "_prompt_operands retry loop" {
                        repeat
                            :Prompt for operand (label: first/second/"");
                            :Read raw input;

                            partition "OperationDispatcher.coerce_operands([raw], coerce)" {
                                :Call coerce(raw);
                                if (coerce raises ValueError or TypeError?) then (yes)
                                    :Raise ValueError:\n"Invalid operand '<raw>'...";
                                else (no)
                                    :Return [coerced_value];
                                endif
                            }

                            if (ValueError from coerce_operands?) then (yes)
                                :attempt_count += 1;
                                :logger.log_invalid_operand(raw, "<numeric>");
                                :Print "Error: Invalid operand '<raw>': expected a numeric value.";
                                if (attempt_count >= MAX_RETRIES?) then (yes)
                                    :Raise ValueError:\n"Too many invalid attempts for operand. Ending session.";
                                else (no)
                                    ' retry < MAX_RETRIES: re-prompt same operand
                                endif
                            else (no)
                                :Append coerced value to operands list;
                            endif
                        repeat while (more operands to collect)
                    }

                    if (ValueError raised during _prompt_operands?) then (yes)
                        :Print "Error: <exc>";
                    else (no)
                        :_dispatch(op_choice, operands);
                        note right
                            Delegates to
                            OperationDispatcher.dispatch()
                        end note

                        partition "OperationDispatcher.dispatch(op_key, operands)" {
                            :Look up method_name from OPERATIONS[op_key];
                            :getattr(calculator, method_name)(*operands);
                        }

                        if (ZeroDivisionError raised?) then (yes)
                            :logger.log_division_by_zero(operands);
                            :Print "Error: Division by zero is not allowed.";
                        elseif (ValueError raised?) then (yes)
                            :logger.log_domain_error(op_choice, str(exc));
                            :Print "Error: <exc>";
                        elseif (TypeError raised?) then (yes)
                            :logger.log_domain_error(op_choice, str(exc));
                            :Print "Error: <exc>";
                        else (no)
                            :Print "Result: <result>";
                        endif
                    endif
                endif
            endif
        endif
    endif
repeat while (session active)

' -----------------------------------------------------------------------
' CLI mode flow
' -----------------------------------------------------------------------
partition "CLI Mode (main.py)" {
    start

    :Create Calculator instance;
    :Create CliDispatcher with calculator;
    note right
        CliDispatcher.__init__ also creates
        an OperationDispatcher instance
        (_dispatcher = OperationDispatcher(calc))
    end note
    :Call dispatcher.dispatch_from_args(sys.argv[1:]);

    if (args is empty?) then (yes)
        :Print usage and available operations to stderr;
        :Return exit code 1;
        stop
    else (no)
        :Extract op_key = args[0].lower();

        if (op_key in OPERATIONS?) then (no)
            :logger.log_unsupported_operation(op_key);
            :Print "Error: Unknown operation '<op_key>'" to stderr;
            :Return exit code 1;
            stop
        else (yes)
            :Look up op_info from OPERATIONS;
            :Extract arity and coerce callable;

            :operand_args = args[1:];

            if (len(operand_args) != arity?) then (yes)
                :logger.log_invalid_argument_count(op_key, arity, len(operand_args));
                :Print "Error: wrong operand count" to stderr;
                :Return exit code 1;
                stop
            else (no)
                :_coerce_operands(operand_args, coerce);
                note right
                    Iterates per element;
                    delegates to
                    OperationDispatcher.coerce_operands([raw], coerce)
                end note

                partition "OperationDispatcher.coerce_operands (per element)" {
                    :Call coerce(raw);
                    if (coerce raises ValueError or TypeError?) then (yes)
                        :Raise ValueError:\n"Invalid operand '<raw>'...";
                    else (no)
                        :Return [coerced_value];
                    endif
                }

                if (ValueError from _coerce_operands?) then (yes)
                    :logger.log_invalid_operand(raw, "<numeric>");
                    :Print "Error: Invalid operand '<raw>'" to stderr;
                    :Return exit code 1;
                    stop
                else (no)
                    :_dispatch(op_key, operands);
                    note right
                        Delegates to
                        OperationDispatcher.dispatch()
                    end note

                    partition "OperationDispatcher.dispatch(op_key, operands)" {
                        :Look up method_name from OPERATIONS[op_key];
                        :getattr(calculator, method_name)(*operands);
                    }

                    if (ZeroDivisionError raised?) then (yes)
                        :logger.log_division_by_zero(operands);
                        :Print "Error: Division by zero" to stderr;
                        :Return exit code 1;
                        stop
                    elseif (ValueError raised?) then (yes)
                        :logger.log_domain_error(op_key, str(exc));
                        :Print "Error: <exc>" to stderr;
                        :Return exit code 1;
                        stop
                    elseif (TypeError raised?) then (yes)
                        :logger.log_domain_error(op_key, str(exc));
                        :Print "Error: <exc>" to stderr;
                        :Return exit code 1;
                        stop
                    else (no)
                        :Print result to stdout;
                        :Return exit code 0;
                        stop
                    endif
                endif
            endif
        endif
    endif
}

' -----------------------------------------------------------------------
' GUI mode flow
' -----------------------------------------------------------------------
partition "GUI Mode (GuiCalculator)" {
    start

    :Create Calculator instance;
    :Create GuiCalculator(root, calculator);
    note right
        __init__ creates OperationDispatcher,
        BaseMode, History; mode = NORMAL.
        _setup_layout() builds all widgets.
    end note
    :Call gui.run() — enter Tk main loop;

    repeat
        if (user changes mode radio button?) then (yes)
            :_on_mode_change(new_mode);
            :_mode = new_mode;
            :_setup_operation_grid()\nRebuild buttons via\nBaseMode.get_available_operations();
        else (operation button clicked)
            :_on_operation_click(op_key);
            :Look up op_info from OPERATIONS;
            :Extract arity and coerce;

            :_prompt_operands_dialog(op_key, arity, coerce);
            note right
                One simpledialog.askstring per operand.
                Returns None if user cancels any dialog
                or if coercion fails (error dialog shown).
            end note

            if (operands is None (cancelled or invalid)?) then (yes)
                :No-op; return to event loop;
            else (no)
                :_execute_operation(op_key, operands);

                :OperationDispatcher.dispatch(op_key, operands);

                if (ZeroDivisionError?) then (yes)
                    :logger.log_division_by_zero(operands);
                    :_show_error_dialog("Division by Zero", ...);
                elseif (ValueError?) then (yes)
                    :logger.log_domain_error(op_key, ...);
                    :_show_error_dialog("Domain Error", ...);
                elseif (TypeError?) then (yes)
                    :logger.log_domain_error(op_key, ...);
                    :_show_error_dialog("Type Error", ...);
                else (no)
                    :_history.add_operation(...);
                    :_update_result_display(result);
                    :_update_history_display();
                endif
            endif
        endif
    repeat while (window open)
    stop
}

@enduml
