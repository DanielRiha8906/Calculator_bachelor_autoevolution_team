@startuml activity_diagram

start

:Instantiate Calculator;

partition "Basic Arithmetic" {
  :add(a, b) → a + b;
  :subtract(a, b) → a - b;
  :multiply(a, b) → a * b;

  :divide(a, b);
  if (b == 0?) then (yes)
    :Raise ZeroDivisionError;
    detach
  else (no)
    :Return a / b;
  endif
}

partition "Factorial" {
  :factorial(n);
  if (n is bool?) then (yes)
    :Raise TypeError;
    detach
  else (no)
  endif
  if (n is float?) then (yes)
    if (n.is_integer()?) then (no)
      :Raise TypeError;
      detach
    else (yes)
      :Convert n to int;
    endif
  else (no)
  endif
  if (n is not int?) then (yes)
    :Raise TypeError;
    detach
  else (no)
  endif
  if (n < 0?) then (yes)
    :Raise ValueError;
    detach
  else (no)
  endif
  :Compute n! iteratively (result = 1; for i in 2..n: result *= i);
  :Return result;
}

partition "Unary Power Operations\n(all raise TypeError for bool or non-numeric input)" {
  :square(x) → x * x;
  :cube(x) → x * x * x;

  :square_root(x);
  if (x < 0?) then (yes)
    :Raise ValueError;
    detach
  else (no)
    :Return math.sqrt(x);
  endif

  :cube_root(x);
  :Return math.copysign(abs(x)^(1/3), x);

  :power(base, exponent);
  :Return float(base ** exponent);
}

partition "Logarithms\n(both raise TypeError for bool or non-numeric input)" {
  :log10(x);
  if (x <= 0?) then (yes)
    :Raise ValueError;
    detach
  else (no)
    :Return math.log10(x);
  endif

  :natural_log(x);
  if (x <= 0?) then (yes)
    :Raise ValueError;
    detach
  else (no)
    :Return math.log(x);
  endif
}

stop

@enduml
