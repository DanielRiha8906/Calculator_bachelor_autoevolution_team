@startuml activity_diagram

start

:__main__.main() is invoked;

if (sys.argv has arguments?) then (yes — CLI mode)

    partition "run_cli(args)" {
        if (args is empty?) then (yes)
            :Print usage error to stderr;
            :Return exit code 1;
            stop
        else (no)
            :Join args with spaces → expression string;
            :Instantiate Calculator (with empty OperationHistory);

            partition "parse_and_evaluate(expression, calc)" {
                :Strip expression;
                if (expression is empty?) then (yes)
                    :Raise ValueError "Expression must not be empty";
                else (no)
                    :ast.parse(expression, mode="eval");
                    if (SyntaxError?) then (yes)
                        :Raise ValueError "Invalid expression syntax";
                    else (no)
                        partition "_eval_node(tree.body, calc)" {
                            if (node is ast.Constant?) then (yes)
                                :Return constant value (int or float);
                            elseif (node is ast.UnaryOp?) then (yes)
                                :Recurse on operand;
                                if (USub?) then (yes)
                                    :calc.multiply(operand, -1);
                                    :calc._history.add_record("multiply", ...);
                                else (UAdd)
                                    :Return operand as-is;
                                endif
                            elseif (node is ast.BinOp?) then (yes)
                                :Recurse on left and right nodes;
                                if (Add?) then (yes)
                                    :calc.add(left, right);
                                    :calc._history.add_record("add", ...);
                                elseif (Sub?) then (yes)
                                    :calc.subtract(left, right);
                                    :calc._history.add_record("subtract", ...);
                                elseif (Mult?) then (yes)
                                    :calc.multiply(left, right);
                                    :calc._history.add_record("multiply", ...);
                                elseif (Div?) then (yes)
                                    :calc.divide(left, right);
                                    if (b == 0?) then (yes)
                                        :Raise ZeroDivisionError;
                                    else (no)
                                        :calc._history.add_record("divide", ...);
                                    endif
                                else (Pow)
                                    :calc.power(left, right);
                                    :calc._history.add_record("power", ...);
                                endif
                            else (unsupported node)
                                :Raise ValueError "Unsupported expression node";
                            endif
                        }
                    endif
                endif
            }

            if (ZeroDivisionError?) then (yes)
                :Print "Error: Division by zero is not allowed." to stderr;
                :Return exit code 1;
                stop
            elseif (ValueError?) then (yes)
                :Print error message to stderr;
                :Return exit code 1;
                stop
            elseif (TypeError?) then (yes)
                :Print error message to stderr;
                :Return exit code 1;
                stop
            else (success)
                :Print result to stdout;
                :Return exit code 0;
                stop
            endif
        endif
    }

else (no — interactive mode)

    partition "run_interactive()" {
        :Instantiate Calculator (with empty OperationHistory);
        :Build operation list from OPERATIONS keys;
        :Display numbered list of available operations;
        :op_attempts = 0;

        repeat

            :Prompt "Select operation:";
            :op_attempts += 1;

            if (input is 'quit' or 'exit'?) then (yes)
                :Print "Bye!";
                stop
            elseif (input not in OPERATIONS?) then (yes)
                if (op_attempts >= MAX_RETRIES?) then (yes)
                    :Print max-retries-exceeded error;
                    stop
                else (no)
                    :Print unknown-operation error;
                endif
            else (valid operation)
                :op_attempts = 0;

                partition "get_operands(operation)" {
                    :Look up operand_count in OPERATIONS;
                    :operand_attempts = 0;
                    repeat
                        :Prompt user for next operand;
                        :operand_attempts += 1;
                        if (parse_number(raw) succeeds?) then (yes)
                            :Append parsed number to operands list;
                            :operand_attempts = 0;
                        else (InvalidInputError)
                            if (operand_attempts >= MAX_RETRIES?) then (yes)
                                :Raise OperandRetryExceeded;
                            else (no)
                                :Print error message, retry same operand;
                            endif
                        endif
                    repeat while (all operands collected?) is (no)
                    -> yes;
                }

                if (OperandRetryExceeded?) then (yes)
                    :Print retry-exceeded error;
                else (no)

                    partition "execute_operation(calc, operation, operands)" {
                        :Resolve Calculator method name via OPERATIONS;
                        :Call method(*operands) on Calculator instance;
                        if (exception raised?) then (ZeroDivisionError)
                            :Return "Error: Division by zero is not allowed.";
                        elseif (ValueError)
                            :Return "Error: <exception message>";
                        elseif (TypeError)
                            :Return "Error: <exception message>";
                        else (success)
                            :calc._history.add_record(op, operands, result, now());
                            :Return numeric result;
                        endif
                    }

                    :format_result(result) → str;
                    :Print "Result: <formatted_result>";

                endif

            endif

        repeat while (loop continues?) is (yes)
        -> no;

        stop
    }

endif

@enduml
