@startuml
title Calculator — Activity Diagram

start

if (CLI arguments present? (sys.argv[1:])) then (yes)
  :Parse arguments with argparse (run_cli);
  if (Operation recognised in OPERATIONS?) then (no)
    :Print error to stderr;
    :Exit with code 2;
    stop
  else (yes)
  endif
  if (Operand count correct?) then (no)
    :Print error to stderr;
    :Exit with code 2;
    stop
  else (yes)
  endif
  if (All operands parse as float?) then (no)
    :Print error to stderr;
    :Exit with code 2;
    stop
  else (yes)
  endif
  :Create Calculator instance;
  :dispatch(operation, operands, calc);
  if (ValueError raised?) then (yes)
    :Print error to stderr;
    :Exit with code 2;
    stop
  else (no)
    :Print result to stdout;
    stop
  endif
else (no)
endif

:Create Calculator instance;
:Print operation menu (print_menu);
:Prompt user for operation (get_operation);

if (Operation == "exit"?) then (yes)
  :Print "Goodbye!";
  stop
else (no)
  if (Operation == "__invalid__"?) then (yes)
    :Loop back to menu;
    :Print operation menu (print_menu);
    :Prompt user for operation (get_operation);
  else (no)
    :Look up operand_count from OPERATIONS;
    group try
      :Prompt user for operand(s) (get_operands);
      :Dispatch operation to Calculator (dispatch);
      :Print Result;
    end group
    if (ValueError raised?) then (yes)
      :Print "Error: <message>";
    else (no)
    endif
    :Loop back to menu;
    :Print operation menu (print_menu);
    :Prompt user for operation (get_operation);
  endif
endif

stop
@enduml
