@startuml activity_diagram_interactive_mode
!theme plain

start

:Initialize history, error_log;
:consecutive_failures = 0;
:current_mode = MODE_NORMAL;
:active_registry = _build_registry(MODE_NORMAL);

repeat
  :Prompt: enter operation name;
  :operation = input().strip().lower();

  if (operation in {quit, exit, q}?) then (yes)
    break
  endif

  if (operation == "history"?) then (yes)
    :Display operation history;
    :consecutive_failures = 0;
  elseif (operation starts with "mode"?) then (yes)
    if (mode_arg == "normal" or "norm"?) then (yes)
      :current_mode = MODE_NORMAL;
      :active_registry = _build_registry(MODE_NORMAL);
      :Print "Mode switched to normal.";
    elseif (mode_arg == "scientific" or "sci"?) then (yes)
      :current_mode = MODE_SCIENTIFIC;
      :active_registry = _build_registry(MODE_SCIENTIFIC);
      :Print "Mode switched to scientific.";
    else (no)
      :Print "Unknown mode. Use normal or scientific.";
      :consecutive_failures += 1;
    endif
  elseif (MODE_NORMAL and op in _SCIENTIFIC_OPS_BLOCKED?) then (yes)
    :Print "Error: operation not available in normal mode";
    :consecutive_failures += 1;
  elseif (not active_registry.has(operation)?) then (yes)
    :Log unsupported operation error;
    :Print "Error: Unknown operation";
    :consecutive_failures += 1;
  else (no)
    :op_obj = active_registry.get(operation);
    :Collect operands via InputValidator;
    if (input parse error?) then (yes)
      :Log invalid input;
      :consecutive_failures += 1;
    else (no)
      :result = op_obj.execute(*operands);
      if (execution error?) then (yes)
        :Log calculation error;
        :consecutive_failures += 1;
      else (no)
        :Print result;
        :history.record(operation, operands, result);
        :consecutive_failures = 0;
      endif
    endif
  endif

  if (consecutive_failures >= 3?) then (yes)
    :Print "Too many invalid attempts. Exiting.";
    break
  endif

repeat while (user continues)

stop

@enduml
