@startuml class_diagram

package "src" {
    class Calculator {
        +add(a, b) : float
        +subtract(a, b) : float
        +multiply(a, b) : float
        +divide(a, b) : float
        +factorial(n: int) : int
        +square(x: int|float) : int|float
        +cube(x: int|float) : int|float
        +square_root(x: int|float) : float
        +cube_root(x: int|float) : float
        +power(base: int|float, exponent: int|float) : int|float
        +log(x: int|float) : float
        +ln(x: int|float) : float
    }

    class InputHandler <<module>> {
        +get_operation_registry(calculator: Calculator) : dict
        +display_menu(registry: dict) : None
        +get_operation_choice(registry: dict) : tuple | None
        +get_operands(arity: int) : list[float]
        +run_interactive_session(calculator: Calculator) : None
    }
}

package "__main__" {
    class EntryPoint <<module>> {
        +main() : None
    }
}

EntryPoint ..> Calculator : instantiates
EntryPoint ..> InputHandler : calls run_interactive_session()
InputHandler ..> Calculator : invokes methods via registry

note right of Calculator::factorial
  Raises TypeError if n is not int.
  Raises ValueError if n < 0.
end note

note right of Calculator::square_root
  Raises TypeError if x is not numeric.
  Raises ValueError if x < 0.
end note

note right of Calculator::cube_root
  Supports negative inputs via sign handling.
  Raises TypeError if x is not numeric.
end note

note right of Calculator::power
  Raises ValueError if base < 0 and
  exponent is non-integer (complex result).
end note

note right of Calculator::log
  Base-10 logarithm (log₁₀).
  Raises ValueError if x <= 0.
end note

note right of Calculator::ln
  Natural logarithm (ln).
  Raises ValueError if x <= 0.
end note

note right of InputHandler::get_operation_choice
  Returns None on quit (q/quit/exit).
  Accepts operation name or 1-based index.
end note

note right of InputHandler::run_interactive_session
  Catches TypeError, ValueError,
  ZeroDivisionError per iteration.
end note

@enduml
