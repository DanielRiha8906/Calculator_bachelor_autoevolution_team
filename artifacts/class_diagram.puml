@startuml class_diagram
title Calculator — Class Diagram

component [main()] <<entry point>>

class Calculator {
  +add(a, b) : float
  +subtract(a, b) : float
  +multiply(a, b) : float
  +divide(a, b) : float
  +power(x, y) : float
  +factorial(n: int) : int
  +square(x) : float
  +cube(x) : float
  +square_root(x) : float
  +cube_root(x) : float
  +log(x) : float
  +ln(x) : float
}

class OperationRegistry {
  -_registry : dict
  +__init__(calculator: Calculator) : None
  +get_operation(key: str) : tuple
  +list_operations() : dict
}

class InputHandler {
  +get_operation_choice(available_operations: dict) : str
  +get_operand(prompt: str) : float
  +display_result(operation, operands, result) : None
  +display_error(message: str) : None
}

