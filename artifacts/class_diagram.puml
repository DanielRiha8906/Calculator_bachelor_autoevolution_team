skinparam classAttributeIconSize 0

class Calculator {
    -_engine : CalculationEngine
    +add(a, b) : float
    +subtract(a, b) : float
    +multiply(a, b) : float
    +divide(a, b) : float
    +factorial(n) : int
    +square(x: float) : float
    +cube(x: float) : float
    +square_root(x: float) : float
    +cube_root(x: float) : float
    +power(base: float, exponent: float) : float
    +logarithm(x: float) : float
    +natural_logarithm(x: float) : float
    +sin(x: float) : float
    +cos(x: float) : float
    +tan(x: float) : float
}

note right of Calculator
  Facade (src/calculator.py).
  Arithmetic methods (add/subtract/multiply/divide)
  delegate to internal CalculationEngine.
  Scientific methods are implemented directly.
end note

note right of Calculator::divide
  Delegates to CalculationEngine.divide().
  Raises ZeroDivisionError when b == 0.
end note

note right of Calculator::factorial
  Raises TypeError if n is a
  non-integer float (e.g. 5.5).
  Raises ValueError if n < 0.
  Accepts whole-number floats
  (e.g. 5.0) by coercing to int.
end note

note right of Calculator::square_root
  Raises ValueError if x < 0.
end note

note right of Calculator::logarithm
  Base-10 log (math.log10).
  Raises ValueError if x <= 0.
end note

note right of Calculator::natural_logarithm
  Natural log base e (math.log).
  Raises ValueError if x <= 0.
end note

note right of Calculator::sin
  Radians input (math.sin).
  Available in scientific mode only.
end note

note right of Calculator::cos
  Radians input (math.cos).
  Available in scientific mode only.
end note

note right of Calculator::tan
  Radians input (math.tan).
  Available in scientific mode only.
end note

class CalculationEngine {
    +add(a: float, b: float) : float
    +subtract(a: float, b: float) : float
    +multiply(a: float, b: float) : float
    +divide(a: float, b: float) : float
}

note right of CalculationEngine
  Core arithmetic engine (src/core/engine.py).
  Handles the four basic arithmetic operations.
  divide() raises ZeroDivisionError if b == 0.
  Calculator owns exactly one instance via _engine.
end note

class MaxRetriesExceeded {
}

note right of MaxRetriesExceeded
  Raised when the user exceeds
  MAX_RETRIES (3) consecutive
  invalid inputs in the REPL.
  Defined in src/support/exceptions.py;
  re-exported by src/exceptions.py shim.
end note

MaxRetriesExceeded --|> Exception

class ErrorLogger {
    +INVALID_INPUT : str
    +UNSUPPORTED_OPERATION : str
    +CALCULATION_ERROR : str
    +error_file : str
    +__init__(error_file: str = "error.log")
    +clear_errors() : None
    +log_error(error_type: str, user_input: str, exception: Exception) : None
    +get_errors() : list[str]
}

note right of ErrorLogger::clear_errors
  Truncates or creates the error log file.
  Called once at session start for
  session isolation.
end note

note right of ErrorLogger::log_error
  Appends an ISO8601-timestamped entry
  to the error file. Entry includes
  error_type, user_input, and exception message.
  File I/O errors are logged to stderr.
end note

note right of ErrorLogger::get_errors
  Returns list of recorded error entries,
  trailing newlines stripped.
  Returns [] on FileNotFoundError or OSError.
end note

class OperationHistory {
    +history_file : str
    +__init__(history_file: str = "history.txt")
    +clear_history() : None
    +record_operation(entry: str) : None
    +display_history() : list[str]
}

note right of OperationHistory::clear_history
  Truncates or creates the history file.
  Called once at session start for
  session isolation.
end note

note right of OperationHistory::record_operation
  Appends entry + newline to history file.
  File I/O errors are logged to stderr
  and silently swallowed.
end note

note right of OperationHistory::display_history
  Returns list of recorded entries,
  trailing newlines stripped.
  Returns [] on FileNotFoundError or OSError.
end note

class Operation <<dataclass>> {
    +name : str
    +arity : int
    +display_name : str
    +aliases : tuple[str, ...]
    +mode : str
}

note right of Operation
  Frozen dataclass (src/core/operations.py).
  Metadata for a single calculator operation.
  mode field: "both" (visible in all modes),
  "scientific" (visible only in scientific mode).
  15 operations in _CATALOG: 12 with mode="both"
  (arithmetic, roots, log, power), 3 with
  mode="scientific" (sin, cos, tan).
end note

class OperationRegistry {
    -calculator : Any
    -_current_mode : str
    -_operations : list[Operation]
    -_lookup : dict[str, Operation]
    +__init__(calculator: Any)
    +set_mode(mode: str) : None
    +get_operations() : list[Operation]
    +get_operation(token: str) : Operation | None
    +resolve(token: str) : str
    +arity(token: str) : int
    +get_operation_mapping() : dict[str, str]
    +dispatch(operation: str, operands: list[float]) : float
}

note right of OperationRegistry::__init__
  Builds _lookup from the module-level
  _CATALOG (15 operations): every name
  and alias maps to its Operation.
  _current_mode defaults to "normal".
end note

note right of OperationRegistry::set_mode
  Sets _current_mode ("normal" or "scientific").
  Filters visible operations in get_operations(),
  resolve(), arity(), and get_operation_mapping().
  Raises ValueError for unrecognised mode strings.
end note

note right of OperationRegistry::resolve
  Returns the canonical operation name
  for a given token (name or alias).
  Raises ValueError if token unknown or
  not available in the current mode.
end note

note right of OperationRegistry::get_operation_mapping
  Returns a flat dict: every accepted
  token (name + aliases) → canonical name.
  Only tokens for mode-compatible operations
  are included.
  Useful for components that need a
  simple token → method_name mapping.
end note

note right of OperationRegistry::dispatch
  Executes the operation with operands.
  "logarithm" is treated as a two-argument
  log(x, base) via math.log(x, base) with
  full domain validation — this special case
  is isolated here so CLI and REPL do not
  need to handle it independently.
  All other operations are forwarded to the
  injected Calculator via getattr.
  Raises ValueError, ZeroDivisionError,
  TypeError, or OverflowError.
end note

class CalculatorContext {
    +current_mode : str
    +__init__()
    +set_mode(mode: str) : None
    +get_mode() : str
    +is_scientific_mode() : bool
}

note right of CalculatorContext
  Single source of truth for mode state
  (src/context.py).
  Defaults to "normal" on construction.
  Valid modes: "normal", "scientific".
  Raises ValueError for unknown mode strings.
  Both REPL and CLI layers read from it;
  the REPL also writes when the user
  issues a mode-switch command.
end note

class REPLInterface {
    +OPERATIONS : dict
    -calculator : Calculator
    -history : OperationHistory | None
    -error_logger : ErrorLogger | None
    -last_result : float | None
    -_context : CalculatorContext
    -_registry : OperationRegistry
    -_operations : list[Operation]
    -_operation_keys : list[str]
    +__init__(calculator: Calculator, history: OperationHistory | None, error_logger: ErrorLogger | None, context: CalculatorContext | None)
    +run() : void
    +get_operation_selection() : str
    +get_operand(prompt: str) : float
    +display_result(operation: str, operands: list, result: float) : void
    -_first_operand_prompt(label: str) : str
    -_execute(operation: str, operands: list) : float
    -_refresh_operations() : void
    -_is_valid_operand(raw_input: str) : bool
    -_is_valid_operation_input(raw_input: str) : bool
}

note right of REPLInterface::OPERATIONS
  Module-level dict (backwards-compat shim)
  mapping operation name → {arity, label}
  for all 15 supported operations.
  Built from OperationRegistry._CATALOG.
end note

note right of REPLInterface::last_result
  Carries the result of the last
  operation forward as the default
  first operand for the next operation.
end note

note right of REPLInterface::_execute
  Delegates entirely to
  OperationRegistry.dispatch(operation, operands).
  The two-argument logarithm special case
  is handled inside the registry.
end note

note right of REPLInterface::get_operation_selection
  Displays current mode and operation menu.
  Handles "mode <name>" to switch modes via
  CalculatorContext and OperationRegistry,
  then calls _refresh_operations().
  Re-prompts on invalid input.
  Raises MaxRetriesExceeded after
  MAX_RETRIES (3) failed attempts.
  Returns "history" for history display.
end note

note right of REPLInterface::_refresh_operations
  Refreshes _operations and _operation_keys
  from the registry after a mode change so
  the menu reflects the updated operation set.
end note

note right of REPLInterface::get_operand
  Re-prompts on invalid input.
  Returns last_result on empty Enter.
  Raises MaxRetriesExceeded after
  MAX_RETRIES (3) failed attempts.
end note

note right of REPLInterface::_is_valid_operand
  Returns True if raw_input can
  be parsed as a float.
end note

note right of REPLInterface::_is_valid_operation_input
  Returns True if raw_input is "quit",
  "history", a "mode <name>" command,
  or a valid menu index in
  [1, len(_operation_keys)].
end note

class CLIHandler {
    -calculator : Calculator
    -history : OperationHistory | None
    -error_logger : ErrorLogger | None
    -_context : CalculatorContext
    -_registry : OperationRegistry
    +__init__(calculator: Calculator, history: OperationHistory | None, error_logger: ErrorLogger | None, context: CalculatorContext | None)
    +get_operation_mapping() : dict
    +parse_args(args: list[str]) : tuple[str, list[float]]
    +execute(args: list[str]) : float
}

note right of CLIHandler::get_operation_mapping
  Delegates to OperationRegistry.
  Maps names and symbols to canonical
  Calculator method names.
  Supports aliases: +, -, *, /,
  ^, sqrt, cbrt, log, ln.
  Only tokens for the active mode are included.
end note

note right of CLIHandler::parse_args
  Uses OperationRegistry to resolve
  the operation token and validate arity.
  Converts operand strings to float.
  Raises ValueError on any error.
end note

note right of CLIHandler::execute
  Delegates dispatch to
  OperationRegistry.dispatch(method_name, operands).
  Logs UNSUPPORTED_OPERATION, INVALID_INPUT,
  or CALCULATION_ERROR via error_logger if set.
  Records result to history if set.
  Raises ValueError, ZeroDivisionError,
  or TypeError on error.
end note

