@startuml
title Calculator — Class Diagram

note "Calculator has no I/O dependencies.\nAll user interaction is handled by the Interaction Layer." as N1

package "Calculation Layer" {
  class Calculator {
    +add(a, b) : float
    +subtract(a, b) : float
    +multiply(a, b) : float
    +divide(a, b) : float
    +power(base: float, exponent: float) : float
    +factorial(n: int) : int
    +square(x: float) : float
    +cube(x: float) : float
    +square_root(x: float) : float
    +cube_root(x: float) : float
    +log(x: float) : float
    +ln(x: float) : float
  }

  package "operations" {
    class arithmetic <<module>> {
      +add(a: float, b: float) : float
      +subtract(a: float, b: float) : float
      +multiply(a: float, b: float) : float
      +divide(a: float, b: float) : float
    }

    class exponents <<module>> {
      +power(base: float, exponent: float) : float
      +factorial(n: int) : int
      +square(x: float) : float
      +cube(x: float) : float
    }

    class roots <<module>> {
      +square_root(x: float) : float
      +cube_root(x: float) : float
    }

    class logarithmic <<module>> {
      +log(x: float) : float
      +ln(x: float) : float
    }
  }

  note right of Calculator
    Delegation wrapper — all methods
    forward to the operations subpackage.
    Public API is unchanged.
  end note
}

package "Interaction Layer" {
  class Colors <<constant>> {
    BACKGROUND = #000000
    STANDARD_BUTTON = #333333
    OPERATOR_BUTTON = #FF9500
    UTILITY_BUTTON = #A5A5A5
    TEXT = white
  }

  class Mode <<enum>> {
    NORMAL
    SCIENTIFIC
    +get_normal_operations() : frozenset[str]
    +get_scientific_operations() : frozenset[str]
    +get_operations_for_mode(mode: Mode) : frozenset[str]
  }

  class InputLoop <<module>> {
    +OPERATIONS : dict
    +MAX_RETRY_ATTEMPTS : int
    +print_menu(mode: Mode) : None
    +print_history(history: OperationHistory) : None
    +get_operation(input_fn: Callable, retry_limit: int, mode: Mode) : str | None
    +handle_mode_switch(user_input: str, current_mode: Mode) : Mode | None
    +get_operands(count: int, input_fn: Callable, retry_limit: int) : list[float] | None
    +dispatch(operation: str, operands: list, calc: Calculator) : float
    +run_loop(input_fn: Callable, history: OperationHistory) : None
  }

  class Validation <<module>> {
    +VALID_OPERATIONS : frozenset[str]
    +validate_operation(op: str, mode: Mode | None) : tuple[bool, str]
    +validate_operand(raw: str) : tuple[bool, float, str]
  }

  class Main <<module>> {
    +main(argv: list[str] | None) : None
  }

  class OperandInputWidget {
    -_label : tk.Label
    -_entry : tk.Entry
    +__init__(parent: tk.Widget, label_text: str, row: int) : None
    +get_value() : float
    +clear() : None
    +set_visible(visible: bool) : None
  }

  class CalculatorGUI {
    -_calc : Calculator
    -_history : OperationHistory
    -_error_logger : ErrorLogger
    -_current_mode : Mode
    -_selected_operation : str | None
    -_root : tk.Tk
    -_operation_buttons : list[tk.Button]
    -_operand_widgets : list[OperandInputWidget]
    -_result_var : tk.StringVar
    -_error_var : tk.StringVar
    -_mode_tab_buttons : dict[Mode, tk.Button]
    +__init__() : None
    +run() : None
    -_create_mode_selector_frame() : None
    -_create_operation_selector_frame() : None
    -_create_input_frame() : None
    -_create_result_frame() : None
    -_create_history_frame() : None
    -_on_mode_changed(new_mode: Mode) : None
    -_on_operation_selected(operation: str) : None
    -_perform_calculation() : None
    -_get_button_color(operation_key: str) : str
    -_update_mode_tabs() : None
    -_update_operation_buttons() : None
    -_refresh_history_display() : None
    -_clear_operand_inputs() : None
    -_show_error(message: str) : None
  }

  class CLI <<module>> {
    +run_cli(history: OperationHistory) : None
    -_build_parser() : ArgumentParser
  }

  class OperationHistory {
    -_history : list[str]
    -_file_path : str
    +__init__() : None
    +record_operation(op: str, operands: list, result: float) : None
    +get_history() : list[str]
    +clear() : None
    -_format_entry(op: str, operands: list, result: float) : str
  }

  class ErrorLogger {
    -_history : list[str]
    -_file_path : str
    +__init__(file_path: str) : None
    +log_error(category: str, message: str, context: dict) : None
    +get_errors() : list[str]
    -_format_entry(timestamp: str, category: str, message: str, context: dict) : str
  }

  class ErrorCategories <<enum>> {
    INVALID_INPUT
    UNSUPPORTED_OPERATION
    CALCULATION_ERROR
    UNEXPECTED_ERROR
  }

  note right of CLI
    Uses argparse + sys from stdlib.
    No third-party dependencies.
  end note
}

Calculator --> arithmetic : delegates add/subtract/multiply/divide
Calculator --> exponents : delegates power/factorial/square/cube
Calculator --> roots : delegates square_root/cube_root
Calculator --> logarithmic : delegates log/ln

InputLoop --> Calculator : uses
InputLoop --> Validation : validate_operation / validate_operand
InputLoop --> OperationHistory : creates / records / prints history
InputLoop --> ErrorLogger : creates / logs errors
InputLoop --> Mode : uses for menu / validation / mode-switch
Validation --> Mode : uses for mode-scoped validation
Main --> InputLoop : calls run_loop()
Main --> CLI : calls run_cli()
Main --> CalculatorGUI : creates / calls run() when --gui

CalculatorGUI --> Colors : uses for styling
CalculatorGUI --> Calculator : uses via dispatch()
CalculatorGUI --> OperationHistory : creates / records history
CalculatorGUI --> ErrorLogger : creates / logs errors
CalculatorGUI --> Mode : uses get_operations_for_mode()
CalculatorGUI --> InputLoop : calls dispatch()
CalculatorGUI *-- OperandInputWidget : contains two instances
CLI --> OPERATIONS : reads operand count
CLI --> Calculator : creates instance
CLI --> InputLoop : calls dispatch()
CLI --> OperationHistory : creates / records operation
CLI --> ErrorLogger : creates / logs errors
ErrorLogger --> ErrorCategories : uses

@enduml
