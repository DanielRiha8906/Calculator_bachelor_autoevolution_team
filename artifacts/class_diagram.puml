@startuml class_diagram

class ArithmeticEngine {
    +add(a: int|float, b: int|float) : int|float
    +subtract(a: int|float, b: int|float) : int|float
    +multiply(a: int|float, b: int|float) : int|float
    +divide(a: int|float, b: int|float) : float
    +factorial(n: int) : int
    +square(x: int|float) : int|float
    +cube(x: int|float) : int|float
    +square_root(x: int|float) : float
    +cube_root(x: int|float) : float
    +power(base: int|float, exponent: int|float) : float
    +log10(x: int|float) : float
    +natural_log(x: int|float) : float
    +sin(x: int|float) : float
    +cos(x: int|float) : float
    +tan(x: int|float) : float
    +exp(x: int|float) : float
    +log(x: int|float) : float
    +sqrt(x: int|float) : float
}

class Calculator {
    -_engine: ArithmeticEngine
    -_history: OperationHistory
    -_registry: OperationRegistry
    -_mode: str
    +get_mode() : str
    +set_mode(mode: str) : None
    +get_history() : list
    +clear_history() : None
    +add(a, b) : float
    +subtract(a, b) : float
    +multiply(a, b) : float
    +divide(a, b) : float
    +factorial(n: int) : int
    +square(x: int|float) : int|float
    +cube(x: int|float) : int|float
    +square_root(x: int|float) : float
    +cube_root(x: int|float) : float
    +power(base: int|float, exponent: int|float) : float
    +log10(x: int|float) : float
    +natural_log(x: int|float) : float
    +sin(x: int|float) : float
    +cos(x: int|float) : float
    +tan(x: int|float) : float
    +exp(x: int|float) : float
    +log(x: int|float) : float
    +sqrt(x: int|float) : float
}

class OperationHistory {
    -_records: list[OperationRecord]
    +add_record(operation_name: str, operands: list, result: object, timestamp: datetime) : None
    +get_history() : list[OperationRecord]
    +clear_history() : None
    +__len__() : int
}

class OperationRecord <<dataclass>> {
    +operation_name: str
    +operands: list
    +result: object
    +timestamp: datetime
}

abstract class Operation {
    {abstract} +name() : str
    {abstract} +execute(*args: int|float) : float
    {abstract} +operand_count() : int
}

class OperationRegistry {
    -_operations: dict[str, Operation]
    +register(operation_name: str, op: Operation) : None
    +get(operation_name: str) : Operation|None
    +list_operations() : list[str]
    +is_registered(operation_name: str) : bool
}

