@startuml class_diagram

skinparam classAttributeIconSize 0

class Calculator {
    +add(a, b) : float
    +subtract(a, b) : float
    +multiply(a, b) : float
    +divide(a, b) : float
    +factorial(n) : int
}

note right of Calculator::divide
  Raises ZeroDivisionError
  when b == 0
end note

note right of Calculator::factorial
  Raises TypeError if n is a
  non-integer float (e.g. 5.5).
  Raises ValueError if n < 0.
  Accepts whole-number floats
  (e.g. 5.0) by coercing to int.
end note

class "__main__" as Main {
    +main() : void
}

Main ..> Calculator : instantiates

@enduml
