@startuml class_diagram

package "src" {
    class ErrorLogger {
        +log_error(error_type: str, context: dict) : None
    }

    class CLI <<module>> {
        +parse_arguments(args: list[str]) : tuple[str, list[str]]
        +execute_cli(operation_name: str, operand_strs: list[str], registry: dict, calculator: Calculator) : int
    }
}

package "src.core" {
    class Calculator {
        +add(a, b) : float
        +subtract(a, b) : float
        +multiply(a, b) : float
        +divide(a, b) : float
        +square(x: int|float) : int|float
        +square_root(x: int|float) : float
        +cube(x: int|float) : int|float
        +cube_root(x: int|float) : float
        +power(base: int|float, exponent: int|float) : int|float
        +factorial(n: int) : int
        +log(x: int|float) : float
        +ln(x: int|float) : float
        +sin(x: float) : float
        +cos(x: float) : float
        +tan(x: float) : float
        +cot(x: float) : float
        +asin(x: float) : float
        +acos(x: float) : float
    }

    class OperationRegistry {
        -_calculator : Calculator
        -_normal_operations : dict[str, tuple]
        -_scientific_operations : dict[str, tuple]
        +__init__(calculator: Calculator)
        -_load_normal_operations() : None
        -_load_scientific_operations() : None
        -_register_normal_op(name: str, method: object, arity: int) : None
        -_register_scientific_op(name: str, method: object, arity: int) : None
        +get_all_operations() : dict[str, tuple]
        +get_normal_operations() : dict[str, tuple]
        +get_scientific_operations() : dict[str, tuple]
    }

    class Operations <<module>> {
        +get_operation_registry(calculator: Calculator) : dict[str, tuple]
    }
}

package "src.interface" {
    class InputParser <<module>> {
        +parse_cli_args(args: list[str]) : tuple[str, list[str]]
        +convert_operand(value: str) : int | float
    }

    class OutputFormatter <<module>> {
        +format_result(result: int|float) : str
    }

    class MenuRenderer <<module>> {
        +display_menu(registry: dict, current_mode: str = "normal") : None
    }
}

package "src.interactive" {
    class Session <<module>> {
        MAX_VALIDATION_ATTEMPTS : int = 5
        _HISTORY_TOKEN : str = "h"
        _MODE_SWITCH_TOKEN : str = "m"
        +get_mode_selection() : str
        +get_operation_choice(registry: dict) : tuple | None
        +get_operation_choice_with_mode_option(registry: dict) : tuple | str | None
        +get_operands(arity: int) : list[float] | None
        +run_interactive_session(calculator: Calculator, history_tracker: HistoryTracker) : None
    }
}

package "src.support" {
    class HistoryTracker {
        -_history : list[str]
        +record(operation_name: str, operands: list, result: object) : None
        +get_history() : list[str]
        +display() : None
        +save_to_file(filepath: str) : None
        +clear() : None
    }
}

package "src.gui" {
    abstract class CalcMode {
        {abstract} +name : str
        {abstract} +get_operations() : dict[str, tuple]
    }

    class SimpleMode {
        -_registry : OperationRegistry
        +__init__(calculator: Calculator)
        +name : str
        +get_operations() : dict[str, tuple]
    }

    class ScientificMode {
        -_registry : OperationRegistry
        +__init__(calculator: Calculator)
        +name : str
        +get_operations() : dict[str, tuple]
    }

    class CalculatorGUI {
        -_root : tk.Tk
        -_calculator : Calculator
        -_mode : CalcMode
        -_history_tracker : HistoryTracker
        -_display_var : tk.StringVar
        -_display : tk.Label
        -_history_listbox : tk.Listbox
        -_current_input : str
        -_first_operand : float | None
        -_pending_op : tuple | None
        -_pending_op_name : str | None
        +__init__(root, calculator, mode, history_tracker)
        -_build_ui() : None
        -_build_display(parent) : None
        -_build_mode_toggle(parent) : None
        -_build_button_grid(parent) : None
        -_bind_hover(btn, default_bg, hover_bg) : None
        -_build_history_panel(parent) : None
        -_toggle_mode() : None
        -_on_digit(digit: str) : None
        -_on_decimal() : None
        -_on_clear() : None
        -_on_operation(op_name, op_callable, arity) : None
        -_on_equals() : None
        -_execute_unary(op_name, op_callable, value) : None
        -_parse_current_input() : float | None
        -{static} _format_result(result) : str
        -_refresh_history() : None
        -_switch_to_simple() : None
        -_switch_to_scientific() : None
        -_reset_transient_state() : None
    }

    SimpleMode --|> CalcMode
    ScientificMode --|> CalcMode
    CalculatorGUI o-- CalcMode
}

package "__main__" {
    class EntryPoint <<module>> {
    }
}

package "gui_main" {
    class GUIEntryPoint <<module>> {
        +main() : None
    }
}

Operations ..> OperationRegistry : instantiates
OperationRegistry o-- Calculator : delegates to

EntryPoint ..> Calculator : instantiates
EntryPoint ..> HistoryTracker : instantiates
EntryPoint ..> Session : calls run_interactive_session()

Session ..> Calculator : invokes methods via registry
Session ..> HistoryTracker : records results / displays / saves
Session ..> OperationRegistry : get_normal_operations() / get_scientific_operations()
Session ..> ErrorLogger : logs errors
Session ..> MenuRenderer : calls display_menu()

CLI ..> Calculator : invokes methods via registry
CLI ..> Operations : calls get_operation_registry()
CLI ..> ErrorLogger : logs errors
CLI ..> InputParser : calls parse_cli_args() / convert_operand()

GUIEntryPoint ..> Calculator : instantiates
GUIEntryPoint ..> HistoryTracker : instantiates
GUIEntryPoint ..> SimpleMode : instantiates
GUIEntryPoint ..> CalculatorGUI : instantiates

SimpleMode ..> OperationRegistry : uses get_normal_operations()
ScientificMode ..> OperationRegistry : uses get_scientific_operations()
CalculatorGUI ..> Calculator : invokes methods via mode operations
CalculatorGUI ..> HistoryTracker : records results / refreshes panel

note right of Calculator::factorial
  Raises TypeError if n is not int.
  Raises ValueError if n < 0.
end note

note right of Calculator::square_root
  Raises TypeError if x is not numeric.
  Raises ValueError if x < 0.
end note

note right of Calculator::cube_root
  Supports negative inputs via sign handling.
  Raises TypeError if x is not numeric.
end note

note right of Calculator::power
  Raises ValueError if base < 0 and
  exponent is non-integer (complex result).
end note

note right of Calculator::log
  Base-10 logarithm (log10).
  Raises ValueError if x <= 0.
end note

note right of Calculator::ln
  Natural logarithm (ln).
  Raises ValueError if x <= 0.
end note

note right of Calculator::cot
  Defined as 1/tan(x).
  Raises ValueError if tan(x) == 0.
end note

note right of Calculator::asin
  Domain [-1, 1]. Returns radians in [-π/2, π/2].
  Raises ValueError if x outside domain.
end note

note right of Calculator::acos
  Domain [-1, 1]. Returns radians in [0, π].
  Raises ValueError if x outside domain.
end note

note right of OperationRegistry
  Normal mode (6 ops): add, subtract, multiply,
  divide, square, square_root.
  Scientific mode (18 ops): normal ops + power,
  cube, cube_root, factorial, log, ln, sin, cos,
  tan, cot, asin, acos.
  get_all_operations() returns all 18 (backward compat).
end note

note right of Operations
  Delegates to OperationRegistry.get_all_operations().
  Return format: dict[name -> (method, arity)].
end note

note right of HistoryTracker::record
  Stores entry as "operation(args) = result".
end note

note right of HistoryTracker::save_to_file
  Defaults to "history.txt".
  OSError is caught and printed to stderr.
end note

note right of Session::get_mode_selection
  Returns "normal" or "scientific".
  Defaults to "normal" after MAX_VALIDATION_ATTEMPTS.
end note

note right of Session::get_operation_choice_with_mode_option
  Returns (_MODE_SWITCH_TOKEN, None, None) on "m".
  Returns None on quit (q/quit/exit).
  Returns (_HISTORY_TOKEN, None, None) on "h".
  Returns (None, None, None) when MAX_VALIDATION_ATTEMPTS exceeded.
  Otherwise returns (name, method, arity) 3-tuple.
end note

note right of Session::get_operands
  Returns None when MAX_VALIDATION_ATTEMPTS exceeded.
end note

note right of Session::run_interactive_session
  Prompts for mode (normal/scientific) at session start.
  User can switch modes mid-session via "m" input.
  history_tracker defaults to a new HistoryTracker() if None.
  Calls history_tracker.display() on "h" input.
  Records each successful operation via history_tracker.record().
  Saves history to file on session exit.
  Catches TypeError, ValueError, ZeroDivisionError per iteration.
end note

note right of MenuRenderer::display_menu
  Shows current mode label (Normal / Scientific).
  Lists numbered operations for active registry.
  Always appends h (history), m (switch mode), q (quit).
end note

note right of CLI::execute_cli
  Returns 0 on success, 1 on error.
  Catches TypeError, ValueError,
  ZeroDivisionError.
end note

note right of InputParser::convert_operand
  Parses string to int or float.
  Returns int if value is whole (3.0 -> 3).
end note

note right of ErrorLogger::log_error
  Writes to error.log in ISO 8601 format.
  Format: TIMESTAMP | ERROR_TYPE | OPERATION | OPERANDS | MESSAGE
  Error types: UNSUPPORTED_OPERATION, INVALID_OPERAND,
  ARGUMENT_COUNT_MISMATCH, DIVISION_BY_ZERO, INVALID_DOMAIN.
  Module-level singleton logger; silently swallows I/O errors.
end note

note right of CalcMode
  Abstract base class (ABC).
  Concrete modes supply name and get_operations().
end note

note right of SimpleMode
  Wraps OperationRegistry.get_normal_operations().
  Exposes: add, subtract, multiply, divide,
  square, square_root (6 ops).
end note

note right of ScientificMode
  Wraps OperationRegistry.get_scientific_operations().
  Exposes all 18 ops (normal + scientific).
end note

note right of CalculatorGUI
  iOS-style Tkinter GUI; no arithmetic performed here.
  Display is a tk.Label backed by _display_var (tk.StringVar).
  Single mode-toggle button: label shows the mode to switch TO.
  _toggle_mode() calls _switch_to_simple() or _switch_to_scientific().
  _bind_hover() simulates CSS hover via tkinter Enter/Leave events.
  _build_button_grid() renders digits + ops in a unified 4-column grid.
  Binary ops queue first_operand + pending_op until "=" is pressed.
  Unary ops execute immediately on current_input.
  Mode switch rebuilds entire widget tree (_build_ui).
  history_tracker is shared across mode switches.
  factorial auto-converts whole-float operands to int.
end note

note right of GUIEntryPoint
  Launches tkinter mainloop.
  Default mode is SimpleMode.
  Run via: python -m src.gui_main
end note

@enduml
