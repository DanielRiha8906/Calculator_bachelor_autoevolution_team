@startuml activity_advanced_math

title Advanced Math Methods — Validation and Computation Flows

|square_root|
start
:Receive x;
if (x < 0?) then (yes)
    :Raise ValueError;
    stop
else (no)
    :return math.sqrt(x);
    stop
endif

|cube_root|
start
:Receive x;
note right
  Accepts all real numbers.
  No domain restriction.
end note
:abs_cbrt = abs(x) ** (1/3);
:return math.copysign(abs_cbrt, x);
note right
  Sign of x is preserved
  via math.copysign.
end note
stop

|natural_log|
start
:Receive x;
if (x <= 0?) then (yes)
    :Raise ValueError;
    stop
else (no)
    :return math.log(x);
    stop
endif

|log_base_10|
start
:Receive x;
if (x <= 0?) then (yes)
    :Raise ValueError;
    stop
else (no)
    :return math.log10(x);
    stop
endif

@enduml
