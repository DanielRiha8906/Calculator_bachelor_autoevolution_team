@startuml gui_classes
title GUI Package — iOS-Inspired Redesign — Class Diagram

skinparam classAttributeIconSize 0

package "calculator.gui.window" {

  class GUIWindow {
    {static} COLOR_BG: str = "#000000"
    {static} COLOR_DIGIT: str = "#333333"
    {static} COLOR_OP: str = "#FF9500"
    {static} COLOR_UTIL: str = "#A5A5A5"
    {static} COLOR_TEXT: str = "#FFFFFF"
    --
    + root: tk.Tk
    - _controller: GUIController
    - _buttons: dict[str, _ButtonConfig]
    - _display_var: tk.StringVar
    - _display: tk.Label
    - _operand1: str
    - _pending_op: str | None
    - _awaiting_second: bool
    - _scientific_frame: tk.Frame | None
    - _scientific_panel_visible: bool
    --
    + __init__(controller: GUIController, title: str = "Calculator")
    + run(): None
    - _build_display(): None
    - _build_standard_grid(): None
    - _build_scientific_panel(): None
    - _rebuild_scientific_panel(): None
    - _make_button(frame, text, bg, row, col, colspan, command): _ButtonConfig
    - _make_command(text: str): Callable
    - _make_scientific_command(op_name: str): Callable
    - _on_digit(digit: str): None
    - _on_operator(op_name: str): None
    - _on_equals(): None
    - _on_clear(): None
    - _on_delete(): None
    - _on_mode_toggle(): None
    - _on_scientific_op(op_name: str): None
  }

  class _ButtonConfig {
    - _widget: object
    - _bg: str
    - _fg: str
    - _relief: str
    - _row: int
    - _column: int
    - _columnspan: int
    --
    + __init__(widget, bg, fg, relief, row, column, columnspan)
    + cget(key: str): str | None
    + grid_info(): dict
  }
}

package "calculator.gui" {
  class GUIController {
    - _current_mode: str
    - _active_registry: OperationRegistry
    - _session_history: list[dict]
    --
    + __init__(mode: str)
    + get_current_mode(): str
    + switch_mode(mode: str): None
    + get_available_operations(): list[str]
    + get_operation_arity(operation_name: str): int
    + execute_operation(operation_name: str, operands: list): dict
    + get_session_history(): list[dict]
    + clear_session_history(): None
  }
}

package "calculator.operations" {
  class OperationRegistry {
    - _ops: dict[str, Operation]
    --
    + register(operation: Operation, name: str | None): None
    + get(name: str): Operation
    + list_all(): list[str]
    + has(name: str): bool
  }

  interface Operation <<interface>> {
    {abstract} + name: str
    {abstract} + arity: int
    {abstract} + execute(*args: float): float
  }
}

' Relationships
GUIWindow "1" *-- "1" GUIController : composes >
GUIWindow "1" *-- "*" _ButtonConfig : owns via _buttons >
GUIController "1" --> "1" OperationRegistry : uses >
OperationRegistry "1" o-- "*" Operation : contains >

@enduml
