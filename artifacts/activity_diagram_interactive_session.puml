@startuml activity_diagram_interactive_session

start

:Create Calculator instance;
:detect_mode() -> mode;
:get_operation_menu(calc) -> operations;
:Create OperationHistory();

repeat

    :Create OperationValidationSession\n(mode, operations, max_retries=5);
    :reset_counter();

    repeat
        :Prompt "Select operation (number or name): ";
        :Read raw_choice;

        if (raw_choice in {quit, exit, q}?) then (yes)
            :history.save_to_file("history.txt");
            :Print "Goodbye!";
            stop
        else (no)
        endif

        if (raw_choice in {history, h}?) then (yes)
            :history.get_history() -> entries;
            if (entries is empty?) then (yes)
                :Print "No history yet.";
            else (no)
                :Print each entry;
            endif
            :continue;
        else (no)
        endif

        if (raw_choice is valid operation?) then (yes)
            :op_name = selected operation;
        else (no — invalid)
            :format_operation_error(operations);
            :Print formatted error;
            :attempt_count += 1;
            if (attempt_count >= max_retries?) then (yes)
                :Print "Maximum retry attempts exceeded";
                :history.save_to_file("history.txt");
                stop
            else (no)
            endif
        endif
    repeat while (valid op obtained?) is (no)
    -> yes;

    :get_arity(calc, op_name) -> arity;

    :get_operands(arity, mode) -> operands;

    partition "get_operands() — per operand" {
        :Create OperandValidationSession\n(mode, max_retries=5);

        fork
            :<color:green>interactive mode</color>;
            repeat
                :Prompt "Enter operand {i}: ";
                :Read raw input;
                if (parse_float(raw) succeeds?) then (yes)
                    :Append float to operands;
                else (no — ValueError)
                    :Print error message;
                    :attempt_count += 1;
                    if (attempt_count >= max_retries?) then (yes)
                        :Print "Maximum retry attempts exceeded";
                        :history.save_to_file("history.txt");
                        :Return None;
                        detach
                    else (no)
                    endif
                endif
            repeat while (valid float obtained?) is (no)
            -> yes;
        fork again
            :<color:blue>cli mode</color>;
            :Single attempt — parse_float(raw);
            if (parse_float succeeds?) then (yes)
                :Append float to operands;
            else (no)
                :Print error and exit(1);
                stop
            endif
        end fork
    }

    if (operands is None?) then (yes)
        :history.save_to_file("history.txt");
        stop
    else (no)
    endif

    :result = getattr(calc, op_name)(*operands);
    :history.record_operation(op_name, operands, result);

    if (Calculator raises exception?) then (yes)
        :Print "Error: {exc}";
    else (no)
        :Print "Result: {result}";
    endif

    :get_operation_menu(calc) -> operations;

repeat while (user continues?) is (yes — loop back to menu)

stop

@enduml
