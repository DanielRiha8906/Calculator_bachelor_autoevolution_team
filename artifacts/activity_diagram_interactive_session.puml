@startuml activity_diagram_interactive_session

skinparam ActivityBorderColor #555
skinparam ActivityBackgroundColor #f9f9f9
skinparam ArrowColor #333

|cli.interactive_session|
start

:detect_mode() -> mode;
:CalculatorSession(calculator) -> session;
:session.get_operation_list() -> operations;
:OperationValidationSession(mode, operations) -> op_session;

repeat

  :format_menu_header(operations);
  :format_quit_instruction();
  :input("Select operation...") -> raw_choice;

  if (raw_choice in {quit, exit, q}?) then (yes)
    :session.save_history("history.txt");
    stop
  endif

  if (raw_choice in {history, h}?) then (yes)
    :session.get_history() -> entries;
    if (entries empty?) then (yes)
      :print "No history yet.";
    else (no)
      :format_history_header();
      :print each entry;
    endif
    note right: continues loop
  else (no)

    |CalculatorSession|
    :select_operation(raw_choice, mode) -> (op_name, exit_code);

    |cli.interactive_session|
    if (exit_code == 2 — index out of range?) then (yes)
      :print range error;
      :retry_count += 1;
      if (retry_count >= max_retries?) then (yes)
        :session.save_history("history.txt");
        stop
      endif
    elseif (op_name is None — unrecognized?) then (yes)
      :print invalid selection error;
      :retry_count += 1;
      if (retry_count >= max_retries?) then (yes)
        :session.save_history("history.txt");
        stop
      endif
    else (resolved)
      :retry_count = 0;

      |CalculatorSession|
      :get_arity(op_name) -> arity;
      :collect_operands(arity, mode) -> (operands, exit_code);
      note right
        Creates OperandValidationSession internally.
        interactive: retry up to 5 times per operand.
        cli: SystemExit on first invalid input.
      end note

      |cli.interactive_session|
      if (operands is None — retry limit exceeded?) then (yes)
        :session.save_history("history.txt");
        stop
      endif

      |CalculatorSession|
      :execute_operation(op_name, operands) -> (result, error_msg);
      note right
        Calls Calculator.<op_name>(*operands).
        Catches ZeroDivisionError -> log_division_by_zero.
        Catches ValueError -> log_invalid_domain.
      end note

      |cli.interactive_session|
      if (error_msg is not None?) then (yes)
        :format_error(error_msg);
        :print error;
      else (no)
        :session.record_history(op_name, operands, result);
        :format_result(op_name, operands, result);
        :print result;
      endif

    endif

  endif

repeat while (session continues?) is (yes)

stop

@enduml
