@startuml activity_diagram_interactive_session

start

:Instantiate OperationHistory;
:history.clear();
:Instantiate Calculator;
:Instantiate InputHandler(history);
:Instantiate OperationRegistry(calculator);
:Instantiate ModeManager();
note right: _current_mode = CalculatorMode.NORMAL

:Print welcome message;

repeat

  :available = registry.get_available_operations(mode_manager);
  note right: Filters ops by current mode
  :current_mode_name = mode_manager.get_mode_display_name();

  :choice = handler.get_operation_choice(available, current_mode=current_mode_name);
  note right: Displays mode header and filtered op list

  if (InputRetryExhaustedError?) then (yes)
    stop
  endif

  if (choice == "exit" or "quit"?) then (yes)
    :Print "Goodbye!";
    stop
  endif

  if (choice == "mode"?) then (yes)
    :mode_manager.switch_mode();
    :Print "Switched to {new_mode} mode.";
  else (no)
    :method, arity, description = registry.get_operation(choice);

    if (arity == 1?) then (yes)
      :value = handler.get_operand("Enter value: ");
      if (choice == "factorial"?) then (yes)
        :value = int(value);
      endif
      :operands = [value];
    else (no)
      :operands = [get_operand("first"), get_operand("second")];
    endif

    :result = method(*operands);
    :handler.display_result(description, operands, result);
    :history.record_operation(choice, operands, result);

    note right
      ValueError / ZeroDivisionError / KeyError
      caught and displayed via display_error()
    end note
  endif

  backward: next iteration
  repeat while (KeyboardInterrupt?) is (no)
->yes;

:Print "Goodbye!";
stop

@enduml
