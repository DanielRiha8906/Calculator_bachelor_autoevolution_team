@startuml class_diagram_gui

skinparam classAttributeIconSize 0
skinparam classFontStyle bold

' --- External base class ---
class "tk.Tk" as TkTk <<external>>

' --- Error types ---
class ValueError <<stdlib>>
class OperationNotAvailableInModeError {
  + operation: str
  + current_mode: str
  + available_modes: list[str]
}
ValueError <|-- OperationNotAvailableInModeError

' --- Operation sets (abstract base + concrete) ---
abstract class BaseOperationSet {
  + {abstract} get_operations(): dict
  # _record(result)
}

class BasicOperations {
  + add(a, b)
  + subtract(a, b)
  + multiply(a, b)
  + divide(a, b)
  + get_operations(): dict
}

class AdvancedOperations {
  + factorial(n)
  + square(x)
  + cube(x)
  + square_root(x)
  + cube_root(x)
  + power(base, exp)
  + natural_log(x)
  + log_base_10(x)
  + get_operations(): dict
}

class ScientificOperations {
  + sin(x) / cos(x) / tan(x)
  + asin(x) / acos(x) / atan(x)
  + sinh(x) / cosh(x) / tanh(x)
  + degrees(x) / radians(x)
  + exp(x) / ln(x)
  + get_operations(): dict
}

BaseOperationSet <|-- BasicOperations
BaseOperationSet <|-- AdvancedOperations
BaseOperationSet <|-- ScientificOperations

' --- Core computation engine ---
class CalculatorEngine {
  - _history: list
  - _mode: str
  - _basic: BasicOperations
  - _advanced: AdvancedOperations
  - _scientific: ScientificOperations
  --
  + set_mode(mode)
  + get_history()
  + add(a, b) / subtract(a, b)
  + multiply(a, b) / divide(a, b)
  + square_root(x) / sin(x) / cos(x)
}

CalculatorEngine *-- BasicOperations
CalculatorEngine *-- AdvancedOperations
CalculatorEngine *-- ScientificOperations

' --- Calculator facade ---
class Calculator {
  --
  + set_mode(mode)
  + get_available_modes_for_operation(op)
  + get_history()
  + (delegates all operations to CalculatorEngine)
}
Calculator *-- CalculatorEngine

' --- Input processing ---
class ExpressionParser {
  + parse(raw_input: str): tuple[str, list]
}

class InputValidator {
  + validate(operation, operands)
  + validate_operation(operation)
  + validate_operand_count(operation, operands)
}

class RetryConfig {
  + max_retries: int
}

' --- GUI entry point ---
class CalculatorGUI {
  - _calculator: Calculator
  - _parser: ExpressionParser
  - _validator: InputValidator
  - _expression: str
  - _display_var: tk.StringVar
  - _mode_var: tk.StringVar
  - _button_widgets: dict[str, tk.Button]
  --
  - _build_ui()
  - _on_button(label)
  - _on_mode_change(mode)
  - _evaluate()
  - _append(text) / _append_operator(op) / _append_function(label)
  - _clear() / _backspace()
  - _set_display(text) / _show_error(msg)
  - _rebuild_button_grid_for_mode(mode)
}
TkTk <|-- CalculatorGUI
CalculatorGUI *-- Calculator
CalculatorGUI *-- ExpressionParser
CalculatorGUI *-- InputValidator

' --- REPL entry point ---
class CalculatorREPL {
  - _calculator: Calculator
  - _parser: ExpressionParser
  - _validator: InputValidator
  - _retry_config: RetryConfig
  --
  + run()
}
CalculatorREPL *-- Calculator
CalculatorREPL *-- ExpressionParser
CalculatorREPL *-- InputValidator
CalculatorREPL *-- RetryConfig

note bottom of CalculatorGUI
  Launched via: main.py --gui / -g
end note

note bottom of CalculatorREPL
  Launched via: main.py (default REPL)
end note

@enduml
