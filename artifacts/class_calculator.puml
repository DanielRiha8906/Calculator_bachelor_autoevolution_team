@startuml class_calculator

skinparam classAttributeIconSize 0

class Calculator {
    .. Binary Arithmetic ..
    + add(a: int|float, b: int|float) : int|float
    + subtract(a: int|float, b: int|float) : int|float
    + multiply(a: int|float, b: int|float) : int|float
    + divide(a: int|float, b: int|float) : float
    .. Unary Algebraic ..
    + square(x: int|float) : int|float
    + cube(x: int|float) : int|float
    + square_root(x: int|float) : float
    + cube_root(x: int|float) : float
    .. Binary Power ..
    + power(base: int|float, exponent: int|float) : int|float
    .. Unary Logarithm ..
    + log10(x: int|float) : float
    + ln(x: int|float) : float
    .. Unary Special ..
    + factorial(n: int) : int
}

note right of Calculator::divide
  raises ZeroDivisionError
  when b == 0
end note

note right of Calculator::square_root
  raises ValueError
  if x < 0
end note

note right of Calculator::power
  raises ValueError if base < 0
  and exponent is not integer
end note

note right of Calculator::log10
  raises ValueError
  if x <= 0
end note

note right of Calculator::ln
  raises ValueError
  if x <= 0
end note

note right of Calculator::factorial
  strict type + sign validation;
  raises ValueError for non-int,
  bool, float, str, None, or n < 0;
  delegates to math.factorial(n)
end note

package "Python stdlib" {
    class math <<module>> {
        + factorial(n: int) : int
        + sqrt(x: float) : float
        + log10(x: float) : float
        + log(x: float) : float
    }
}

Calculator --> math : uses factorial(), sqrt(), log10(), log()

@enduml
