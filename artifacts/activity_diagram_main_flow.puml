@startuml activity_diagram_main_flow

skinparam activityFontSize 13
skinparam diamondFontSize 12

start

:python -m src invoked;

if (len(sys.argv) > 1?) then (yes — batch mode)

  if (argv[1:] == ['history']?) then (yes)
    :load and display history.txt;
    stop
  else (no)
    :parse_batch_args();
    :execute_batch(calc, args);
    if (operation succeeded?) then (yes)
      :print result to stdout;
      :exit(0);
    else (no)
      :print error to stderr;
      :exit(1);
    endif
    stop
  endif

else (no — interactive mode)

  :Create Calculator instance;
  :mode = "normal";

  while (running?) is (yes)
    :run_calculator(calc, mode);

    if (result == "QUIT"?) then (yes)
      break
    elseif (result == "MODE_TOGGLE"?) then (yes)
      if (mode == "normal"?) then (yes)
        :calc.enable_scientific_mode();
        :mode = "scientific";
      else (no)
        :calc.disable_scientific_mode();
        :mode = "normal";
      endif
      :display_mode_change(mode);
    else (no)
      if (MaxRetriesExceeded raised?) then (yes)
        :display error message;
        break
      else (no)
        :continue — accumulate history;
      endif
    endif
  endwhile

  fork
    :persist_history_to_file(calc);
  fork again
    note right: Ctrl+C also triggers\npersist before exit
  end fork

  stop

endif

note left
  Dual state sync:
  - mode: str (local, controls UI)
  - calc._scientific_mode: bool (internal)
  Both updated together on MODE_TOGGLE.
end note

@enduml
