@startuml component_calculator

package "Calculator Application" {
    [Calculator] as Calc
    note right of Calc
      Exposes arithmetic (add, subtract, multiply, divide),
      power operations (square, cube, square_root, cube_root, power),
      logarithmic (log10, ln), and special (factorial) operations
    end note
}

package "Python Standard Library" {
    [math] as Math
}

Calc --> Math : uses factorial(), sqrt(), log10(), log()

@enduml
