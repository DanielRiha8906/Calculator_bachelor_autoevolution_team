@startuml class_diagram_calculator

skinparam classAttributeIconSize 0
skinparam classFontStyle bold

class Calculator {
    + add(a, b) : numeric
    + subtract(a, b) : numeric
    + multiply(a, b) : numeric
    + divide(a, b) : float
}

class "calculator" <<fixture>> {
    Creates a Calculator instance per test.
    Injected into every test method.
}

class TestDivision {
    + test_divide_positive_numbers(calculator)
    + test_divide_with_floats(calculator)
    + test_divide_negative_numbers(calculator)
    + test_divide_by_zero_raises_exception(calculator)
    + test_divide_zero_by_nonzero(calculator)
    + test_divide_non_numeric_inputs_raise_typeerror(calculator, invalid_a, invalid_b) <<parametrized: 6 cases>>
    + test_divide_result_precision(calculator)
    + test_divide_large_numbers(calculator)
    + test_divide_very_small_numbers(calculator)
}

class TestAddition {
    + test_add_various_numbers(calculator, a, b, expected) <<parametrized: 11 cases>>
    + test_add_non_numeric_inputs_raise_typeerror(calculator, invalid_a, invalid_b) <<parametrized: 8 cases>>
}

class TestSubtraction {
    + test_subtract_various_numbers(calculator, a, b, expected) <<parametrized: 12 cases>>
    + test_subtract_non_numeric_inputs_raise_typeerror(calculator, invalid_a, invalid_b) <<parametrized: 8 cases>>
}

class TestMultiplication {
    + test_multiply_various_numbers(calculator, a, b, expected) <<parametrized: 11 cases>>
    + test_multiply_non_numeric_inputs_raise_typeerror(calculator, invalid_a, invalid_b) <<parametrized: 4 cases>>
    + test_multiply_with_strings_and_lists(calculator, a, b, expected) <<parametrized: 2 cases>>
}

TestDivision ..> Calculator : depends on
TestAddition ..> Calculator : depends on
TestSubtraction ..> Calculator : depends on
TestMultiplication ..> Calculator : depends on

TestDivision ..> "calculator" : uses
TestAddition ..> "calculator" : uses
TestSubtraction ..> "calculator" : uses
TestMultiplication ..> "calculator" : uses

note bottom of TestDivision
  pytest test classes.
  All methods receive a Calculator
  instance via the calculator() fixture.
end note

note bottom of TestAddition
  pytest test classes.
  All methods receive a Calculator
  instance via the calculator() fixture.
end note

note bottom of TestSubtraction
  pytest test classes.
  All methods receive a Calculator
  instance via the calculator() fixture.
end note

note bottom of TestMultiplication
  pytest test classes.
  All methods receive a Calculator
  instance via the calculator() fixture.
end note

@enduml
