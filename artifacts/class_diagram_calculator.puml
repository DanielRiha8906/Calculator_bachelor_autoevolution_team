@startuml class_diagram_calculator

skinparam classAttributeIconSize 0

class Calculator {
    ' Binary Operations (arity 2)
    + add(a: float, b: float) : float
    + subtract(a: float, b: float) : float
    + multiply(a: float, b: float) : float
    + divide(a: float, b: float) : float
    + power(base: float, exp: float) : float

    ' Unary Operations (arity 1)
    + square(a: float) : float
    + cube(a: float) : float
    + square_root(a: float) : float
    + cube_root(a: float) : float
    + factorial(n: float|int) : int
    + log(a: float) : float
    + ln(a: float) : float
}

note top of Calculator
  Stateless class — no instance variables
  Binary (arity 2): add, subtract, multiply, divide, power
  Unary  (arity 1): square, cube, square_root, cube_root, factorial, log, ln
end note

note right of Calculator::divide
  Raises ZeroDivisionError
  when b == 0
end note

note right of Calculator::square_root
  Raises ValueError
  when a < 0
end note

note right of Calculator::factorial
  Raises ValueError when:
  - n is a boolean
  - n is fractional
  - n < 0
end note

note right of Calculator::log
  Base-10 logarithm
  Raises ValueError when a <= 0
end note

note right of Calculator::ln
  Natural logarithm
  Raises ValueError when a <= 0
end note

package "math" <<stdlib>> {
}

Calculator ..> math : uses\nsqrt, factorial,\nlog10, log

@enduml
