@startuml class_diagram_calculator

skinparam classAttributeIconSize 0

class Calculator {
    ' Binary Operations
    + add(a, b) : numeric
    + subtract(a, b) : numeric
    + multiply(a, b) : numeric
    + divide(a, b) : numeric
    + power(base, exp) : numeric

    ' Unary Operations
    + square(a) : numeric
    + cube(a) : numeric
    + square_root(a) : float
    + cube_root(a) : float
    + factorial(n) : int
    + log(a) : float
    + ln(a) : float
}

note right of Calculator::divide
  Raises ZeroDivisionError
  when b == 0
end note

note right of Calculator::square_root
  Raises ValueError
  when a < 0
end note

note right of Calculator::cube_root
  Handles negatives:
  -(abs(a) ^ (1/3))
end note

note right of Calculator::factorial
  Raises ValueError when:
  - n is a boolean
  - n is non-integer
  - n < 0
end note

note right of Calculator::log
  Base-10 logarithm
  Raises ValueError when a <= 0
end note

note right of Calculator::ln
  Natural logarithm
  Raises ValueError when a <= 0
end note

package "math" <<module>> {
}

Calculator ..> math : uses\nsqrt, factorial,\nlog10, log

@enduml
