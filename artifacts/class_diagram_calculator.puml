@startuml class_diagram_calculator

skinparam classAttributeIconSize 0

class Calculator {
    ' Binary Operations (arity 2)
    + add(a, b) : numeric
    + subtract(a, b) : numeric
    + multiply(a, b) : numeric
    + divide(a, b) : numeric
    + power(base, exp) : numeric

    ' Unary Operations (arity 1)
    + square(a) : numeric
    + cube(a) : numeric
    + square_root(a) : float
    + cube_root(a) : float
    + factorial(n) : int
    + log(a) : float
    + ln(a) : float
}

note top of Calculator
  Stateless class — all pure methods
  Binary (arity 2): add, subtract, multiply, divide, power
  Unary  (arity 1): square, cube, square_root, cube_root, factorial, log, ln
end note

note right of Calculator::divide
  Raises ZeroDivisionError
  when b == 0
end note

note right of Calculator::square_root
  Raises ValueError
  when a < 0
end note

note right of Calculator::factorial
  Raises ValueError when:
  - n is a boolean
  - n is non-integer
  - n < 0
end note

note right of Calculator::log
  Base-10 logarithm
  Raises ValueError when a <= 0
end note

note right of Calculator::ln
  Natural logarithm
  Raises ValueError when a <= 0
end note

package "math" <<stdlib>> {
}

Calculator ..> math : uses\nsqrt, factorial,\nlog10, log

@enduml
