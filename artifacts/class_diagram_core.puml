@startuml class_diagram_core

skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam packageFontSize 11

class Calculator {
  - _history : list[dict]
  - _scientific_mode : bool
  --
  + __init__() : None
  .. History ..
  + get_history() : list[dict]
  + clear_history() : None
  - _record_operation(name, operands, result)
  .. Binary Ops ..
  + add(a, b)
  + subtract(a, b)
  + multiply(a, b)
  + divide(a, b)
  + power(base, exp)
  .. Unary Ops ..
  + square(x)
  + cube(x)
  + square_root(x)
  + cube_root(x)
  + factorial(n)
  + log(x)
  + ln(x)
  .. Scientific Ops ..
  + sin(x) / cos(x) / tan(x)
  + asin(x) / acos(x) / atan(x)
  + sinh(x) / cosh(x) / tanh(x)
  + exp(x) / get_pi() / get_e()
  .. Mode Management ..
  + enable_scientific_mode()
  + disable_scientific_mode()
  + toggle_scientific_mode()
  + is_scientific_mode() : bool
}

class "«module»\nbasic_operations" as basic_ops {
  + add(a, b)
  + subtract(a, b)
  + multiply(a, b)
  + divide(a, b)
}

class "«module»\nadvanced_operations" as advanced_ops {
  + square(x)
  + cube(x)
  + square_root(x)
  + cube_root(x)
  + factorial(n)
  + power(base, exp)
  + log(x)
  + ln(x)
}

class "«module»\nscientific_operations" as sci_ops {
  .. Trigonometric ..
  + sin(x) / cos(x) / tan(x)
  + asin(x) / acos(x) / atan(x)
  .. Hyperbolic ..
  + sinh(x) / cosh(x) / tanh(x)
  .. Other ..
  + exp(x)
  + pi() : float
  + e() : float
  note "asin/acos raise ValueError\nif x not in [-1, 1]"
}

class "«module»\ninterface" as interface_mod {
  + OPERATIONS : dict
  + SCIENTIFIC_OPERATIONS : dict
  --
  + prompt_for_operator(mode: str) : str
  + prompt_for_first_number() : float
  + prompt_for_second_number() : float
  + display_result(result) : None
  + display_error(msg) : None
  + display_history(calc) : None
  + display_mode_change(new_mode: str) : None
  + run_calculator(calc, mode: str) : str
  + persist_history_to_file(calc) : None
}

class "«exception»\nMaxRetriesExceeded" as max_retries_exc {
}

class "«facade»\ncli" as cli_facade {
  note "re-exports all\nfrom interface"
}

Calculator --> basic_ops : delegates arithmetic
Calculator --> advanced_ops : delegates math
Calculator --> sci_ops : delegates scientific

interface_mod --> Calculator : uses
interface_mod +-- max_retries_exc

cli_facade ..> interface_mod : re-export

@enduml
