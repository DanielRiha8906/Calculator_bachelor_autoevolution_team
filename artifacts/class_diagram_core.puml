@startuml class_diagram_core

skinparam classAttributeIconSize 0
skinparam classFontSize 13
skinparam packageFontSize 11

class Calculator {
  - _history : list[dict]
  --
  + __init__() : None
  .. History ..
  + get_history() : list[dict]
  + clear_history() : None
  - _record_operation(name, operands, result)
  .. Binary Ops ..
  + add(a, b)
  + subtract(a, b)
  + multiply(a, b)
  + divide(a, b)
  + power(base, exp)
  .. Unary Ops ..
  + square(x)
  + cube(x)
  + square_root(x)
  + cube_root(x)
  + factorial(n)
  + log(x)
  + ln(x)
}

class "«module»\nbasic_operations" as basic_ops {
  + add(a, b)
  + subtract(a, b)
  + multiply(a, b)
  + divide(a, b)
}

class "«module»\nadvanced_operations" as advanced_ops {
  + square(x)
  + cube(x)
  + square_root(x)
  + cube_root(x)
  + factorial(n)
  + power(base, exp)
  + log(x)
  + ln(x)
}

class "«module»\ninterface" as interface_mod {
  + OPERATIONS : dict
  --
  + prompt_for_operator() : str
  + prompt_for_first_number() : float
  + prompt_for_second_number() : float
  + display_result(result) : None
  + display_error(msg) : None
  + display_history(calc) : None
  + display_history_notification() : None
  + run_calculator(calc, max_retries) : str
  + persist_history_to_file(calc) : None
}

class "«exception»\nMaxRetriesExceeded" as max_retries_exc {
}

class "«module»\nbatch_cli" as batch_cli_mod {
  + _BATCH_OPERATIONS : dict
  --
  + parse_batch_args() : namespace
  + execute_batch(calc, args) : float
  + batch_main() : None
  + print_help() : None
}

class "«facade»\ncalculator" as calc_facade {
  note "re-exports Calculator\nfrom calculator_core"
}

class "«facade»\ncli" as cli_facade {
  note "re-exports all\nfrom interface"
}

Calculator --> basic_ops : delegates arithmetic
Calculator --> advanced_ops : delegates math

interface_mod --> Calculator : uses
interface_mod +-- max_retries_exc

batch_cli_mod --> Calculator : uses
batch_cli_mod --> interface_mod : uses (OPERATIONS,\ndisplay functions)

calc_facade ..> Calculator : re-export
cli_facade ..> interface_mod : re-export

@enduml
