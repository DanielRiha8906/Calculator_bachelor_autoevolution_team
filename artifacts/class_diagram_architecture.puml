@startuml class_diagram_architecture

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

package "src.core.operations" {

    class NormalOperations {
        {static} +add(a, b)
        {static} +subtract(a, b)
        {static} +multiply(a, b)
        {static} +divide(a, b)
    }

    class ScientificOperations {
        {static} +factorial(n: int) : int
        {static} +square(x: float) : float
        {static} +cube(x: float) : float
        {static} +square_root(x: float) : float
        {static} +cube_root(x: float) : float
        {static} +logarithm(x: float) : float
        {static} +natural_logarithm(x: float) : float
        {static} +power(base: float, exponent: float) : float
    }
}

package "src.core" {

    class Calculator {
        +add(a, b)
        +subtract(a, b)
        +multiply(a, b)
        +divide(a, b)
        +factorial(n: int) : int
        +square(x: float) : float
        +cube(x: float) : float
        +square_root(x: float) : float
        +cube_root(x: float) : float
        +logarithm(x: float) : float
        +natural_logarithm(x: float) : float
        +power(base: float, exponent: float) : float
    }
}

package "src" {

    class CalculatorSession {
        -_calculator: Calculator
        -_history: OperationHistory
        -_error_logger: ErrorLogger
        -_operation_list: list[str]
        --
        -_get_operation_list() : list[str]
        -_get_arity(op_name: str) : int
        ..
        +select_operation(raw_choice: str, mode: str) : tuple[str|None, int]
        +collect_operands(arity: int, mode: str) : tuple[list[float]|None, int]
        +execute_operation(op_name: str, operands: list[float]) : tuple[object, str|None]
        +get_arity(op_name: str) : int
        +record_history(op_name: str, operands: list[float], result: object) : None
        +get_history() : list[str]
        +save_history(filepath: str) : None
        +get_operation_list() : list[str]
        +max_retries : int <<property>>
    }

    class OperationHistory {
        -_entries: list[str]
        --
        +record_operation(operation_name: str, args: list, result: object) : None
        +get_history() : list[str]
        +clear() : None
        +save_to_file(filepath: str) : None
    }

    class ErrorLogger {
        -_logger: logging.Logger
        --
        -_flush() : None
        +log_unsupported_operation(operation_name: str) : None
        +log_invalid_operand(operand: str, reason: str) : None
        +log_incorrect_arity(operation_name: str, expected: int, got: int) : None
        +log_division_by_zero(numerator: float) : None
        +log_invalid_domain(operation_name: str, operand: float, reason: str) : None
    }
}

package "src.validation" {

    class OperandValidationSession {
        -_mode: str
        -_max_retries: int
        -_attempt_count: int
        --
        +attempt_count : int <<property>>
        +reset_counter() : None
        +validate_input(prompt_fn: Callable, error_msg: str) : float|None
    }

    class OperationValidationSession {
        -_mode: str
        -_available_ops: list[str]
        -_max_retries: int
        -_attempt_count: int
        --
        +attempt_count : int <<property>>
        +reset_counter() : None
        +validate_input(prompt_fn: Callable) : str|None
    }
}

Calculator --> NormalOperations : delegates arithmetic
Calculator --> ScientificOperations : delegates scientific

CalculatorSession *--> OperationHistory : owns
CalculatorSession *--> ErrorLogger : owns
CalculatorSession --> Calculator : uses (injected)
CalculatorSession ..> OperandValidationSession : creates transiently

note right of CalculatorSession
  Encapsulates all REPL state.
  No I/O internally — all I/O
  delegated to cli.interactive_session()
end note

note right of Calculator
  src/calculator.py is a backward-compat
  shim that re-exports this class.
  Canonical location: src/core/calculator.py
end note

@enduml
