@startuml class_diagram_cli

skinparam classAttributeIconSize 0

exception MaxRetriesExceeded {
    Raised when a prompt function exhausts
    max_retries attempts on invalid input
}

class Calculator {
    + add(a, b) : numeric
    + subtract(a, b) : numeric
    + multiply(a, b) : numeric
    + divide(a, b) : numeric
    + power(base, exp) : numeric
    + square(a) : numeric
    + cube(a) : numeric
    + square_root(a) : float
    + cube_root(a) : float
    + factorial(n) : int
    + log(a) : float
    + ln(a) : float
}

class "cli" <<module>> {
    ' Exception
    + MaxRetriesExceeded : exception

    ' Registry
    + OPERATIONS : dict

    ' Prompt functions with retry limits
    + prompt_for_operator(max_retries=3) : str
    + prompt_for_first_number(max_retries=3) : float
    + prompt_for_second_number(max_retries=3) : float

    ' Display functions
    + display_result(first, operator, second, result) : None
    + display_result_unary(operation_key, operand, result) : None
    + display_result_binary(operation_key, first, second, result) : None
    + display_error(error_message) : None

    ' Private helpers
    - _get_operation_arity(key) : int
    - _get_calculator_method(key) : str
    - _get_display_symbol(key) : str

    ' Orchestrator
    + run_calculator(max_retries=3) : float
}

note right of "cli"::OPERATIONS
  12-entry dict:
  key -> (arity, method_name, symbol, description)
  Binary (arity 2): "+", "-", "*", "/", "power"
  Unary  (arity 1): "square", "cube", "sqrt",
                    "cbrt", "factorial", "log", "ln"
end note

note right of "cli"::prompt_for_operator
  Loops until valid operator or max_retries hit.
  Tracks attempt count.
  Raises MaxRetriesExceeded if limit exhausted.
  Displays attempt counter in error message.
end note

note right of "cli"::prompt_for_first_number
  Loops until valid float or max_retries hit.
  Tracks attempt count.
  Raises MaxRetriesExceeded if limit exhausted.
  Displays attempt counter in error message.
end note

note right of "cli"::run_calculator
  Arity-aware dispatch via getattr().
  Passes max_retries to all prompt functions.
  Catches ValueError/ZeroDivisionError from Calculator,
  calls display_error(), then re-raises.
  MaxRetriesExceeded propagates uncaught to main().
end note

class "__main__" <<module>> {
    + main() : None
}

note right of "__main__"::main
  Calls run_calculator(max_retries=3).
  Catches MaxRetriesExceeded -> display_error() -> sys.exit(1).
  Catches ZeroDivisionError and Exception,
  calls display_error() -> sys.exit(1).
end note

"cli" --> Calculator : <<import>>\nCalculator
"cli" --> MaxRetriesExceeded : <<raises>>
"__main__" --> "cli" : <<import>>\nrun_calculator\ndisplay_error\nMaxRetriesExceeded
"__main__" --> MaxRetriesExceeded : <<catches>>

@enduml
