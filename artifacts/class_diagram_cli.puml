@startuml class_diagram_cli

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

package "src/calculator.py" {
    class Calculator {
        .. Binary operations ..
        +add(a, b) : numeric
        +subtract(a, b) : numeric
        +multiply(a, b) : numeric
        +divide(a, b) : numeric
        +power(base: float, exponent: float) : float
        .. Unary operations ..
        +factorial(n: int) : int
        +square(x: float) : float
        +cube(x: float) : float
        +square_root(x: float) : float
        +cube_root(x: float) : float
        +logarithm(x: float) : float
        +natural_logarithm(x: float) : float
    }
}

package "src/cli.py" {
    class "get_operation_menu()" as GetMenu <<function>> {
        +calculator: Calculator
        --
        Returns list[str] of public method names
        Uses dir() + callable() filter
        Excludes dunder methods
    }

    class "get_arity()" as GetArity <<function>> {
        +calculator: Calculator
        +op_name: str
        --
        Returns int (1 or 2)
        Uses inspect.signature()
        Counts params excluding self
    }

    class "parse_float()" as ParseFloat <<function>> {
        +value: str
        --
        Returns float
        Raises ValueError if not numeric
    }

    class "get_operands()" as GetOperands <<function>> {
        +arity: int
        --
        Returns list[float]
        Prompts user arity times
        Re-prompts on ValueError
    }

    class "interactive_session()" as Session <<function>> {
        +calculator: Calculator
        --
        REPL loop: menu -> select -> collect -> dispatch
        Exits on: quit / exit / q
        Catches all Calculator exceptions
    }
}

package "src/__main__.py" {
    class "main()" as Main <<function>> {
        --
        Instantiates Calculator
        Calls interactive_session
    }
}

package "main.py" {
    class "get_operation_arity()" as BashGetArity <<function>> {
        +operation_name: str
        --
        Returns int (arity) or -1 if unknown
        Uses inspect.signature() on unbound method
        Reflects Calculator class (not instance)
    }

    class "parse_arguments()" as ParseArgs <<function>> {
        +args: list[str]
        --
        Returns tuple[str, list[str]]
        Extracts (operation_name, operands_list)
        Exits code 1 if no args
    }

    class "_to_number()" as ToNumber <<function>> {
        +value: str
        --
        Returns int | float
        Tries int() first, falls back to float()
        Raises ValueError if neither works
    }

    class "execute_operation()" as ExecuteOp <<function>> {
        +calc: Calculator
        +operation_name: str
        +operands: list[str]
        --
        Converts operand strings to numbers
        Dispatches via getattr()
        Returns Calculator result
    }

    class "main()" as BashMain <<function>> {
        --
        Bash CLI orchestrator: parse -> validate -> execute
        Exits code 0 on success, 1 on any error
    }
}

Main --> Calculator : <<instantiates>>
Main --> Session : calls

Session --> GetMenu : calls each iteration
Session --> GetArity : calls after selection
Session --> GetOperands : calls to collect inputs
Session --> Calculator : <<dynamic dispatch>>\ngetattr(calc, op_name)(*operands)

GetMenu --> Calculator : introspects via dir()
GetArity --> Calculator : inspects via inspect.signature()
GetOperands --> ParseFloat : validates each input string

BashMain --> ParseArgs : parse sys.argv[1:]
BashMain --> BashGetArity : inspect operation arity
BashMain --> ExecuteOp : invoke operation
BashMain --> Calculator : <<instantiates>>

ExecuteOp --> ToNumber : convert each operand
ExecuteOp --> Calculator : <<dynamic dispatch>>\ngetattr(calc, op_name)(*numeric_operands)
BashGetArity --> Calculator : inspects unbound method via inspect.signature()

note right of BashMain
  Bash CLI: non-interactive, single execution
  parse -> validate arity -> execute -> exit 0/1
end note

note right of BashGetArity
  Key difference from src/cli.py::get_arity():
  Inspects unbound method (Calculator.method)
  NOT bound instance method (calc.method)
  Returns -1 if operation not found
end note

note right of Session
  Interactive REPL: continuous menu loop
  Uses dynamic dispatch with bound methods
end note

@enduml
