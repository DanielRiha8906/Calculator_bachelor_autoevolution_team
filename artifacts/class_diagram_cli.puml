@startuml class_diagram_cli

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

package "src/calculator.py" {
    class Calculator {
        .. Binary operations ..
        +add(a, b) : numeric
        +subtract(a, b) : numeric
        +multiply(a, b) : numeric
        +divide(a, b) : numeric
        +power(base: float, exponent: float) : float
        .. Unary operations ..
        +factorial(n: int) : int
        +square(x: float) : float
        +cube(x: float) : float
        +square_root(x: float) : float
        +cube_root(x: float) : float
        +logarithm(x: float) : float
        +natural_logarithm(x: float) : float
    }
}

package "src/history.py" {
    class OperationHistory {
        -_entries: list[str]
        --
        +record_operation(operation_name: str, args: list, result: object) : None
        +get_history() : list[str]
        +clear() : None
        +save_to_file(filepath: str) : None
    }
}

package "src/error_logger.py" {
    class ErrorLogger {
        -_logger: logging.Logger
        --
        +log_unsupported_operation(operation_name) : None
        +log_invalid_operand(operand, reason) : None
        +log_incorrect_arity(operation_name, expected, got) : None
        +log_division_by_zero(numerator) : None
        +log_invalid_domain(operation_name, operand, reason) : None
    }
}

package "src/formatter.py" <<module>> {
    class "formatter (pure functions)" as Formatter <<module>> {
        {static} +format_menu_header(operations: list[str]) : str
        {static} +format_quit_instruction() : str
        {static} +format_history_header() : str
        {static} +format_operation_error(operation: str) : str
        {static} +format_result(op_name: str, operands: list[float], result: object) : str
        {static} +format_error(error_msg: str) : str
    }
}

package "src/session.py" {
    class CalculatorSession {
        -_calculator: Calculator
        -_history: OperationHistory
        -_error_logger: ErrorLogger
        -_operation_list: list[str]
        --
        +select_operation(raw_choice: str, mode: str) : tuple[str | None, int]
        +collect_operands(arity: int, mode: str) : tuple[list[float] | None, int]
        +execute_operation(op_name: str, operands: list[float]) : tuple[object, str | None]
        +get_arity(op_name: str) : int
        +record_history(op_name: str, operands: list[float], result: object) : None
        +get_history() : list[str]
        +save_history(filepath: str) : None
        +get_operation_list() : list[str]
        +max_retries : int <<property>>
    }
}

package "src/cli.py" {
    class "interactive_session()" as Session <<function>> {
        +calculator: Calculator
        --
        REPL loop: menu -> select -> collect -> execute -> record
        Delegates all state/logic to CalculatorSession
        Uses formatter for all output strings
    }

    class "get_operation_menu()" as GetMenu <<function>> {
        +calculator: Calculator
        --
        Returns list[str] of public method names
        (legacy helper)
    }

    class "get_arity()" as GetArity <<function>> {
        +calculator: Calculator
        +op_name: str
        --
        Returns int (1 or 2)
        (legacy helper)
    }

    class "parse_float()" as ParseFloat <<function>> {
        +value: str
        --
        Returns float
        Raises ValueError if not numeric
    }

    class "get_operands()" as GetOperands <<function>> {
        +arity: int
        +mode: str
        --
        Returns list[float] | None
        (legacy helper)
    }
}

package "src/__main__.py" {
    class "main()" as Main <<function>> {
        --
        Instantiates Calculator
        Calls interactive_session
    }
}

package "main.py" {
    class "main()" as BashMain <<function>> {
        --
        Bash CLI orchestrator: parse -> validate -> execute
        Exits code 0 on success, 1 on any error
    }

    class "execute_operation()" as ExecuteOp <<function>> {
        +calc: Calculator
        +operation_name: str
        +operands: list[str]
        --
        Dispatches via getattr(); returns result
    }
}

' __main__ -> interactive_session
Main --> Calculator : <<instantiates>>
Main ..> Session : calls

' interactive_session delegates to CalculatorSession
Session ..> CalculatorSession : select_operation()
Session ..> CalculatorSession : get_arity()
Session ..> CalculatorSession : collect_operands()
Session ..> CalculatorSession : execute_operation()
Session ..> CalculatorSession : record_history()
Session ..> CalculatorSession : save_history()
Session ..> CalculatorSession : get_history()
Session ..> Formatter : format_menu_header()\nformat_result()\nformat_error()\nformat_history_header()

' CalculatorSession composition
CalculatorSession *-- OperationHistory : owns
CalculatorSession *-- ErrorLogger : owns
CalculatorSession --> Calculator : uses (injected)

' legacy cli helpers
GetMenu --> Calculator : introspects via dir()
GetArity --> Calculator : inspect.signature()
GetOperands --> ParseFloat : validates input

' bash main
BashMain --> ExecuteOp : invoke operation
BashMain --> Calculator : <<instantiates>>

note right of Session
  interactive_session() now delegates
  all REPL state and business logic to
  CalculatorSession. Legacy helper functions
  (get_arity, get_operands, etc.) remain
  for backward compatibility.
end note

note right of Formatter
  Pure functions — no I/O, no imports
  from src/. All output string construction
  is centralised here.
end note

@enduml
