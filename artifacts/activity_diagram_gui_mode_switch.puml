@startuml activity_diagram_gui_mode_switch

start

:User presses Mode button;
:_on_mode_switch() invoked;

:ModeManager.switch_mode();

note right
  Toggles internal state:
  NORMAL -> SCIENTIFIC
  SCIENTIFIC -> NORMAL
end note

:ModeManager.get_current_mode() -> CalculatorMode;

if (mode == SCIENTIFIC?) then (yes)
    :_scientific_frame.pack(side=LEFT, before=_standard_frame);
    :Scientific panel appears to the left;
else (no)
    :_scientific_frame.pack_forget();
    :Scientific panel hidden;
endif

:GUI updates automatically via tkinter event loop;

stop

@enduml
