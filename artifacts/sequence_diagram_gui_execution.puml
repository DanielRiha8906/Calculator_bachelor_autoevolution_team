@startuml sequence_diagram_gui_execution

actor User
participant "CalculatorGUI" as GUI
participant "OperationRegistry" as Registry
participant "Calculator" as Calc
participant "SessionHistory" as History

User ->> GUI : press digit "5"\n_on_digit("5")
activate GUI
GUI ->> GUI : _display_value = "5"\n_is_new_number = False
GUI ->> GUI : _update_display() -> shows "5"
deactivate GUI

User ->> GUI : press "+"\n_on_operator("+")
activate GUI
GUI ->> GUI : float(_display_value) = 5.0\n_accumulated_value = 5.0\n_pending_operator = "+"\n_is_new_number = True
deactivate GUI

User ->> GUI : press digit "3"\n_on_digit("3")
activate GUI
GUI ->> GUI : _is_new_number true\n_display_value = "3"\n_is_new_number = False
GUI ->> GUI : _update_display() -> shows "3"
deactivate GUI

User ->> GUI : press "="\n_on_equals()
activate GUI
GUI ->> GUI : _execute_pending()

GUI ->> Registry : get_operation("add")
activate Registry
Registry -->> GUI : (Calculator.add, 2, "desc")
deactivate Registry

GUI ->> Calc : add(5.0, 3.0)
activate Calc

alt [Calculator raises ValueError / ZeroDivisionError / ArithmeticError]
    Calc -->> GUI : raises exception
    deactivate Calc
    GUI ->> GUI : _display_value = str(exc)
    GUI ->> GUI : _pending_operator = None\n_accumulated_value = None\n_is_new_number = True
    GUI ->> GUI : _update_display() -> shows error message
else success
    Calc -->> GUI : 8.0
    deactivate Calc

    GUI ->> History : record_operation("add", [5.0, 3.0], 8.0)
    activate History
    History -->> GUI : ok
    deactivate History

    GUI ->> GUI : _format_result(8.0) = "8"\n_display_value = "8"\n_accumulated_value = 8.0\n_is_new_number = True
    GUI ->> GUI : _update_display() -> shows "8"
end

deactivate GUI

@enduml
