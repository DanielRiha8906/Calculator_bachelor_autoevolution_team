@startuml sequence_diagram_gui_execution

actor User
participant "CalculatorGUI" as GUI
participant "OperationRegistry" as Registry
participant "validate_operand" as Validation
participant "Calculator" as Calc
participant "SessionHistory" as History

User -> GUI : click Calculate
activate GUI

GUI -> GUI : check listbox selection
alt no operation selected
    GUI -> GUI : _display_error("No operation selected")
    GUI --> User : error label shown
    deactivate GUI
else operation selected
    GUI -> Registry : get_operation(key)
    activate Registry
    Registry --> GUI : (method, arity, description)
    deactivate Registry

    loop for each operand entry (0..arity-1)
        GUI -> Validation : validate_operand(raw_string)
        activate Validation
        alt invalid input
            Validation --> GUI : raises OperandValidationError
            deactivate Validation
            GUI -> GUI : _display_error(msg)
            GUI --> User : error label shown
            deactivate GUI
        else valid input
            Validation --> GUI : float value
            deactivate Validation
        end
    end

    alt operation is factorial
        GUI -> GUI : convert operand to int\n(error if non-integer)
    end

    GUI -> Calc : method(*operands)
    activate Calc
    alt arithmetic error (ZeroDivisionError / ValueError)
        Calc --> GUI : raises exception
        deactivate Calc
        GUI -> GUI : _display_error(msg)
        GUI --> User : error label shown
        deactivate GUI
    else success
        Calc --> GUI : result
        deactivate Calc

        GUI -> GUI : _display_result(op, operands, result)
        GUI --> User : result label updated

        GUI -> History : record_operation(key, operands, result)
        activate History
        History --> GUI : ok
        deactivate History

        GUI -> GUI : _refresh_history_display()
        GUI --> User : history pane updated
        deactivate GUI
    end
end

@enduml
