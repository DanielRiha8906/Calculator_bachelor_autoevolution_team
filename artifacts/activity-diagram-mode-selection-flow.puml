@startuml activity-diagram-mode-selection-flow

skinparam backgroundColor #FEFEFE
skinparam activityBackgroundColor #F8F9FA
skinparam activityBorderColor #495057
skinparam arrowColor #343A40

title iOS Calculator GUI — Mode Toggle and Operation Button Click

|GuiCalculator|

partition "Flow 1: Mode Toggle" {
    start
    :User clicks toggle button;
    :_on_mode_toggle() triggered;
    if (_mode == "normal"?) then (yes)
        :_mode = "scientific";
        :toggle button text → "normal";
    else (no)
        :_mode = "normal";
        :toggle button text → "scientific";
    endif
    :adapter.set_mode(_mode);
    :_selected_op = None;
    :Destroy all child widgets in _grid_frame;
    :_build_button_grid(_grid_frame);
    note right: Rebuilds buttons with\nnew color scheme for mode
    :update_result("0");
    stop
}

partition "Flow 2: Operation Button Click" {
    start
    :User clicks operation button;
    :_on_operation_click(op_name) triggered;
    :_selected_op = op_name;
    :symbol = _SYMBOL_MAP.get(op_name, op_name);
    :update_result(symbol);
    note right: Display refreshes\nto show operation symbol
    stop
}

@enduml
