@startuml class_diagram_gui_layer

skinparam classAttributeIconSize 0

package "GUI Layer" {
    class CalculatorGUI {
        +root: tk.Tk
        --
        -_history: SessionHistory
        -_calc: Calculator
        -_registry: OperationRegistry
        -_mode_manager: ModeManager
        -_display_value: str
        -_accumulated_value: float | None
        -_pending_operator: str | None
        -_is_new_number: bool
        -_main_frame: tk.Frame
        -_display_label: tk.Label
        -_buttons_frame: tk.Frame
        -_standard_frame: tk.Frame
        -_scientific_frame: tk.Frame
        --
        +__init__(root: tk.Tk, history: SessionHistory)
        +run()
        -_build_widgets()
        -_make_button(parent, text, bg, command, column_span) : tk.Button
        -_build_standard_grid(parent)
        -_build_scientific_grid(parent)
        -_update_display()
        -_on_digit(digit: str)
        -_on_decimal()
        -_on_operator(op_symbol: str)
        -_on_equals()
        -_execute_pending()
        -_execute_unary(op_symbol: str)
        -_on_clear()
        -_on_delete()
        -_on_mode_switch()
        -{static} _symbol_to_operation(symbol: str) : str
        -{static} _format_result(value: float) : str
    }

    note right of CalculatorGUI
        iOS-style keypad UI.
        Does not import workflow or CLI components.
        State machine: _accumulated_value +
        _pending_operator manage binary operations.
    end note
}

package "Engine" {
    class Calculator {
        +add(a: float, b: float) : float
        +subtract(a: float, b: float) : float
        +multiply(a: float, b: float) : float
        +divide(a: float, b: float) : float
        +factorial(n: int) : int
        +square(x: float) : float
        +square_root(x: float) : float
        +power(x: float, y: float) : float
        +log(x: float) : float
        +ln(x: float) : float
    }

    class OperationRegistry {
        +__init__(calculator: Calculator)
        +get_operation(key: str) : tuple
        +get_available_operations(mode_manager: ModeManager) : dict
        +register_scientific()
    }

    class ModeManager {
        +switch_mode()
        +get_current_mode() : CalculatorMode
        +is_operation_available() : bool
    }

    enum CalculatorMode {
        NORMAL
        SCIENTIFIC
    }
}

package "Session" {
    class SessionHistory {
        +record_operation()
        +display_history() : str
        +get_history() : list
        +clear()
        +is_empty() : bool
    }
}

CalculatorGUI *-- Calculator         : owns
CalculatorGUI *-- OperationRegistry  : owns
CalculatorGUI *-- ModeManager        : owns
CalculatorGUI o-- SessionHistory     : via constructor

OperationRegistry --> Calculator     : holds bound methods
ModeManager --> CalculatorMode       : uses

@enduml
