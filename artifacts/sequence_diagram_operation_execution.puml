@startuml sequence_diagram_operation_execution

participant "User" as User
participant "main()" as Main
participant "interactive_session()" as Session
participant "get_operation_menu()" as GetMenu
participant "get_arity()" as GetArity
participant "get_operands()" as GetOperands
participant "parse_float()" as ParseFloat
participant "Calculator" as Calc

Main -> Calc : Calculator()
activate Calc

Main -> Session : interactive_session(calc)
activate Session

loop REPL iteration

    Session -> GetMenu : get_operation_menu(calc)
    activate GetMenu
    GetMenu -> Calc : dir(calc) + callable filter
    Calc --> GetMenu : method name list
    GetMenu --> Session : ["add", "cube", "divide", ...]
    deactivate GetMenu

    Session -> User : display numbered menu\n(1. add, 2. cube, ..., quit/exit/q to quit)

    User -> Session : enters "abc" (invalid selection)
    Session -> Session : int("abc") raises ValueError
    Session -> User : "Invalid selection..."

    User -> Session : enters "1" (selects "add")
    Session -> Session : choice = 1, op_name = "add"

    Session -> GetArity : get_arity(calc, "add")
    activate GetArity
    GetArity -> Calc : inspect.signature(calc.add)
    Calc --> GetArity : (a, b) — 2 params
    GetArity --> Session : 2
    deactivate GetArity

    Session -> GetOperands : get_operands(2)
    activate GetOperands

    GetOperands -> User : "Enter operand 1: "
    User -> GetOperands : "hello" (invalid)
    GetOperands -> ParseFloat : parse_float("hello")
    activate ParseFloat
    ParseFloat --> GetOperands : ValueError
    deactivate ParseFloat
    GetOperands -> User : "Invalid input: hello. Please try again."

    GetOperands -> User : "Enter operand 1: "
    User -> GetOperands : "5"
    GetOperands -> ParseFloat : parse_float("5")
    activate ParseFloat
    ParseFloat --> GetOperands : 5.0
    deactivate ParseFloat

    GetOperands -> User : "Enter operand 2: "
    User -> GetOperands : "3"
    GetOperands -> ParseFloat : parse_float("3")
    activate ParseFloat
    ParseFloat --> GetOperands : 3.0
    deactivate ParseFloat

    GetOperands --> Session : [5.0, 3.0]
    deactivate GetOperands

    Session -> Calc : add(5.0, 3.0)\n<<getattr(calc, "add")(5.0, 3.0)>>
    Calc --> Session : 8.0
    Session -> User : "Result: 8.0"

end

alt user types "q" to exit

    Session -> GetMenu : get_operation_menu(calc)
    activate GetMenu
    GetMenu --> Session : ["add", "cube", ...]
    deactivate GetMenu

    Session -> User : display menu
    User -> Session : "q"
    Session -> User : "Goodbye!"

end

deactivate Session
deactivate Calc

@enduml
